#!/usr/bin/env python3
"""Unified verification gate for Golang Harness projects."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path


def bool_from_config(text: str, key: str, default: bool) -> bool:
    match = re.search(rf"^\s*{re.escape(key)}:\s*(true|false)\s*$", text, re.M)
    if not match:
        return default
    return match.group(1) == "true"


def command_text(command: list[str]) -> str:
    return " ".join(command)


def git_changed_paths(project_root: Path) -> list[Path]:
    repo_root = project_root.parent
    commands = [
        ["git", "diff", "--name-only", "HEAD"],
        ["git", "ls-files", "--others", "--exclude-standard"],
    ]
    paths: set[Path] = set()
    for command in commands:
        completed = subprocess.run(command, cwd=str(repo_root), text=True, capture_output=True, check=False)
        if completed.returncode != 0:
            continue
        for line in completed.stdout.splitlines():
            if not line.strip():
                continue
            paths.add((repo_root / line.strip()).resolve())
    return sorted(paths)


def is_relative_to(path: Path, parent: Path) -> bool:
    try:
        path.resolve().relative_to(parent.resolve())
        return True
    except ValueError:
        return False


def changed_change_dirs(paths: list[Path], project_root: Path) -> list[Path]:
    changes_root = project_root / ".cc" / "changes"
    dirs: set[Path] = set()
    for path in paths:
        if not is_relative_to(path, changes_root):
            continue
        relative = path.resolve().relative_to(changes_root.resolve())
        if relative.parts and relative.parts[0] != "task-board.md":
            candidate = changes_root / relative.parts[0]
            if candidate.exists():
                dirs.add(candidate)
    return sorted(dirs)


def has_harness_changes(paths: list[Path], project_root: Path) -> bool:
    repo_root = project_root.parent
    watched_roots = [
        project_root / ".claude",
        project_root / "README.md",
        repo_root / "README.md",
        repo_root / ".github",
    ]
    return any(any(is_relative_to(path, root) if root.is_dir() else path.resolve() == root.resolve() for root in watched_roots) for path in paths)


def has_go_changes(paths: list[Path], project_root: Path) -> bool:
    for path in paths:
        if not is_relative_to(path, project_root):
            continue
        if path.name == "go.mod" or path.name == "go.sum" or path.suffix == ".go":
            return True
    return False


def fingerprints(stdout: str, stderr: str) -> list[str]:
    lines: list[str] = []
    for line in (stdout + "\n" + stderr).splitlines():
        value = re.sub(r"\s+", " ", line.strip())
        if value:
            lines.append(value[:300])
    return sorted(set(lines))


def warnings(stdout: str, stderr: str) -> list[str]:
    warning_lines = []
    for line in (stdout + "\n" + stderr).splitlines():
        if re.search(r"\bwarn(ing)?\b", line, re.I):
            warning_lines.append(re.sub(r"\s+", " ", line.strip())[:300])
    return sorted(set(warning_lines))


def diagnosis_for(name: str, status: str, stderr: str) -> dict[str, str]:
    if status == "passed":
        return {}
    if name == "cc-lint":
        return {
            "cause": "Harness lint found command, rule, or document shape drift.",
            "fix_hint": "Fix the reported lint target before rerunning cc-verify.",
            "doc_ref": ".claude/scripts/cc-lint",
        }
    if name == "cc-sync-check":
        return {
            "cause": "Change documents are out of sync.",
            "fix_hint": "Align spec, tasks, review, test evidence, and validation mapping references.",
            "doc_ref": ".claude/scripts/cc-sync-check",
        }
    if name == "cc-readset":
        return {
            "cause": "Generated runtime readsets are stale or inconsistent.",
            "fix_hint": "Run .claude/scripts/cc-readset --write, review the diff, then rerun cc-verify.",
            "doc_ref": ".claude/runtime/readsets/index.yaml",
        }
    if name == "cc-doctor-check":
        return {
            "cause": "Harness adoption readiness check failed.",
            "fix_hint": "Fix the reported scaffold, script permission, protocol, language profile, or CI fixture issue.",
            "doc_ref": ".claude/docs/adoption/integration-preflight-checklist.md",
        }
    if name == "cc-event-check":
        return {
            "cause": "Lifecycle event log validation failed.",
            "fix_hint": "Fix invalid .cc/changes/<change-id>/events.jsonl records or remove incomplete event drafts.",
            "doc_ref": ".claude/schemas/command-event.schema.json",
        }
    if name == "cc-behavior-check":
        return {
            "cause": "Behavior replay eval failed.",
            "fix_hint": "Fix the regressed behavior or update the behavior case only when the contract intentionally changed.",
            "doc_ref": ".claude/evals/behavior",
        }
    if name == "cc-schema-check":
        return {
            "cause": "Runtime, protocol, topic rule, or change document schema validation failed.",
            "fix_hint": "Fix the reported schema issue; do not bypass schema drift with manual readset edits.",
            "doc_ref": ".claude/scripts/cc-schema-check",
        }
    if name == "cc-role-check":
        return {
            "cause": "Command write scope or role contract validation failed.",
            "fix_hint": "Align the command writes with workflow/runtime contracts and registered roles.",
            "doc_ref": ".claude/rules/role-contracts.md",
        }
    if name == "change-dir":
        return {
            "cause": "The requested change directory does not exist.",
            "fix_hint": "Provide an existing change_id or create the proposal before running change-scoped checks.",
            "doc_ref": ".cc/changes/task-board.md",
        }
    if name == "go checks" and "explicit fixture" in stderr:
        return {
            "cause": "The explicit fixture path does not resolve to a Go module.",
            "fix_hint": "Use a fixture path containing go.mod, such as .claude/fixtures/go-http-user-service.",
            "doc_ref": ".claude/runtime/languages/golang.yaml",
        }
    if name in {"go test", "go vet", "golangci-lint"}:
        return {
            "cause": f"{name} failed for the selected Go project.",
            "fix_hint": "Inspect the command output, fix the Go failure, then rerun cc-verify.",
            "doc_ref": ".claude/runtime/languages/golang.yaml",
        }
    if status == "skipped":
        return {
            "cause": "This check was skipped because its entrypoint was not found or disabled.",
            "fix_hint": "Confirm the skip is intentional; explicit fixture paths should point to a real go.mod.",
            "doc_ref": ".claude/harness.config.yaml",
        }
    return {
        "cause": "Verification step failed.",
        "fix_hint": "Inspect stdout, stderr, and fingerprints for the failing command.",
        "doc_ref": ".claude/scripts/cc-verify",
    }


def run_step(name: str, kind: str, command: list[str], cwd: Path) -> dict[str, object]:
    started = time.time()
    try:
        env = os.environ.copy()
        if kind == "go" and "GOCACHE" not in env:
            env["GOCACHE"] = "/tmp/cc-go-build"
        completed = subprocess.run(
            command,
            cwd=str(cwd),
            text=True,
            capture_output=True,
            check=False,
            env=env,
        )
        duration_ms = int((time.time() - started) * 1000)
        status = "passed" if completed.returncode == 0 else "failed"
        result = {
            "name": name,
            "kind": kind,
            "command": command,
            "cwd": str(cwd),
            "status": status,
            "exit_code": completed.returncode,
            "duration_ms": duration_ms,
            "stdout": completed.stdout,
            "stderr": completed.stderr,
            "fingerprints": fingerprints(completed.stdout, completed.stderr) if completed.returncode else [],
            "warnings": warnings(completed.stdout, completed.stderr),
        }
        result["diagnosis"] = diagnosis_for(name, status, completed.stderr)
        return result
    except FileNotFoundError as exc:
        duration_ms = int((time.time() - started) * 1000)
        message = str(exc)
        return {
            "name": name,
            "kind": kind,
            "command": command,
            "cwd": str(cwd),
            "status": "failed",
            "exit_code": 127,
            "duration_ms": duration_ms,
            "stdout": "",
            "stderr": message,
            "fingerprints": [message],
            "warnings": [],
            "diagnosis": diagnosis_for(name, "failed", message),
        }


def skipped_step(name: str, kind: str, reason: str) -> dict[str, object]:
    return {
        "name": name,
        "kind": kind,
        "command": [],
        "cwd": "",
        "status": "skipped",
        "exit_code": 0,
        "duration_ms": 0,
        "stdout": "",
        "stderr": reason,
        "fingerprints": [],
        "warnings": [],
        "diagnosis": diagnosis_for(name, "skipped", reason),
    }


def failed_step(name: str, kind: str, reason: str, cwd: Path) -> dict[str, object]:
    return {
        "name": name,
        "kind": kind,
        "command": [],
        "cwd": str(cwd),
        "status": "failed",
        "exit_code": 1,
        "duration_ms": 0,
        "stdout": "",
        "stderr": reason,
        "fingerprints": [reason],
        "warnings": [],
        "diagnosis": diagnosis_for(name, "failed", reason),
    }


def build_report(args: argparse.Namespace) -> dict[str, object]:
    claude_root = Path(__file__).resolve().parent.parent
    project_root = claude_root.parent
    changes_root = project_root / ".cc" / "changes"
    go_project_root = (project_root / args.fixture).resolve() if args.fixture else project_root
    config_path = claude_root / "harness.config.yaml"
    config_text = config_path.read_text(encoding="utf-8") if config_path.exists() else ""
    change_dir = changes_root / args.change if args.change else None
    changed_paths = git_changed_paths(project_root) if args.changed_only else []
    changed_dirs = changed_change_dirs(changed_paths, project_root) if args.changed_only else []
    harness_changed = has_harness_changes(changed_paths, project_root) if args.changed_only else False

    results: list[dict[str, object]] = []
    if args.change and change_dir and not change_dir.exists():
        results.append(
            {
                "name": "change-dir",
                "kind": "harness",
                "command": [],
                "cwd": str(project_root),
                "status": "failed",
                "exit_code": 1,
                "duration_ms": 0,
                "stdout": "",
                "stderr": f"{change_dir} not found",
                "fingerprints": [f"{change_dir} not found"],
                "warnings": [],
            }
        )
    if not args.go_only:
        cc_lint = claude_root / "scripts" / "cc-lint"
        cc_sync_check = claude_root / "scripts" / "cc-sync-check"
        cc_readset = claude_root / "scripts" / "cc-readset"
        cc_doctor_check = claude_root / "scripts" / "cc-doctor-check"
        cc_event_check = claude_root / "scripts" / "cc-event-check"
        cc_behavior_check = claude_root / "scripts" / "cc-behavior-check"
        cc_schema_check = claude_root / "scripts" / "cc-schema-check"
        cc_role_check = claude_root / "scripts" / "cc-role-check"
        sync_target = change_dir if change_dir and change_dir.exists() else changes_root
        if args.changed_only:
            if not harness_changed and not changed_dirs:
                results.append(skipped_step("changed-only", "harness", "no changed Harness or change files detected"))
            lint_targets = [str(claude_root)] if harness_changed else []
            lint_targets.extend(str(path) for path in changed_dirs)
            if lint_targets:
                results.append(run_step("cc-lint", "harness", [str(cc_lint), *lint_targets], project_root))
            if changed_dirs:
                changed_dir_args = [str(path) for path in changed_dirs]
                results.append(run_step("cc-sync-check", "harness", [str(cc_sync_check), *changed_dir_args], project_root))
                results.append(run_step("cc-event-check", "harness", [str(cc_event_check), *changed_dir_args], project_root))
                results.append(run_step("cc-schema-check", "harness", [str(cc_schema_check), *changed_dir_args], project_root))
            if harness_changed:
                results.append(run_step("cc-readset", "harness", [str(cc_readset), "--check"], project_root))
                results.append(run_step("cc-doctor-check", "harness", [str(cc_doctor_check)], project_root))
                if os.environ.get("CC_BEHAVIOR_REPLAY") != "1":
                    results.append(run_step("cc-behavior-check", "harness", [str(cc_behavior_check)], project_root))
                results.append(run_step("cc-schema-check", "harness", [str(cc_schema_check), str(sync_target)], project_root))
        else:
            lint_targets = [str(claude_root)]
            if sync_target.exists():
                lint_targets.append(str(sync_target))
            results.append(run_step("cc-lint", "harness", [str(cc_lint), *lint_targets], project_root))
            results.append(run_step("cc-sync-check", "harness", [str(cc_sync_check), str(sync_target)], project_root))
            results.append(run_step("cc-readset", "harness", [str(cc_readset), "--check"], project_root))
            results.append(run_step("cc-doctor-check", "harness", [str(cc_doctor_check)], project_root))
            results.append(run_step("cc-event-check", "harness", [str(cc_event_check), str(sync_target)], project_root))
            if os.environ.get("CC_BEHAVIOR_REPLAY") != "1":
                results.append(run_step("cc-behavior-check", "harness", [str(cc_behavior_check)], project_root))
            results.append(run_step("cc-schema-check", "harness", [str(cc_schema_check), str(sync_target)], project_root))
        if args.command:
            command = [str(cc_role_check), "--command", args.command]
            if args.change:
                command.extend(["--change", args.change])
            results.append(run_step("cc-role-check", "harness", command, project_root))

    run_go_checks = not args.harness_only
    if args.changed_only and not args.fixture and not args.go_only and not has_go_changes(changed_paths, project_root):
        run_go_checks = False
    if run_go_checks:
        go_mod = go_project_root / "go.mod"
        if not go_mod.exists():
            if args.fixture:
                results.append(
                    failed_step(
                        "go checks",
                        "go",
                        f"explicit fixture {args.fixture} is invalid: {go_mod} not found",
                        go_project_root,
                    )
                )
            else:
                results.append(skipped_step("go checks", "go", f"{go_mod} not found"))
        else:
            if bool_from_config(config_text, "test", True):
                results.append(run_step("go test", "go", ["go", "test", "./..."], go_project_root))
            if bool_from_config(config_text, "vet", True):
                results.append(run_step("go vet", "go", ["go", "vet", "./..."], go_project_root))
            if bool_from_config(config_text, "golangci_lint", False):
                if shutil.which("golangci-lint"):
                    results.append(run_step("golangci-lint", "go", ["golangci-lint", "run"], go_project_root))
                else:
                    results.append(skipped_step("golangci-lint", "go", "golangci-lint not found"))

    failed = [result for result in results if result["status"] == "failed"]
    report = {
        "schema_version": 1,
        "tool": "cc-verify",
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "project_root": str(project_root),
        "claude_root": str(claude_root),
        "change_id": args.change or "",
        "fixture": args.fixture or "",
        "command": args.command or "",
        "mode": "changed-only" if args.changed_only else "harness-only" if args.harness_only else "go-only" if args.go_only else "full",
        "changed_files": [str(path) for path in changed_paths],
        "status": "failed" if failed else "passed",
        "results": results,
    }
    return report


def print_text(report: dict[str, object], verbose: bool) -> None:
    print(f"cc-verify: {report['status']} ({report['mode']})")
    for result in report["results"]:
        status = str(result["status"]).upper()
        command = command_text(result["command"]) if result["command"] else str(result["stderr"])
        print(f"{status:7} {result['name']}: {command}")
        if verbose or result["status"] == "failed":
            stdout = str(result["stdout"]).strip()
            stderr = str(result["stderr"]).strip()
            if stdout:
                print(stdout)
            if stderr:
                print(stderr, file=sys.stderr)
            diagnosis = result.get("diagnosis")
            if isinstance(diagnosis, dict) and diagnosis:
                cause = diagnosis.get("cause", "")
                fix_hint = diagnosis.get("fix_hint", "")
                doc_ref = diagnosis.get("doc_ref", "")
                if cause:
                    print(f"cause: {cause}")
                if fix_hint:
                    print(f"fix_hint: {fix_hint}")
                if doc_ref:
                    print(f"doc_ref: {doc_ref}")


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Run Golang Harness verification checks.")
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--harness-only", action="store_true", help="Only run Harness document checks.")
    mode.add_argument("--go-only", action="store_true", help="Only run Go project checks.")
    parser.add_argument("--change", help="Limit sync checks and report metadata to one change-id.")
    parser.add_argument("--fixture", help="Run Go checks from a fixture path relative to the project root.")
    parser.add_argument("--command", help="Run role/write-scope checks for a cc-* command.")
    parser.add_argument("--changed-only", action="store_true", help="Run the smallest deterministic check set for changed files.")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    parser.add_argument("--output", help="Write JSON report to this file.")
    parser.add_argument("--verbose", action="store_true", help="Show command output for passing steps.")
    args = parser.parse_args(argv)

    report = build_report(args)
    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(json.dumps(report, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    if args.json and not args.output:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        print_text(report, args.verbose)
        if args.output:
            print(f"report: {args.output}")
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
