{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loop Engineering Trust Envelope Configuration Schema",
  "description": "Validates loop-config.yaml for autonomous agent execution boundaries",
  "type": "object",
  "required": ["version", "trust_envelope"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "trust_envelope": {
      "type": "object",
      "required": [
        "max_scope",
        "max_residual_risk",
        "allowed_change_types",
        "disallowed_change_types"
      ],
      "properties": {
        "max_scope": {
          "type": "string",
          "enum": ["micro", "small", "medium", "large", "xlarge"]
        },
        "max_residual_risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "allowed_change_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "disallowed_change_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "autonomy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scope_overage": {
              "type": "string",
              "enum": ["supervised", "staged", "blocked"]
            },
            "risk_overage": {
              "type": "string",
              "enum": ["staged", "blocked"]
            }
          }
        },
        "accepted_finding_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification": {
          "type": "object",
          "properties": {
            "require_all_tests_pass": {
              "type": "boolean"
            },
            "require_no_open_findings": {
              "type": "boolean"
            },
            "require_validation_mapping_closed": {
              "type": "boolean"
            }
          }
        },
        "knowledge": {
          "type": "object",
          "properties": {
            "auto_compound_when_obvious": {
              "type": "boolean"
            },
            "default_action": {
              "type": "string",
              "enum": [
                "no_knowledge_compounding",
                "create_new_knowledge",
                "update_existing_knowledge"
              ]
            }
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "properties": {
        "max_consecutive_escalations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "max_auto_approvals_per_day": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "token_budget_multiplier": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 3.0
        }
      }
    },
    "notifications": {
      "type": "object",
      "properties": {
        "notify_on": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "escalation",
              "circuit_breaker",
              "trust_envelope_exceeded",
              "verification_failed",
              "daily_audit_summary"
            ]
          }
        },
        "channel": {
          "type": "string",
          "enum": ["loop_audit_file"]
        }
      }
    }
  }
}
