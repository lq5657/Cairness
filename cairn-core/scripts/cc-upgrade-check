#!/usr/bin/env python3
"""Upgrade safety checks for Harness projects."""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
import tarfile
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

from harness_runtime import load_runtime_protocol, protocol_language_assets, runtime_protocol_asset_declarations
from harness_runtime.issues import Issue, add, issues_to_dicts
from harness_runtime.context import HarnessContext, HarnessContextError, load_harness_context
from harness_runtime.versioning import (
    VersionMetadataError,
    normalize_release_tag,
    read_pyproject_version,
    read_version,
)


def read(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def require(path: Path, kind: str, issues: list[Issue], code: str = "E_UPGRADE001") -> None:
    if kind == "file" and not path.is_file():
        add(issues, code, path, "missing file")
    if kind == "dir" and not path.is_dir():
        add(issues, code, path, "missing directory")


def check_version_docs(claude_root: Path, issues: list[Issue]) -> dict[str, str]:
    version_path = claude_root / "VERSION"
    changelog_path = claude_root / "CHANGELOG.md"
    upgrade_path = claude_root / "UPGRADE.md"
    require(version_path, "file", issues)
    require(changelog_path, "file", issues)
    require(upgrade_path, "file", issues)
    version = read(version_path).strip() if version_path.exists() else ""
    if version and upgrade_path.exists():
        content = read(upgrade_path)
        if f"Upgrade To {version}" not in content and f"升级到 {version}" not in content:
            add(issues, "E_UPGRADE002", upgrade_path, f"missing upgrade section for current version {version}")
    if version and changelog_path.exists() and version not in read(changelog_path):
        add(issues, "E_UPGRADE003", changelog_path, f"missing changelog entry for current version {version}")
    return {"version": version}


def check_repository_version_metadata(
    repository_root: Path,
    framework_root: Path,
    *,
    exact_tag: str = "",
    require_release_tag: bool = False,
) -> list[Issue]:
    issues: list[Issue] = []
    version_path = framework_root / "VERSION"
    pyproject_path = repository_root / "pyproject.toml"
    try:
        version = read_version(version_path)
    except VersionMetadataError as exc:
        add(issues, "E_UPGRADE008", version_path, str(exc))
        return issues
    try:
        mirror = read_pyproject_version(pyproject_path)
    except VersionMetadataError as exc:
        add(issues, "E_UPGRADE008", pyproject_path, str(exc))
    else:
        if mirror != version:
            add(
                issues,
                "E_UPGRADE009",
                pyproject_path,
                f"pyproject version {mirror} does not match VERSION {version}",
            )
    tag_version = normalize_release_tag(exact_tag) if exact_tag else None
    if exact_tag and tag_version and tag_version != version:
        add(issues, "E_UPGRADE010", repository_root, f"release tag {exact_tag} does not match VERSION {version}")
    if require_release_tag and not tag_version:
        add(issues, "E_UPGRADE011", repository_root, "HEAD must have an exact Cairness release tag")
    return issues


def exact_head_tag(repository_root: Path) -> str:
    result = subprocess.run(
        ["git", "describe", "--tags", "--exact-match", "HEAD"],
        cwd=repository_root,
        capture_output=True,
        text=True,
    )
    return result.stdout.strip() if result.returncode == 0 else ""


def check_release_artifact(artifact: Path, version: str, exact_tag: str) -> list[Issue]:
    issues: list[Issue] = []
    expected_stem = f"cairness-{version}"
    artifact_name = artifact.name
    if not artifact_name.startswith(expected_stem + "."):
        add(issues, "E_UPGRADE012", artifact, f"artifact filename must start with {expected_stem}.")
    try:
        with tarfile.open(artifact, "r:*") as archive:
            member = next(
                (item for item in archive.getmembers() if item.name.rstrip("/").endswith("cairn-core/VERSION")),
                None,
            )
            extracted = archive.extractfile(member) if member is not None else None
            internal = extracted.read().decode("utf-8").strip() if extracted is not None else ""
    except (OSError, tarfile.TarError, UnicodeDecodeError) as exc:
        add(issues, "E_UPGRADE013", artifact, f"cannot read artifact VERSION: {exc}")
    else:
        if internal != version:
            add(issues, "E_UPGRADE013", artifact, f"artifact VERSION {internal or 'missing'} does not match {version}")
    tag_version = normalize_release_tag(exact_tag)
    if tag_version != version:
        add(issues, "E_UPGRADE010", artifact, f"release tag {exact_tag or 'missing'} does not match VERSION {version}")
    return issues


def check_state_separation(
    project_root: Path,
    claude_root: Path,
    issues: list[Issue],
    *,
    require_state_dirs: bool = True,
) -> None:
    # E_UPGRADE004 asserts an *installed target project* preserved its state
    # dirs across upgrade. The framework source repo is not an installed
    # project -- its .cairness/ is gitignored and legitimately absent on a
    # clean checkout -- so callers pass require_state_dirs=False for it. The
    # E_UPGRADE005 misplacement check below still runs everywhere.
    if require_state_dirs:
        for state_dir in ("context", "changes", "knowledge"):
            require(project_root / ".cairness" / state_dir, "dir", issues, "E_UPGRADE004")
    legacy_state_paths = [
        claude_root / "context",
        claude_root / "changes" / "task-board.md",
        claude_root / "audits",
        claude_root / "knowledge",
    ]
    for path in legacy_state_paths:
        if path.exists():
            add(issues, "E_UPGRADE005", path, "project state must live under .cairness, not .claude")


FRAMEWORK_POLLUTION_MARKERS = [
    "VERSION",
    "CHANGELOG.md",
    "UPGRADE.md",
    "runtime",
    "rules",
    "schemas",
    "scripts",
    "workflows",
    "templates",
]


def check_state_pollution(project_root: Path, issues: list[Issue]) -> None:
    """Framework assets must not leak into .cairness/ (reverse of E_UPGRADE005).

    E_UPGRADE005 catches project state misplaced under .claude/; this catches
    framework assets misplaced under .cairness/, which an unsafe upgrade could
    then clobber or carry forward incorrectly.
    """
    cairness = project_root / ".cairness"
    if not cairness.is_dir():
        return
    for marker in FRAMEWORK_POLLUTION_MARKERS:
        path = cairness / marker
        if path.exists():
            add(issues, "E_UPGRADE007", path, "framework asset must not live under .cairness")


def check_upgrade_boundaries(
    project_root: Path,
    claude_root: Path,
    issues: list[Issue],
    context: HarnessContext | None = None,
) -> None:
    framework_assets = [
        claude_root / "runtime",
        claude_root / "rules",
        claude_root / "schemas",
        claude_root / "scripts",
        claude_root / "workflows",
        claude_root / "templates",
        claude_root / "docs",
    ]
    for path in framework_assets:
        require(path, "dir", issues, "E_UPGRADE006")
    creation_templates = [
        claude_root / "templates" / "context" / "project-summary.md",
        claude_root / "templates" / "context" / "project-context.md",
        claude_root / "templates" / "context" / "domain-language.md",
        claude_root / "templates" / "context" / "dev-map.md",
        claude_root / "templates" / "changes" / "task-board.md",
        claude_root / "templates" / "knowledge" / "index.md",
    ]
    for path in creation_templates:
        require(path, "file", issues, "E_UPGRADE006")
    core, protocol, _ = load_runtime_protocol(project_root, claude_root)
    resolve = context.resolve_path if context is not None else lambda declared: project_root / declared
    technology_assets = [
        (claude_root / "runtime" / "technology", "dir"),
        (claude_root / "runtime" / "result-contracts" / "standard-command.yaml", "file"),
        (claude_root / "schemas" / "technology-decision-catalog.schema.json", "file"),
        *[(resolve(declared), "file") for declared in runtime_protocol_asset_declarations(core)],
        *[(resolve(declared), "file") for declared in protocol_language_assets(project_root, protocol, framework_root=claude_root)],
    ]
    for path, kind in technology_assets:
        require(path, kind, issues, "E_UPGRADE006")


def build_report(
    project_root: Path | None = None,
    claude_root: Path | None = None,
    *,
    require_release_tag: bool = False,
    release_artifact: Path | None = None,
    context: HarnessContext | None = None,
) -> dict[str, Any]:
    if context is not None:
        project_root = context.project_root
        claude_root = context.framework_root
    elif claude_root is None:
        claude_root = Path(__file__).resolve().parent.parent
    if project_root is None:
        project_root = claude_root.parent
    issues: list[Issue] = []
    repository_root = claude_root.parent
    is_framework_source = (
        (repository_root / "pyproject.toml").is_file()
        and (repository_root / "cairn_install").is_file()
    )
    metadata = check_version_docs(claude_root, issues)
    check_state_separation(
        project_root, claude_root, issues, require_state_dirs=not is_framework_source
    )
    check_state_pollution(project_root, issues)
    check_upgrade_boundaries(project_root, claude_root, issues, context)
    if is_framework_source:
        exact_tag = exact_head_tag(repository_root)
        issues.extend(
            check_repository_version_metadata(
                repository_root,
                claude_root,
                exact_tag=exact_tag,
                require_release_tag=require_release_tag,
            )
        )
        if release_artifact is not None:
            try:
                version = read_version(claude_root / "VERSION")
            except VersionMetadataError:
                pass
            else:
                issues.extend(check_release_artifact(release_artifact, version, exact_tag))
    return {
        "tool": "cc-upgrade-check",
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "status": "failed" if issues else "passed",
        "project_root": str(project_root),
        "version": metadata.get("version", ""),
        "protected_state_root": str(project_root / ".cairness"),
        "replaceable_framework_root": str(claude_root),
        "issues": issues_to_dicts(issues),
    }


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Check Harness upgrade safety boundaries.")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    parser.add_argument("--output", help="Write JSON report to this file.")
    parser.add_argument("--root", help="Explicit Cairness project root; overrides automatic discovery.")
    parser.add_argument(
        "--require-release-tag",
        action="store_true",
        help="Require HEAD to have an exact release tag matching VERSION.",
    )
    parser.add_argument(
        "--release-artifact",
        type=Path,
        help="Validate a Cairness tar archive name and internal VERSION against the exact Git tag.",
    )
    args = parser.parse_args(argv)

    try:
        context = load_harness_context(
            explicit_root=Path(args.root) if args.root else None,
            framework_hint=None if args.root else Path(__file__).resolve().parent.parent,
        )
    except HarnessContextError as exc:
        print(f"E_CONTEXT001 {exc}", file=sys.stderr)
        return 2
    report = build_report(
        require_release_tag=args.require_release_tag or args.release_artifact is not None,
        release_artifact=args.release_artifact,
        context=context,
    )
    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(json.dumps(report, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    if args.json and not args.output:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    elif report["status"] == "passed":
        print("cc-upgrade-check: ok")
        if args.output:
            print(f"report: {args.output}")
    else:
        for issue in report["issues"]:
            print(f"{issue['code']} {issue['path']}: {issue['message']}", file=sys.stderr)
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
