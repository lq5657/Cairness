#!/usr/bin/env python3
"""Metadata and document-shape checks for Golang Harness artifacts.

The checker accepts both YAML frontmatter and the legacy fenced metadata block
used by earlier Harness examples. This lets projects migrate metadata format
without breaking existing changes.
"""

from __future__ import annotations

import argparse
import json
import re
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Any


CHANGE_ID_RE = re.compile(r"^[a-z0-9]+(-[a-z0-9]+)*$")
VALID_CHANGE_STATUS = {"propose", "apply", "review", "done"}
VALID_TASK_STATUS = {"todo", "in_progress", "blocked", "partial", "aborted", "done"}
VALID_MAPPING_STATUS = {"todo", "apply-covered", "test-covered", "gap"}
VALID_TEST_MODE = {"supplement", "recovery"}
VALID_REVIEW_STATUS = {
    "stage1_status": {"pass", "fail", "partial"},
    "stage2_status": {"pass", "fail", "skipped", "partial"},
    "final_status": {"pass", "fail", "partial"},
}
EVIDENCE_BY_LEVEL = {
    "L1": {"build", "doc-check"},
    "L2": {"package", "unit"},
    "L3": {"chain"},
    "L4": {"integration", "manual"},
    "L5": {"migration-safety", "release-safety"},
}
HARD_GATE_FIELDS = [
    "confirmed_at",
    "confirmed_by",
    "confirmed_spec_revision",
    "confirmed_tasks_revision",
    "confirmed_scope",
    "accepted_risks",
    "human_review_required",
    "human_review_status",
]
TASK_FIELDS = [
    "**目标**",
    "**涉及文件**",
    "**验收标准**",
    "**验证步骤**",
    "**测试要求**",
    "**回退方式**",
    "**完成后状态**",
    "**Baseline / Delta",
]
RUNTIME_CORE_SCHEMA = "runtime-core.schema.json"
RUNTIME_COMMAND_SCHEMA = "runtime-command.schema.json"
SUBAGENT_REQUIRED_COMMANDS = {
    "cc-apply",
    "cc-review",
    "cc-fix",
    "cc-test",
    "cc-inspect-codebase",
}
ANTI_RATIONALIZATION_COMMANDS = {
    "cc-propose",
    "cc-apply",
    "cc-review",
    "cc-fix",
    "cc-test",
}
READ_ONLY_SUBAGENT_MODES = {"read_only", "proposal_only"}


@dataclass
class Issue:
    code: str
    path: str
    message: str


def read(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def parse_scalar(raw: str) -> Any:
    value = raw.strip().strip('"').strip("'")
    if value == "[]":
        return []
    if value.startswith("[") and value.endswith("]"):
        body = value[1:-1].strip()
        if not body:
            return []
        return [item.strip().strip('"').strip("'") for item in body.split(",")]
    if value.lower() == "true":
        return True
    if value.lower() == "false":
        return False
    return value


def parse_key_values(block: str) -> dict[str, Any]:
    meta: dict[str, Any] = {}
    for line in block.splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or ":" not in stripped:
            continue
        key, value = stripped.split(":", 1)
        meta[key.strip()] = parse_scalar(value.split("#", 1)[0])
    return meta


def parse_frontmatter(text: str) -> dict[str, Any]:
    if not text.startswith("---\n"):
        return {}
    end = text.find("\n---", 4)
    if end == -1:
        return {}
    block = text[4:end]
    try:
        import yaml  # type: ignore

        loaded = yaml.safe_load(block)
        return loaded if isinstance(loaded, dict) else {}
    except Exception:
        return parse_key_values(block)


def parse_legacy_meta(text: str) -> dict[str, Any]:
    match = re.search(r"```(?:text)?\n(.*?)\n```", text, re.S)
    if match:
        return parse_key_values(match.group(1))
    return parse_key_values("\n".join(text.splitlines()[:25]))


def parse_meta(text: str) -> dict[str, Any]:
    return parse_frontmatter(text) or parse_legacy_meta(text)


def table_rows(text: str) -> list[list[str]]:
    rows: list[list[str]] = []
    for line in text.splitlines():
        stripped = line.strip()
        if not stripped.startswith("|") or "---" in stripped:
            continue
        rows.append([cell.strip().strip("`") for cell in stripped.strip("|").split("|")])
    return rows


def validation_rows(text: str) -> list[list[str]]:
    return [row for row in table_rows(text) if row and re.fullmatch(r"V[0-9]+", row[0])]


def task_sections(text: str) -> list[str]:
    matches = list(re.finditer(r"^#### Task [0-9]+:", text, re.M))
    sections: list[str] = []
    for idx, match in enumerate(matches):
        start = match.start()
        end = matches[idx + 1].start() if idx + 1 < len(matches) else len(text)
        sections.append(text[start:end])
    return sections


def finding_rows(text: str) -> list[list[str]]:
    match = re.search(r"#### 5\. Findings(.*?)(?:\n#### 6\.|\Z)", text, re.S)
    if not match:
        return []
    return [
        row
        for row in table_rows(match.group(1))
        if len(row) >= 5 and row[0] in {"Critical", "Important", "Minor", "无"}
    ]


def add(issues: list[Issue], code: str, path: Path, message: str) -> None:
    issues.append(Issue(code=code, path=str(path), message=message))


def load_json_file(path: Path, issues: list[Issue]) -> dict[str, Any] | None:
    if not path.exists():
        add(issues, "E_SCHEMA100", path, "missing JSON schema")
        return None
    try:
        loaded = json.loads(read(path))
    except json.JSONDecodeError as exc:
        add(issues, "E_SCHEMA101", path, f"invalid JSON schema: {exc}")
        return None
    if not isinstance(loaded, dict):
        add(issues, "E_SCHEMA102", path, "JSON schema root must be an object")
        return None
    return loaded


def load_yaml_file(path: Path, issues: list[Issue]) -> dict[str, Any] | None:
    if not path.exists():
        add(issues, "E_SCHEMA103", path, "missing YAML manifest")
        return None
    try:
        import yaml  # type: ignore
    except Exception as exc:
        add(issues, "E_SCHEMA104", path, f"PyYAML is required to parse runtime manifests: {exc}")
        return None
    try:
        loaded = yaml.safe_load(read(path))
    except Exception as exc:
        add(issues, "E_SCHEMA105", path, f"invalid YAML manifest: {exc}")
        return None
    if not isinstance(loaded, dict):
        add(issues, "E_SCHEMA106", path, "YAML manifest root must be a mapping")
        return None
    return loaded


def schema_location(parts: list[str | int]) -> str:
    if not parts:
        return "<root>"
    return ".".join(str(part) for part in parts)


def type_matches(value: Any, expected: str) -> bool:
    if expected == "object":
        return isinstance(value, dict)
    if expected == "array":
        return isinstance(value, list)
    if expected == "string":
        return isinstance(value, str)
    if expected == "integer":
        return isinstance(value, int) and not isinstance(value, bool)
    if expected == "boolean":
        return isinstance(value, bool)
    if expected == "null":
        return value is None
    return True


def json_type_name(value: Any) -> str:
    if isinstance(value, dict):
        return "object"
    if isinstance(value, list):
        return "array"
    if isinstance(value, str):
        return "string"
    if isinstance(value, bool):
        return "boolean"
    if isinstance(value, int):
        return "integer"
    if value is None:
        return "null"
    return type(value).__name__


def resolve_schema_ref(ref: str, root_schema: dict[str, Any]) -> dict[str, Any]:
    if not ref.startswith("#/"):
        raise ValueError(f"unsupported schema ref {ref}")
    current: Any = root_schema
    for raw_part in ref[2:].split("/"):
        part = raw_part.replace("~1", "/").replace("~0", "~")
        current = current[part]
    if not isinstance(current, dict):
        raise ValueError(f"schema ref {ref} does not point to an object")
    return current


def validate_against_schema(
    value: Any,
    schema: dict[str, Any],
    root_schema: dict[str, Any],
    path: list[str | int],
    subject_path: Path,
    issues: list[Issue],
) -> None:
    if "$ref" in schema:
        try:
            schema = resolve_schema_ref(str(schema["$ref"]), root_schema)
        except Exception as exc:
            add(issues, "E_SCHEMA107", subject_path, f"{schema_location(path)}: {exc}")
            return

    location = schema_location(path)
    if "const" in schema and value != schema["const"]:
        add(issues, "E_SCHEMA108", subject_path, f"{location}: expected constant {schema['const']!r}")
        return
    if "enum" in schema and value not in schema["enum"]:
        add(issues, "E_SCHEMA109", subject_path, f"{location}: value {value!r} is not one of {schema['enum']!r}")

    expected_type = schema.get("type")
    if expected_type is not None:
        expected_types = expected_type if isinstance(expected_type, list) else [expected_type]
        if not any(type_matches(value, str(item)) for item in expected_types):
            add(
                issues,
                "E_SCHEMA110",
                subject_path,
                f"{location}: expected type {expected_type!r}, got {json_type_name(value)}",
            )
            return

    if isinstance(value, str):
        if "minLength" in schema and len(value) < int(schema["minLength"]):
            add(issues, "E_SCHEMA111", subject_path, f"{location}: string is shorter than minLength")
        if "pattern" in schema and re.search(str(schema["pattern"]), value) is None:
            add(issues, "E_SCHEMA112", subject_path, f"{location}: value {value!r} does not match pattern")

    if isinstance(value, int) and not isinstance(value, bool):
        if "minimum" in schema and value < int(schema["minimum"]):
            add(issues, "E_SCHEMA113", subject_path, f"{location}: value is below minimum {schema['minimum']}")

    if isinstance(value, list):
        if "minItems" in schema and len(value) < int(schema["minItems"]):
            add(issues, "E_SCHEMA114", subject_path, f"{location}: array has fewer than minItems")
        if schema.get("uniqueItems") is True:
            seen: set[str] = set()
            for item in value:
                marker = json.dumps(item, ensure_ascii=False, sort_keys=True)
                if marker in seen:
                    add(issues, "E_SCHEMA115", subject_path, f"{location}: array items must be unique")
                    break
                seen.add(marker)
        item_schema = schema.get("items")
        if isinstance(item_schema, dict):
            for idx, item in enumerate(value):
                validate_against_schema(item, item_schema, root_schema, path + [idx], subject_path, issues)

    if isinstance(value, dict):
        if "minProperties" in schema and len(value) < int(schema["minProperties"]):
            add(issues, "E_SCHEMA116", subject_path, f"{location}: object has fewer than minProperties")
        property_name_schema = schema.get("propertyNames")
        if isinstance(property_name_schema, dict):
            for key in value:
                validate_against_schema(key, property_name_schema, root_schema, path + [f"{key}<property>"], subject_path, issues)
        required = schema.get("required", [])
        if isinstance(required, list):
            for key in required:
                if key not in value:
                    add(issues, "E_SCHEMA117", subject_path, f"{location}: missing required property {key}")
        properties = schema.get("properties", {})
        if isinstance(properties, dict):
            for key, child_schema in properties.items():
                if key in value and isinstance(child_schema, dict):
                    validate_against_schema(value[key], child_schema, root_schema, path + [key], subject_path, issues)
        additional = schema.get("additionalProperties", True)
        known = set(properties.keys()) if isinstance(properties, dict) else set()
        extras = sorted(set(value.keys()) - known)
        if additional is False and extras:
            add(issues, "E_SCHEMA118", subject_path, f"{location}: additional properties are not allowed: {extras}")
        elif isinstance(additional, dict):
            for key in extras:
                validate_against_schema(value[key], additional, root_schema, path + [key], subject_path, issues)


def project_path(project_root: Path, declared: Any) -> Path | None:
    if not isinstance(declared, str):
        return None
    if "<" in declared or "*" in declared:
        return None
    if declared.startswith(".claude/") or declared.startswith("docs/") or declared.startswith("fixtures/"):
        return project_root / declared
    return None


def require_declared_path(project_root: Path, subject_path: Path, declared: Any, field: str, issues: list[Issue]) -> None:
    resolved = project_path(project_root, declared)
    if resolved is not None and not resolved.exists():
        add(issues, "E_SCHEMA119", subject_path, f"{field} references missing path {declared}")


def validate_runtime_core(claude_root: Path, issues: list[Issue]) -> dict[str, Any] | None:
    project_root = claude_root.parent
    core_path = claude_root / "runtime" / "core.yaml"
    schema_path = claude_root / "schemas" / RUNTIME_CORE_SCHEMA
    core = load_yaml_file(core_path, issues)
    schema = load_json_file(schema_path, issues)
    if core is None:
        return None
    if schema is not None:
        validate_against_schema(core, schema, schema, [], core_path, issues)

    for field in ("workflow_definition",):
        require_declared_path(project_root, core_path, core.get(field), field, issues)
    for section in ("legacy_fallback", "governance", "scripts", "topic_rules"):
        values = core.get(section)
        if isinstance(values, dict):
            for key, declared in values.items():
                require_declared_path(project_root, core_path, declared, f"{section}.{key}", issues)

    migrated = core.get("migrated_commands")
    runtime_commands = core.get("runtime_commands")
    if isinstance(migrated, list) and isinstance(runtime_commands, dict):
        migrated_set = set(migrated)
        mapped_set = set(runtime_commands.keys())
        if migrated_set != mapped_set:
            add(
                issues,
                "E_SCHEMA120",
                core_path,
                f"migrated_commands and runtime_commands differ: missing={sorted(migrated_set - mapped_set)}, extra={sorted(mapped_set - migrated_set)}",
            )
        for command in sorted(mapped_set):
            expected = f".claude/runtime/commands/{command}.yaml"
            actual = runtime_commands.get(command)
            if actual != expected:
                add(issues, "E_SCHEMA121", core_path, f"runtime_commands.{command} must be {expected}")
            require_declared_path(project_root, core_path, actual, f"runtime_commands.{command}", issues)
    return core


def validate_subagent_runtime_contract(command: str, manifest: dict[str, Any], path: Path, issues: list[Issue]) -> None:
    subagents = manifest.get("subagents")
    if command in SUBAGENT_REQUIRED_COMMANDS:
        if not isinstance(subagents, dict) or subagents.get("enabled") is not True:
            add(issues, "E_SCHEMA122", path, f"{command} must declare enabled subagents")
            return
    if not isinstance(subagents, dict):
        return

    agents = subagents.get("agents")
    if not isinstance(agents, list):
        return
    names: set[str] = set()
    for idx, agent in enumerate(agents):
        if not isinstance(agent, dict):
            continue
        name = agent.get("name")
        if isinstance(name, str):
            if name in names:
                add(issues, "E_SCHEMA123", path, f"subagents.agents[{idx}] duplicate name {name}")
            names.add(name)
        mode = agent.get("mode")
        writes = agent.get("writes")
        if mode in READ_ONLY_SUBAGENT_MODES and isinstance(writes, list) and writes:
            add(issues, "E_SCHEMA124", path, f"subagent {name} mode {mode} must not declare writes")
        if mode == "scoped_write" and isinstance(writes, list) and not writes:
            add(issues, "E_SCHEMA125", path, f"subagent {name} mode scoped_write must declare writes")


def validate_runtime_command_references(
    project_root: Path,
    core: dict[str, Any] | None,
    command: str,
    manifest: dict[str, Any],
    path: Path,
    issues: list[Issue],
) -> None:
    registered_topics: set[str] = set()
    if isinstance(core, dict) and isinstance(core.get("topic_rules"), dict):
        registered_topics = {value for value in core["topic_rules"].values() if isinstance(value, str)}

    if manifest.get("command") != command:
        add(issues, "E_SCHEMA126", path, f"command field must match runtime core key {command}")
    if path.name != f"{command}.yaml":
        add(issues, "E_SCHEMA127", path, f"filename must be {command}.yaml")

    state = manifest.get("state")
    if isinstance(state, dict) and state.get("change_to") == "done" and command != "cc-archive":
        add(issues, "E_SCHEMA128", path, "only cc-archive may set change_to done")

    if command in ANTI_RATIONALIZATION_COMMANDS:
        for key in ("anti_rationalizations", "red_flags"):
            if not isinstance(manifest.get(key), list) or not manifest.get(key):
                add(issues, "E_SCHEMA129", path, f"{command} must declare non-empty {key}")

    for idx, declared in enumerate(manifest.get("required_reads", []) if isinstance(manifest.get("required_reads"), list) else []):
        require_declared_path(project_root, path, declared, f"required_reads[{idx}]", issues)

    topic_rules = manifest.get("topic_rules")
    if isinstance(topic_rules, dict):
        for condition, rules in topic_rules.items():
            if not isinstance(rules, list):
                continue
            for idx, rule_path in enumerate(rules):
                if registered_topics and rule_path not in registered_topics:
                    add(issues, "E_SCHEMA130", path, f"topic_rules.{condition}[{idx}] is not registered in runtime/core.yaml: {rule_path}")
                require_declared_path(project_root, path, rule_path, f"topic_rules.{condition}[{idx}]", issues)

    subagents = manifest.get("subagents")
    if isinstance(subagents, dict):
        require_declared_path(project_root, path, subagents.get("policy"), "subagents.policy", issues)


def validate_runtime_commands(claude_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> list[str]:
    project_root = claude_root.parent
    schema_path = claude_root / "schemas" / RUNTIME_COMMAND_SCHEMA
    schema = load_json_file(schema_path, issues)
    runtime_commands = core.get("runtime_commands") if isinstance(core, dict) else None
    if isinstance(runtime_commands, dict):
        command_paths = [(command, project_path(project_root, path)) for command, path in sorted(runtime_commands.items())]
    else:
        command_paths = [(path.stem, path) for path in sorted((claude_root / "runtime" / "commands").glob("cc-*.yaml"))]

    checked: list[str] = []
    for command, resolved_path in command_paths:
        if resolved_path is None:
            continue
        checked.append(str(resolved_path))
        manifest = load_yaml_file(resolved_path, issues)
        if manifest is None:
            continue
        if schema is not None:
            validate_against_schema(manifest, schema, schema, [], resolved_path, issues)
        validate_runtime_command_references(project_root, core, command, manifest, resolved_path, issues)
        validate_subagent_runtime_contract(command, manifest, resolved_path, issues)
    return checked


def validate_runtime_manifests(claude_root: Path, issues: list[Issue]) -> list[str]:
    core = validate_runtime_core(claude_root, issues)
    checked = [str(claude_root / "runtime" / "core.yaml")]
    checked.extend(validate_runtime_commands(claude_root, core, issues))
    return checked


def validate_change_id(value: Any) -> bool:
    return isinstance(value, str) and bool(CHANGE_ID_RE.match(value))


def validate_spec(path: Path, issues: list[Issue]) -> set[str]:
    text = read(path)
    meta = parse_meta(text)
    if not validate_change_id(meta.get("change_id")):
        add(issues, "E_SCHEMA001", path, "invalid or missing change_id")
    if meta.get("status") not in VALID_CHANGE_STATUS:
        add(issues, "E_SCHEMA002", path, "invalid or missing status")
    for key in ("depends_on", "parallel_safe", "branch", "created", "updated", "complexity"):
        if key not in meta:
            add(issues, "E_SCHEMA003", path, f"missing metadata field {key}")
    depends_on = meta.get("depends_on")
    if depends_on is not None and not isinstance(depends_on, list):
        add(issues, "E_SCHEMA004", path, "depends_on must be a list")
    if "parallel_safe" in meta and not isinstance(meta.get("parallel_safe"), bool):
        add(issues, "E_SCHEMA005", path, "parallel_safe must be boolean")

    mapping_ids: set[str] = set()
    rows = validation_rows(text)
    if not rows:
        add(issues, "E_SCHEMA006", path, "missing validation mapping rows")
    for row in rows:
        if len(row) < 7:
            add(issues, "E_SCHEMA007", path, f"validation row {row[0]} has fewer than 7 columns")
            continue
        vid, level, evidence, status = row[0], row[2], row[3], row[6]
        mapping_ids.add(vid)
        if level not in EVIDENCE_BY_LEVEL:
            add(issues, "E_SCHEMA008", path, f"{vid} has invalid level {level}")
        elif evidence not in EVIDENCE_BY_LEVEL[level]:
            add(issues, "E_SCHEMA009", path, f"{vid} evidence {evidence} does not match {level}")
        if status not in VALID_MAPPING_STATUS:
            add(issues, "E_SCHEMA010", path, f"{vid} has invalid closure status {status}")

    for field in HARD_GATE_FIELDS:
        if f"**{field}**" not in text:
            add(issues, "E_SCHEMA011", path, f"HARD-GATE missing {field}")
    return mapping_ids


def validate_tasks(path: Path, mapping_ids: set[str], issues: list[Issue]) -> None:
    text = read(path)
    meta = parse_meta(text)
    if not validate_change_id(meta.get("change_id")):
        add(issues, "E_SCHEMA012", path, "invalid or missing change_id")
    sections = task_sections(text)
    if not sections:
        add(issues, "E_SCHEMA013", path, "no task sections found")
    for section in sections:
        title = section.splitlines()[0].strip()
        for field in TASK_FIELDS:
            if field not in section:
                add(issues, "E_SCHEMA014", path, f"{title} missing {field}")
        match = re.search(r"\*\*完成后状态\*\*\s*:\s*`?([a-z_]+)`?", section)
        if match and match.group(1) not in VALID_TASK_STATUS:
            add(issues, "E_SCHEMA015", path, f"{title} has invalid task status {match.group(1)}")
    for vid in mapping_ids:
        if vid not in text:
            add(issues, "E_SCHEMA016", path, f"missing validation mapping {vid}")


def validate_review(path: Path, issues: list[Issue]) -> None:
    if not path.exists():
        return
    text = read(path)
    meta = parse_meta(text)
    for key, allowed in VALID_REVIEW_STATUS.items():
        if meta.get(key) not in allowed:
            add(issues, "E_SCHEMA017", path, f"invalid or missing {key}")
    for row in finding_rows(text):
        status = row[4].strip("` ")
        if row[0] != "无" and status not in {"open", "fixed", "accepted"}:
            add(issues, "E_SCHEMA018", path, f"finding has invalid status {status}")


def validate_test_spec(path: Path, issues: list[Issue]) -> None:
    if not path.exists():
        return
    text = read(path)
    meta = parse_meta(text)
    if meta and meta.get("status") not in VALID_CHANGE_STATUS:
        add(issues, "E_SCHEMA019", path, "invalid status")
    for row in table_rows(text):
        if len(row) >= 2 and row[0].replace("`", "") == "cc-test 模式":
            mode = row[1].strip("` ")
            if mode not in VALID_TEST_MODE:
                add(issues, "E_SCHEMA020", path, f"invalid cc-test mode {mode}")
            return
    add(issues, "E_SCHEMA021", path, "missing cc-test mode row")


def discover_change_dirs(inputs: list[Path]) -> list[Path]:
    dirs: set[Path] = set()
    for item in inputs:
        if item.is_file():
            parent = item.parent
            if (parent / "spec.md").exists() and (parent / "tasks.md").exists():
                dirs.add(parent)
            continue
        if (item / "spec.md").exists() and (item / "tasks.md").exists():
            dirs.add(item)
            continue
        if item.is_dir():
            for spec in item.rglob("spec.md"):
                if "templates" in spec.parts:
                    continue
                parent = spec.parent
                if (parent / "tasks.md").exists():
                    dirs.add(parent)
    return sorted(dirs)


def default_input() -> Path:
    cwd = Path.cwd()
    if (cwd / ".claude" / "changes").exists():
        return cwd / ".claude" / "changes"
    return Path(__file__).resolve().parent.parent / "changes"


def build_report(inputs: list[Path]) -> dict[str, Any]:
    issues: list[Issue] = []
    claude_root = Path(__file__).resolve().parent.parent
    checked_runtime = validate_runtime_manifests(claude_root, issues)
    change_dirs = discover_change_dirs(inputs)
    for change_dir in change_dirs:
        mapping_ids = validate_spec(change_dir / "spec.md", issues)
        validate_tasks(change_dir / "tasks.md", mapping_ids, issues)
        validate_review(change_dir / "review.md", issues)
        validate_test_spec(change_dir / "test-spec.md", issues)
    return {
        "tool": "cc-schema-check",
        "status": "failed" if issues else "passed",
        "checked_runtime": checked_runtime,
        "checked_changes": [str(path) for path in change_dirs],
        "issues": [issue.__dict__ for issue in issues],
    }


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Check Golang Harness document metadata and shape.")
    parser.add_argument("paths", nargs="*", help="Change directories, files, or changes root.")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    args = parser.parse_args(argv)

    inputs = [Path(path) for path in args.paths] if args.paths else [default_input()]
    report = build_report(inputs)
    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    elif report["status"] == "passed":
        print("cc-schema-check: ok")
    else:
        for issue in report["issues"]:
            print(f"{issue['code']} {issue['path']}: {issue['message']}", file=sys.stderr)
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
