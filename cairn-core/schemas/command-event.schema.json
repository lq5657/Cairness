{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/command-event.schema.json",
  "title": "Harness Command Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "occurred_at",
    "command",
    "change_id",
    "actor",
    "transition",
    "summary",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "event_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "occurred_at": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "pattern": "^cc-[a-z0-9-]+$"
    },
    "change_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {
          "type": "string",
          "enum": ["none", "propose", "apply", "review", "done", "unchanged"]
        },
        "to": {
          "type": "string",
          "enum": ["unchanged", "propose", "apply", "review", "done"]
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "命令执行耗时（毫秒）"
    },
    "token_count": {
      "type": "integer",
      "minimum": 0,
      "description": "估算的 token 消耗"
    },
    "subagent_count": {
      "type": "integer",
      "minimum": 0,
      "description": "调度的子 agent 数量"
    },
    "verification_status": {
      "type": "string",
      "enum": ["passed", "failed", "partial", "not_run"],
      "description": "验证门禁结果"
    },
    "files_changed": {
      "type": "integer",
      "minimum": 0,
      "description": "修改的文件数量"
    },
    "findings_summary": {
      "type": "object",
      "additionalProperties": false,
      "description": "review/fix 命令的 finding 汇总",
      "properties": {
        "total_open": {"type": "integer", "minimum": 0},
        "total_fixed": {"type": "integer", "minimum": 0},
        "total_accepted": {"type": "integer", "minimum": 0},
        "by_severity": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        }
      }
    },
    "gate_effectiveness": {
      "type": "object",
      "description": "门禁有效性度量 — cc-review/cc-fix 时记录",
      "properties": {
        "gates_triggered": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gate_id", "blocked"],
            "properties": {
              "gate_id": {
                "type": "string",
                "description": "门禁标识 (lens name / topic rule / script)"
              },
              "blocked": {
                "type": "boolean",
                "description": "是否阻止了命令继续"
              },
              "was_real_error": {
                "type": "boolean",
                "description": "cc-fix 确认是否为真实错误"
              },
              "finding_ids": {
                "type": "array",
                "items": {"type": "string"},
                "description": "关联的 finding ID 列表"
              }
            }
          }
        }
      }
    }
  }
}
