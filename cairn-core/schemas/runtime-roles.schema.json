{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/runtime-roles.schema.json",
  "title": "cc_spec Runtime Role Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "roles"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "responsibility", "writes"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "responsibility": {"type": "string", "minLength": 1},
          "writes": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
