{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/command-event.schema.json",
  "title": "Harness Command Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "occurred_at",
    "command",
    "change_id",
    "actor",
    "transition",
    "summary",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "event_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "occurred_at": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "pattern": "^cc-[a-z0-9-]+$"
    },
    "change_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {
          "type": "string",
          "enum": ["none", "propose", "apply", "review", "done", "unchanged"]
        },
        "to": {
          "type": "string",
          "enum": ["unchanged", "propose", "apply", "review", "done"]
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

