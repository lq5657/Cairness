#!/usr/bin/env python3
"""Dirty-worktree write-scope checks for cc-* command contracts."""

from __future__ import annotations

import argparse
import hashlib
import json
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path
from typing import Any

from harness_runtime import project_path, require_yaml
from harness_runtime.issues import (
    Issue,
    build_report as build_issue_report,
)
from harness_runtime.context import HarnessContext, HarnessContextError, load_harness_context

from change_docs import (
    parse_file_table,
    parse_inline_list,
    parse_involved_files,
    parse_key_value,
    parse_workflow_commands,
    path_matches_scope,
)

BASELINE_FILENAME = "role-baseline.json"


ABSTRACT_WRITE_PATTERNS = {
    "task_declared_code_files",
    "finding_related_code_files",
    "business_code_changes",
    "test_files",
    "fixed_code",
    "change_docs_update",
    "synced_change_docs",
    "tests_or_evidence",
    "change_docs_update",
    "change_docs_update_if_needed",
    "task_board_update",
    "updated_findings",
    "task_board_archive_state",
    "optional_commits",
    "optional_knowledge",
    "structured_preflight_result",
}


def run_git(project_root: Path, args: list[str]) -> list[str]:
    completed = subprocess.run(
        ["git", "-C", str(project_root), *args],
        text=True,
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        raise RuntimeError(completed.stderr.strip() or completed.stdout.strip() or "git command failed")
    return [line.strip() for line in completed.stdout.splitlines() if line.strip()]


def dirty_paths(project_root: Path) -> list[str]:
    paths: set[str] = set()
    for args in (
        ["diff", "--name-only", "--relative", "--", "."],
        ["diff", "--cached", "--name-only", "--relative", "--", "."],
        ["ls-files", "--others", "--exclude-standard", "--", "."],
    ):
        for path in run_git(project_root, args):
            paths.add(path)
    return sorted(paths)


def baseline_path(project_root: Path, change_id: str) -> Path:
    return project_root / ".cairness" / "changes" / change_id / "baseline" / BASELINE_FILENAME


def load_baseline(path: Path) -> tuple[list[str], dict[str, str]] | None:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return None
    if (
        not isinstance(data, dict)
        or not isinstance(data.get("dirty_paths"), list)
        or not all(isinstance(item, str) for item in data["dirty_paths"])
    ):
        return None
    paths = [str(p) for p in data["dirty_paths"]]
    raw_states = data.get("path_states", {})
    states = (
        {str(key): str(value) for key, value in raw_states.items()}
        if isinstance(raw_states, dict)
        else {}
    )
    return paths, states


def save_baseline(path: Path, dirty: list[str], states: dict[str, str]) -> None:
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(
            json.dumps(
                {
                    "version": 2,
                    "dirty_paths": dirty,
                    "path_states": states,
                    "saved_at": datetime.now().isoformat(),
                },
                indent=2,
            ),
            encoding="utf-8",
        )
    except OSError:
        pass


def reset_baseline(path: Path) -> bool:
    try:
        path.unlink()
        return True
    except FileNotFoundError:
        return True
    except OSError:
        return False


def path_state(project_root: Path, relative: str) -> str:
    """Return a stable fingerprint for one dirty worktree path."""
    path = project_root / relative
    try:
        if path.is_symlink():
            payload = f"symlink:{path.readlink()}".encode("utf-8", errors="surrogateescape")
        elif path.is_file():
            payload = b"file:" + path.read_bytes()
        elif path.is_dir():
            payload = b"directory"
        else:
            payload = b"missing"
    except OSError as exc:
        payload = f"error:{exc.__class__.__name__}".encode("ascii")
    return hashlib.sha256(payload).hexdigest()


def dirty_snapshot(project_root: Path, *, exclude: str = "") -> tuple[list[str], dict[str, str]]:
    paths = [path for path in dirty_paths(project_root) if path != exclude]
    return paths, {path: path_state(project_root, path) for path in paths}


def record_baseline(project_root: Path, change_id: str) -> tuple[Path, list[str]]:
    path = baseline_path(project_root, change_id)
    relative = path.relative_to(project_root).as_posix()
    paths, states = dirty_snapshot(project_root, exclude=relative)
    save_baseline(path, paths, states)
    return path, paths


def _load_manifest_writes(
    claude_root: Path,
    command: str,
    context: HarnessContext | None = None,
) -> list[str] | None:
    """Read the `writes` list from the command's runtime manifest.

    Returns None if the manifest cannot be resolved/loaded (caller falls back
    to workflow during the A1 transition). The manifest is the SSOT for write
    scope; this is the authoritative source going forward.
    """
    project_root = context.project_root if context is not None else claude_root.parent
    core_path = claude_root / "runtime" / "core.yaml"
    if not core_path.exists():
        return None
    yaml = require_yaml()
    try:
        core = yaml.safe_load(core_path.read_text(encoding="utf-8"))
    except Exception:
        return None
    if not isinstance(core, dict):
        return None
    runtime_commands = core.get("runtime_commands")
    if not isinstance(runtime_commands, dict):
        return None
    declared = runtime_commands.get(command)
    if not isinstance(declared, str):
        return None
    manifest_path = (
        context.resolve_path(declared)
        if context is not None
        else project_path(project_root, declared, framework_root=claude_root)
    )
    if manifest_path is None or not manifest_path.exists():
        return None
    try:
        manifest = yaml.safe_load(manifest_path.read_text(encoding="utf-8"))
    except Exception:
        return None
    if not isinstance(manifest, dict):
        return None
    writes = manifest.get("writes")
    if not isinstance(writes, list):
        return None
    return [w for w in writes if isinstance(w, str)]


def load_command_writes(
    claude_root: Path,
    command: str,
    context: HarnessContext | None = None,
) -> tuple[list[str], bool]:
    # Manifest is the SSOT for write scope (A1). Prefer it; fall back to the
    # generated workflow view only if the manifest can't be resolved (e.g.
    # core.yaml unreadable / PyYAML missing) so the write-permission gate
    # never silently degrades to "allow all".
    writes = _load_manifest_writes(claude_root, command, context)
    if writes is None:
        writes = _load_workflow_writes(claude_root, command)
    has_abstract = any(item in ABSTRACT_WRITE_PATTERNS for item in writes)
    concrete: list[str] = []
    for item in writes:
        if item in ABSTRACT_WRITE_PATTERNS:
            continue
        concrete.append(concretize_pattern(item))
    return concrete, has_abstract


def _load_workflow_writes(claude_root: Path, command: str) -> list[str]:
    workflow_path = claude_root / "workflows" / "cc-workflow.yaml"
    if not workflow_path.exists():
        raise RuntimeError(f"{workflow_path} not found")
    blocks = parse_workflow_commands(workflow_path.read_text(encoding="utf-8"))
    if command not in blocks:
        raise RuntimeError(f"{command} not defined in workflow")
    writes_value = parse_key_value(blocks[command], "writes")
    if writes_value is None:
        raise RuntimeError(f"{command} missing writes field")
    return parse_inline_list(writes_value)


def concretize_pattern(pattern: str) -> str:
    if pattern.startswith(".claude/") or pattern.startswith(".cairness/"):
        return pattern
    state_relative_prefixes = (
        "changes/",
        "context/",
        "audits/",
        "knowledge/",
    )
    if pattern.startswith(state_relative_prefixes):
        return f".cairness/{pattern}"
    claude_relative_prefixes = (
        "rules/",
        "schemas/",
        "scripts/",
        "skills/",
        "workflows/",
        "runtime/",
        "evals/",
        "CHANGELOG.md",
        "UPGRADE.md",
        "VERSION",
        "harness.config.yaml",
    )
    if pattern.startswith(claude_relative_prefixes):
        return f".claude/{pattern}"
    return pattern


# Placeholders that name a *set* of subdirs (knowledge <category>, audit/
# discuss ids) with no per-invocation CLI value. role-check has no tighter
# bound than "some subdir under here", so they expand to the fnmatch wildcard.
# <change-id> is handled separately in expand() because it resolves to a
# concrete value passed via --change. Keep aligned with placeholders appearing
# in manifests' `writes` lists (see runtime/commands/*.yaml).
_PLACEHOLDER_RE = re.compile(r"<[a-z][a-z0-9-]*>")


def expand(pattern: str, change_id: str | None) -> str:
    """Expand manifest write-scope placeholders for fnmatch comparison.

    <change-id> resolves to the concrete change id. Any other <placeholder>
    (e.g. <category>, <audit-id>, <discuss-id>) names a set of subdirs with no
    per-invocation value, so it expands to `*` — the command may write under
    any matching subdir, and role-check has no tighter bound to apply. Leaving
    such placeholders literal would make fnmatch match nothing, flagging every
    legitimately-written file as E_ROLE002 out-of-scope.
    """
    pattern = pattern.replace("<change-id>", change_id or "")
    return _PLACEHOLDER_RE.sub("*", pattern)


def is_allowed(path: str, patterns: list[str], change_id: str | None) -> bool:
    expanded = [expand(pattern, change_id) for pattern in patterns]
    return any(path_matches_scope(path, pattern) for pattern in expanded)


def build_role_report(
    command: str,
    change_id: str | None,
    project_root: Path,
    context: HarnessContext | None = None,
) -> dict[str, Any]:
    claude_root = context.framework_root if context is not None else project_root / ".claude"
    patterns, has_abstract = load_command_writes(claude_root, command, context)
    if any("<change-id>" in pattern for pattern in patterns) and not change_id:
        return build_issue_report(
            "cc-role-check",
            [Issue("E_ROLE001", "", "missing --change")],
            status="failed",
            extra={"project_root": str(project_root.resolve()), "reason": f"{command} requires --change", "dirty_paths": []},
        )
    if has_abstract and change_id:
        tasks_path = project_root / ".cairness" / "changes" / change_id / "tasks.md"
        if tasks_path.is_file():
            task_text = tasks_path.read_text(encoding="utf-8")
            task_files = parse_involved_files(task_text) | parse_file_table(task_text)
            patterns.extend(sorted(task_files))
            has_abstract = not bool(task_files)
    if has_abstract:
        return build_issue_report(
            "cc-role-check",
            [],
            status="skipped",
            extra={
                "project_root": str(project_root.resolve()),
                "reason": f"{command} has task-dependent or abstract write scope",
                "allowed": [expand(pattern, change_id) for pattern in patterns],
                "dirty_paths": [],
            },
        )
    paths = dirty_paths(project_root)
    states = {path: path_state(project_root, path) for path in paths}
    previous_paths: list[str] = []
    previous_states: dict[str, str] = {}
    if change_id:
        bp = baseline_path(project_root, change_id)
        baseline_rel = bp.relative_to(project_root).as_posix()
        # role-baseline.json is cc-role-check's own bookkeeping, not a command
        # write. Exclude it from both the new-dirty diff and the saved snapshot
        # so it can never flag itself (E_ROLE002) and never mask a real
        # out-of-scope file added in the same run (the snapshot must only
        # record files the command under test actually wrote).
        paths = [p for p in paths if p != baseline_rel]
        states.pop(baseline_rel, None)
        baseline = load_baseline(bp)
        if baseline is None:
            save_baseline(bp, paths, states)
            return build_issue_report(
                "cc-role-check",
                [],
                extra={
                    "project_root": str(project_root.resolve()),
                    "command": command,
                    "change_id": change_id,
                    "allowed": [expand(pattern, change_id) for pattern in patterns],
                    "dirty_paths": [],
                    "baseline_initialized": True,
                    "baseline_dirty_paths": paths,
                },
            )
        previous_paths, previous_states = baseline
    new_paths = [
        path
        for path in paths
        if path not in previous_paths
        or (path in previous_states and states.get(path) != previous_states[path])
    ]
    issues = [
        Issue("E_ROLE002", path, f"{command} may not write this path")
        for path in new_paths
        if not is_allowed(path, patterns, change_id)
    ]
    return build_issue_report(
        "cc-role-check",
        issues,
        extra={
            "project_root": str(project_root.resolve()),
            "command": command,
            "change_id": change_id or "",
            "allowed": [expand(pattern, change_id) for pattern in patterns],
            "dirty_paths": new_paths,
        },
    )


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Check dirty worktree against cc-* command write scope.")
    parser.add_argument("--command", help="cc-* command, for example cc-review.")
    parser.add_argument("--change", help="Formal change-id when the command is change-scoped.")
    parser.add_argument("--project-root", help="Project root. Defaults to parent of .claude.")
    parser.add_argument("--root", help="Explicit Cairness project root; preferred alias for --project-root.")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    parser.add_argument("--reset-baseline", action="store_true", help="Clear the role baseline for --change.")
    parser.add_argument(
        "--record-baseline",
        action="store_true",
        help="Capture the current dirty worktree before a command starts.",
    )
    args = parser.parse_args(argv)

    if args.root and args.project_root:
        parser.error("--root and --project-root are mutually exclusive")
    context: HarnessContext | None = None
    if args.project_root:
        project_root = Path(args.project_root).expanduser().resolve()
        if not project_root.is_dir():
            print(f"E_CONTEXT001 legacy project root is not a directory: {args.project_root}", file=sys.stderr)
            return 2
    else:
        try:
            context = load_harness_context(
                explicit_root=Path(args.root) if args.root else None,
                framework_hint=None if args.root else Path(__file__).resolve().parent.parent,
            )
        except HarnessContextError as exc:
            print(f"E_CONTEXT001 {exc}", file=sys.stderr)
            return 2
        project_root = context.project_root

    if args.reset_baseline and args.record_baseline:
        parser.error("--reset-baseline and --record-baseline are mutually exclusive")

    if args.reset_baseline:
        if not args.change:
            report = build_issue_report(
                "cc-role-check",
                [Issue("E_ROLE001", "", "missing --change for --reset-baseline")],
                status="failed",
                extra={"reason": "--reset-baseline requires --change"},
            )
            print(json.dumps(report, ensure_ascii=False, indent=2) if args.json else "cc-role-check: --reset-baseline requires --change", file=sys.stderr)
            return 1
        bp = baseline_path(project_root, args.change)
        ok = reset_baseline(bp)
        if ok:
            print(f"cc-role-check: baseline reset for {args.change}")
            return 0
        print(f"cc-role-check: failed to reset baseline for {args.change}", file=sys.stderr)
        return 1

    if args.record_baseline:
        if not args.change:
            print("cc-role-check: --record-baseline requires --change", file=sys.stderr)
            return 1
        path, paths = record_baseline(project_root, args.change)
        report = build_issue_report(
            "cc-role-check",
            [],
            extra={
                "project_root": str(project_root.resolve()),
                "change_id": args.change,
                "baseline": str(path),
                "baseline_dirty_paths": paths,
            },
        )
        if args.json:
            print(json.dumps(report, ensure_ascii=False, indent=2))
        else:
            print(f"cc-role-check: baseline recorded for {args.change} ({len(paths)} dirty paths)")
        return 0

    if not args.command:
        report = build_issue_report(
            "cc-role-check",
            [Issue("E_ROLE003", "", "missing --command")],
            status="failed",
            extra={"reason": "--command is required (unless using --reset-baseline)"},
        )
        print(json.dumps(report, ensure_ascii=False, indent=2) if args.json else "cc-role-check: --command is required", file=sys.stderr)
        return 1
    try:
        report = build_role_report(args.command, args.change, project_root, context)
    except RuntimeError as exc:
        report = build_issue_report(
            "cc-role-check",
            [Issue("E_ROLE003", "", str(exc))],
            status="failed",
            extra={"reason": str(exc)},
        )

    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    elif report["status"] == "passed":
        print("cc-role-check: ok")
    elif report["status"] == "skipped":
        print(f"cc-role-check: skipped ({report['reason']})")
    else:
        for entry in report.get("issues", []):
            print(f"{entry['code']} {entry['path']}: {entry['message']}", file=sys.stderr)
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
