{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cairness adapter regression contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "adapter", "checks"],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "adapter": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required", "evidence_kind", "runner", "sources"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "required": {"type": "boolean"},
          "evidence_kind": {
            "type": "string",
            "enum": ["contract", "fixture", "host-observed"]
          },
          "runner": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "sources": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
