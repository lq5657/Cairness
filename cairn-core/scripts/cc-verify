def _change_cohort(project_root: Path, change_id: str | None) -> dict[str, str]:
    if not change_id:
        return {}
    spec = project_root / ".cairness" / "changes" / change_id / "spec.md"
    if not spec.is_file():
        return {}
    try:
        lines = spec.read_text(encoding="utf-8").splitlines()
    except OSError:
        return {}
    fields: dict[str, str] = {}
    for line in lines[1:]:
        stripped = line.strip()
        if stripped == "---":
            break
        if ":" not in stripped:
            continue
        key, value = (part.strip() for part in stripped.split(":", 1))
        if key in {"complexity", "proposal_profile", "change_type", "type"} and value:
            fields[key] = value
    size = fields.get("proposal_profile") or fields.get("complexity")
    size_map = {
        "simple": "small",
        "medium": "medium",
        "complex": "large",
        "micro": "micro",
        "standard": "medium",
        "staged": "large",
    }
    cohort: dict[str, str] = {}
    if size:
        cohort["change_size"] = size_map.get(size, size)
    change_type = fields.get("change_type") or fields.get("type")
    if change_type:
        cohort["change_type"] = change_type
    return cohort


def _environment_choice(name: str, choices: tuple[str, ...]) -> str | None:
    value = os.environ.get(name, "").strip()
    return value if value in choices else None


def _environment_attempt() -> int | None:
    value = os.environ.get("CC_RUN_ATTEMPT", "").strip()
    if not value:
        return None
    try:
        attempt = int(value)
    except ValueError:
        return None
    return attempt if attempt >= 1 else None


def _environment_terminal() -> bool | None:
    value = os.environ.get("CC_RUN_TERMINAL", "").strip().lower()
    if value in {"1", "true", "yes"}:
        return True
    if value in {"0", "false", "no"}:
        return False
    return None


def _adapter_usage_payload() -> object | None:
    value = os.environ.get("CC_ADAPTER_USAGE_JSON", "").strip()
    if not value:
        return None
    try:
        return json.loads(value)
    except json.JSONDecodeError:
        return None


def _apply_default_run_metadata(args: argparse.Namespace, report: dict[str, object]) -> None:
    phase = args.phase or _environment_choice(
        "CC_RUN_PHASE", ("propose", "apply", "review", "fix", "test", "archive")
    ) or "test"
    activity = args.activity or _environment_choice(
        "CC_RUN_ACTIVITY", ("preflight", "execute", "verify", "transition", "wait")
    ) or "verify"
    attempt = args.attempt or _environment_attempt() or 1
    run_kind = args.run_kind or _environment_choice(
        "CC_RUN_KIND", ("primary", "retry", "shadow", "delta", "probe")
    ) or ("retry" if attempt > 1 else "primary")
    terminal = args.terminal
    if terminal is None:
        terminal = _environment_terminal()
    if terminal is None:
        terminal = activity != "preflight" and run_kind not in {"shadow", "probe"}
    logical_run_id = (
        args.logical_run_id
        or os.environ.get("CC_LOGICAL_RUN_ID", "").strip()
        or f"verify-{uuid.uuid4().hex}"
    )
    report.update({
        "phase": phase,
        "activity": activity,
        "run_kind": run_kind,
        "logical_run_id": logical_run_id,
        "attempt": attempt,
        "terminal": terminal,
    })


def command_text(command: list[str]) -> str:
    return " ".join(command)


def build_report(args: argparse.Namespace, context: HarnessContext | None = None) -> dict[str, object]:
    context = context or load_harness_context(framework_hint=Path(__file__).resolve().parent.parent)
    claude_root = context.framework_root
    project_root = context.project_root
    changes_root = project_root / ".cairness" / "changes"
    target_project_root = (project_root / args.fixture).resolve() if args.fixture else project_root
    config_path = claude_root / "harness.config.yaml"
    try:
        config = load_harness_config(config_path).values
        config_error = ""
    except HarnessConfigError as exc:
        config = {}
        config_error = str(exc)
    execution_mode = getattr(args, "execution_mode", None)
    try:
        # The CLI flag is intentionally explicit.  A configured default is
        # available to other callers, but must not silently narrow legacy CI
        # invocations that omit --execution-mode.
        execution_policy = (
            resolve_execution_policy(
                execution_mode,
                config.get("execution", {}) if isinstance(config, dict) else {},
            )
            if execution_mode
            else None
        )
    except ExecutionPolicyError as exc:
        execution_policy = None
        config_error = f"invalid execution policy: {exc}"
    # Explicit normal mode is the only mode that narrows a verification run.
    # Leaving the flag absent preserves the historical full-verify behavior for
    # existing CI integrations; CI and optimize modes explicitly force full.
    if execution_policy is not None:
        if execution_policy.mode == "normal":
            args.changed_only = True
            args.reuse_cache = True
        elif execution_policy.mode in {"ci", "optimize"}:
            args.changed_only = False
            args.reuse_cache = False
    change_dir = changes_root / args.change if args.change else None
    test_policy_active = (
        execution_mode in {"normal", "ci", "optimize"}
        and not args.fixture
        and not args.harness_only
        and (project_root / "tests" / "test-policy.yaml").is_file()
    )
    changed_paths = (
        git_changed_paths(project_root)
        if args.changed_only or test_policy_active
        else []
    )
    changed_dirs = changed_change_dirs(changed_paths, project_root) if args.changed_only else []
    harness_changed = has_harness_changes(changed_paths, project_root) if args.changed_only else False
    resolution = (
        resolve_language_profile(
            project_root,
            target_root=target_project_root,
            include_project_state=False,
            framework_root=claude_root,
        )
        if args.fixture
        else resolve_language_profile(project_root, framework_root=claude_root)
    )

    results: list[dict[str, object]] = []
    reuse_cache = bool(args.reuse_cache or os.environ.get("CC_VERIFY_REUSE_CACHE") == "1")
    cache_root = project_root / CACHE_RELATIVE

    def run_cached_step(plan, *, cwd: Path = project_root, profile: str | None = None):
        eligible = reuse_cache and plan.name in CACHEABLE_STEPS
        key = (
            build_cache_key(
                project_root=cwd,
                framework_root=claude_root,
                step_name=plan.name,
                command=plan.command,
                profile=profile or resolution.profile_name,
                mode=verification_mode(
                    harness_only=args.harness_only,
                    project_only=args.project_only,
                    changed_only=args.changed_only,
                ),
            )
            if eligible
            else None
        )
        result = run_step(
            plan.name,
            "harness",
            plan.command,
            cwd,
            collect_issues=plan.collect_issues,
            cache_root=cache_root if eligible else None,
            cache_key=key,
            reuse_cache=eligible,
            timeout_seconds=getattr(args, "step_timeout_seconds", None),
        )
        result["cache_eligible"] = plan.name in CACHEABLE_STEPS
        result["cache_enabled"] = reuse_cache
        if result["cache_eligible"] and reuse_cache:
            result["cache_hit"] = result.get("reused") is True
            result["cache_miss"] = result.get("reused") is not True
        elif result["cache_eligible"]:
            result["cache_bypass_reason"] = "disabled"
        else:
            result["cache_bypass_reason"] = "step_not_cacheable"
        return result
    if config_error:
        results.append(failed_step("harness-config", "harness", config_error, project_root))
    if args.change and change_dir and not change_dir.exists():
        results.append(
            {
                "name": "change-dir",
                "kind": "harness",
                "command": [],
                "cwd": str(project_root),
                "status": "failed",
                "exit_code": 1,
                "duration_ms": 0,
                "stdout": "",
                "stderr": f"{change_dir} not found",
                "fingerprints": [f"{change_dir} not found"],
                "warnings": [],
            }
        )
    if not args.project_only:
        knowledge_index_path = project_root / ".cairness" / "knowledge" / "index.md"
        sync_target = change_dir if change_dir and change_dir.exists() else changes_root
        plans = harness_step_plan(
            framework_root=claude_root,
            sync_target=sync_target,
            sync_target_exists=sync_target.exists(),
            changed_only=args.changed_only,
            harness_changed=harness_changed,
            changed_dirs=changed_dirs,
            behavior_replay=os.environ.get("CC_BEHAVIOR_REPLAY") == "1",
            knowledge_index_exists=knowledge_index_path.is_file(),
            adapter_name=context.adapter.name,
            adapter_check_enabled=os.environ.get("CC_ADAPTER_CHECK_EMBEDDED") != "1",
        )
        for plan in plans:
            if plan.action == "skip":
                results.append(skipped_step(plan.name, "harness", plan.reason))
                continue
            results.append(
                run_cached_step(plan)
            )
        for plan in auxiliary_step_plan(
            framework_root=claude_root,
            project_root=project_root,
            command=args.command,
            change_id=args.change,
            change_dir_exists=bool(change_dir and change_dir.exists()),
            check_review_coverage=args.check_review_coverage,
            check_finding_locations=args.check_finding_locations,
            check_risk_triage=args.check_risk_triage,
            check_wave_plan=args.check_wave_plan,
        ):
            if plan.result_constructor == "run_step":
                results.append(
                    run_step(
                        plan.name,
                        plan.kind,
                        plan.command,
                        plan.cwd,
                        collect_issues=plan.collect_issues,
                        timeout_seconds=getattr(args, "step_timeout_seconds", None),
                    )
                )
            elif plan.result_constructor == "check_review_coverage":
                results.append(check_review_coverage(project_root, args.change))
            elif plan.result_constructor == "check_finding_locations":
                results.append(check_finding_locations(project_root, args.change))
            elif plan.result_constructor == "check_risk_triage":
                results.append(check_risk_triage(project_root, args.change))

    test_selection = None
    repository_test_policy = test_policy_active
    if repository_test_policy:
        try:
            selection = select_tests(project_root, changed_paths, execution_mode)
            test_selection = selection.as_dict()
            test_selection["execution_mode"] = execution_mode
            if selection.mode == "none":
                results.append(
                    skipped_step(
                        "pytest",
                        "project:pytest",
                        "no affected pytest tests selected by tests/test-policy.yaml",
                    )
                )
            else:
                command = [sys.executable, "-m", "pytest", "-q"]
                if selection.mode == "selected":
                    command.extend(str(path) for path in selection.tests)
                pytest_result = run_step(
                    "pytest",
                    "project:pytest",
                    command,
                    project_root,
                    timeout_seconds=getattr(args, "step_timeout_seconds", None),
                )
                if execution_mode in {"ci", "optimize"}:
                    shadow = select_tests(project_root, changed_paths, "normal")
                    escape = None
                    if changed_paths:
                        escape = routing_escape(
                            shadow,
                            status=str(pytest_result.get("status", "unknown")),
                            stdout=str(pytest_result.get("stdout", "")),
                            stderr=str(pytest_result.get("stderr", "")),
                        )
                        test_selection["shadow_normal_mode"] = shadow.mode
                        test_selection["shadow_selected_test_count"] = len(shadow.tests)
                        test_selection["shadow_fallback_full"] = shadow.fallback_full
                        test_selection["shadow_unmatched_source_count"] = len(
                            shadow.unmatched_sources
                        )
                    test_selection["routing_escape"] = escape
                results.append(pytest_result)
        except TestPolicyError as exc:
            test_selection = {
                "mode": "error",
                "tests": [],
                "reasons": {},
                "fallback_full": False,
                "unmatched_sources": [],
                "execution_mode": execution_mode,
                "error": str(exc),
            }
            results.append(
                failed_step(
                    "pytest-policy",
                    "project:pytest",
                    f"invalid tests/test-policy.yaml: {exc}",
                    project_root,
                )
            )

    profile_changed = (
        resolution.profile is not None
        and has_profile_changes(changed_paths, project_root, resolution.profile)
    )
    run_project_checks = project_checks_enabled(
        harness_only=args.harness_only,
        project_only=args.project_only,
        changed_only=args.changed_only,
        fixture_selected=bool(args.fixture),
        profile_status=resolution.status,
        has_profile_change=profile_changed,
    )
    if run_project_checks and not repository_test_policy:
        target_project_exists = target_project_root.exists()
        project_capabilities = []
        if (
            target_project_exists
            and resolution.status == "resolved"
            and resolution.profile is not None
        ):
            profile = resolution.profile
            executables = capability_executables(profile)
            project_capabilities = capability_plan(
                profile,
                config,
                {executable: shutil.which(executable) is not None for executable in executables},
            )
        for plan in project_step_plan(
            fixture=args.fixture,
            target_root=target_project_root,
            target_root_exists=target_project_exists,
            resolution_status=resolution.status,
            resolution_errors=resolution.errors,
            profile=resolution.profile,
            capability_plans=project_capabilities,
        ):
            if plan.action == "fail":
                results.append(failed_step(plan.name, plan.kind, plan.reason, target_project_root))
            elif plan.action == "skip":
                results.append(skipped_step(plan.name, plan.kind, plan.reason))
            elif plan.action == "block":
                results.append(blocked_step(plan.name, plan.kind, plan.reason, target_project_root))
            else:
                results.append(
                    run_step(
                        plan.name,
                        plan.kind,
                        plan.command,
                        target_project_root,
                        timeout_seconds=getattr(args, "step_timeout_seconds", None),
                    )
                )

    report = build_verification_report(
        generated_at=datetime.now(timezone.utc).isoformat(),
        project_root=project_root,
        claude_root=claude_root,
        change_id=args.change,
        fixture=args.fixture,
        command=args.command,
        mode=verification_mode(
            harness_only=args.harness_only,
            project_only=args.project_only,
            changed_only=args.changed_only,
        ),
        language_profile=resolution.profile_name,
        language_profile_source=resolution.source,
        changed_paths=changed_paths,
        results=results,
        include_execution_metrics=True,
        execution_policy=execution_policy.as_dict() if execution_policy else None,
        test_selection=test_selection,
        execution_mode_source=("explicit" if execution_mode else "legacy_default"),
    )
    return report


def print_text(report: dict[str, object], verbose: bool) -> None:
    print(f"cc-verify: {report['status']} ({report['mode']})")
    for result in report["results"]:
        status = str(result["status"]).upper()
        command = command_text(result["command"]) if result["command"] else str(result["stderr"])
        print(f"{status:7} {result['name']}: {command}")
        if verbose or result["status"] in {"failed", "blocked"}:
            stdout = str(result["stdout"]).strip()
            stderr = str(result["stderr"]).strip()
            if stdout:
                print(stdout)
            if stderr:
                print(stderr, file=sys.stderr)
            diagnosis = result.get("diagnosis")
            if isinstance(diagnosis, dict) and diagnosis:
                cause = diagnosis.get("cause", "")
                fix_hint = diagnosis.get("fix_hint", "")
                doc_ref = diagnosis.get("doc_ref", "")
                if cause:
                    print(f"cause: {cause}")
                if fix_hint:
                    print(f"fix_hint: {fix_hint}")
                if doc_ref:
                    print(f"doc_ref: {doc_ref}")


def record_runtime_observability(
    project_root: Path, report: dict[str, object], *, duration_ms: int
) -> None:
    """Record local verification coverage without changing gate outcome."""

    try:
        record_verification_run(project_root, report, duration_ms=duration_ms)
    except Exception:
        return


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Run Harness verification checks.")
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--harness-only", action="store_true", help="Only run Harness document checks.")
    mode.add_argument("--project-only", dest="project_only", action="store_true", help="Only run project language verification checks.")
    mode.add_argument("--go-only", dest="project_only", action="store_true", help="Legacy alias for --project-only.")
    parser.add_argument("--change", help="Limit sync checks and report metadata to one change-id.")
    parser.add_argument("--fixture", help="Run project verification checks from a fixture path relative to the project root.")
    parser.add_argument("--command", help="Run role/write-scope checks for a cc-* command.")
    parser.add_argument("--changed-only", action="store_true", help="Run the smallest deterministic check set for changed files.")
    parser.add_argument("--reuse-cache", action="store_true", help="Reuse passed deterministic Harness checks from the content-addressed cache.")
    parser.add_argument(
        "--execution-mode",
        choices=("normal", "ci", "optimize"),
        help="Select explicit execution policy: normal=changed-only/cache, ci=full, optimize=full plus scheduled benchmark policy.",
    )
    parser.add_argument(
        "--step-timeout-seconds",
        type=float,
        help="Maximum duration for each verification subprocess (default: 900; env: CC_VERIFY_STEP_TIMEOUT_SECONDS).",
    )
    parser.add_argument("--check-review-coverage", action="store_true", help="Validate file_review_scope completeness in review.md.")
    parser.add_argument("--check-finding-locations", action="store_true", help="Validate finding existing_code matches actual file content.")
    parser.add_argument("--check-risk-triage", action="store_true", help="Validate risk_triage table is populated when present in review.md.")
    parser.add_argument("--check-wave-plan", action="store_true", help="Validate wave-plan.json consistency with tasks.md declaration (E_WAVE003).")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    parser.add_argument("--output", help="Write JSON report to this file.")
    parser.add_argument("--verbose", action="store_true", help="Show command output for passing steps.")
    parser.add_argument("--root", help="Explicit Cairness project root; overrides automatic discovery.")
    parser.add_argument("--phase", choices=("propose", "apply", "review", "fix", "test", "archive"))
    parser.add_argument("--activity", choices=("preflight", "execute", "verify", "transition", "wait"))
    parser.add_argument("--run-kind", choices=("primary", "retry", "shadow", "delta", "probe"))
    parser.add_argument("--logical-run-id")
    parser.add_argument("--attempt", type=int)
    parser.add_argument("--terminal", action=argparse.BooleanOptionalAction, default=None)
    parser.add_argument("--failure-class")
    parser.add_argument("--usage", help="Adapter-provided JSON token usage object.")
    parser.add_argument("--change-size", choices=("micro", "small", "medium", "large", "xlarge"))
    parser.add_argument("--change-type")
    parser.add_argument("--framework-version")
    args = parser.parse_args(argv)

    if args.attempt is not None and args.attempt < 1:
        parser.error("--attempt must be a positive integer")
    if args.usage:
        try:
            usage = json.loads(args.usage)
        except json.JSONDecodeError as exc:
            parser.error(f"--usage must be valid JSON: {exc}")
        if not isinstance(usage, dict):
            parser.error("--usage must be a JSON object")
    else:
        usage = None

    try:
        context = load_harness_context(
            explicit_root=Path(args.root) if args.root else None,
            framework_hint=None if args.root else Path(__file__).resolve().parent.parent,
        )
    except HarnessContextError as exc:
        print(f"E_CONTEXT001 {exc}", file=sys.stderr)
        return 2
    started = monotonic()
    report = build_report(args, context)
    _apply_default_run_metadata(args, report)
    if args.failure_class is not None:
        report["failure_class"] = args.failure_class
    usage_payload = usage if usage is not None else _adapter_usage_payload()
    report["usage"] = normalize_adapter_usage(
        usage_payload,
        source=f"{context.adapter.name}_adapter",
    )
    framework_version = args.framework_version
    if not framework_version:
        version_file = context.framework_root / "VERSION"
        if version_file.is_file():
            try:
                framework_version = version_file.read_text(encoding="utf-8").strip()
            except OSError:
                framework_version = None
    cohort: dict[str, str] = {
        "phase": str(report["phase"]),
        "mode": str(report.get("mode", "unknown")),
        "adapter": context.adapter.name,
        **_change_cohort(context.project_root, args.change),
    }
    resolved_execution_mode = args.execution_mode
    selection = report.get("test_selection")
    if not resolved_execution_mode and isinstance(selection, dict):
        value = selection.get("execution_mode")
        if isinstance(value, str) and value:
            resolved_execution_mode = value
    if resolved_execution_mode:
        cohort["execution_mode"] = resolved_execution_mode
    if framework_version:
        cohort["framework_version"] = framework_version
    if args.change_size:
        cohort["change_size"] = args.change_size
    if args.change_type:
        cohort["change_type"] = args.change_type
    execution_metrics = report.get("execution_metrics")
    cache = execution_metrics.get("cache") if isinstance(execution_metrics, dict) else None
    if isinstance(cache, dict):
        if cache.get("hits", 0) and not cache.get("misses", 0):
            cohort["cache_state"] = "hit"
        elif cache.get("misses", 0):
            cohort["cache_state"] = "miss"
        elif cache.get("enabled") is True:
            cohort["cache_state"] = "none"
        else:
            cohort["cache_state"] = "disabled"
    report["cohort"] = cohort
    record_runtime_observability(
        context.project_root,
        report,
        duration_ms=int((monotonic() - started) * 1000),
    )
    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(json.dumps(report, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    if args.json and not args.output:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        print_text(report, args.verbose)
        if args.output:
            print(f"report: {args.output}")
    return 1 if report["status"] in {"failed", "blocked"} else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
