_ACTIVE_CONTEXT: ContextVar[HarnessContext | None] = ContextVar("schema_check_context", default=None)


def active_project_root(claude_root: Path) -> Path:
    context = _ACTIVE_CONTEXT.get()
    return context.project_root if context is not None else claude_root.parent



RUNTIME_CORE_SCHEMA = "runtime-core.schema.json"
RUNTIME_COMMAND_SCHEMA = "runtime-command.schema.json"
RUNTIME_SUBAGENT_CONTRACT_SCHEMA = "runtime-subagent-contract.schema.json"
RUNTIME_READSET_SCHEMA = "runtime-readset.schema.json"
COMMAND_PROTOCOL_SCHEMA = "command-protocol.schema.json"
TECHNOLOGY_DECISION_CATALOG_SCHEMA = "technology-decision-catalog.schema.json"
TOPIC_RULE_SCHEMA = "topic-rule.schema.json"
KNOWLEDGE_CATEGORIES_SCHEMA = "knowledge-categories.schema.json"
PROFILE_SCHEMA = "profile.schema.json"

# Merged protocol.yaml, cached by validate_agent_command_protocol for
# validate_runtime_commands to check inputs.* names against input_contracts.
# Reset per run; populated only when validate_agent_command_protocol runs first.
_PROTOCOL_CACHE: dict[str, Any] | None = None
VALID_PROFILE_IDS = {"minimal", "standard", "strict", "loop"}

