def read(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def parse_frontmatter(text: str) -> dict[str, Any]:
    if not text.startswith("---\n"):
        return {}
    end = text.find("\n---", 4)
    if end == -1:
        return {}
    block = text[4:end]
    try:
        import yaml  # type: ignore

        loaded = yaml.safe_load(block)
        return loaded if isinstance(loaded, dict) else {}
    except Exception:
        return parse_key_values(block)


def parse_legacy_meta(text: str) -> dict[str, Any]:
    match = re.search(r"```(?:text)?\n(.*?)\n```", text, re.S)
    if match:
        return parse_key_values(match.group(1))
    return parse_key_values("\n".join(text.splitlines()[:25]))


def parse_meta(text: str) -> dict[str, Any]:
    return parse_frontmatter(text) or parse_legacy_meta(text)


def load_json_file(path: Path, issues: list[Issue]) -> dict[str, Any] | None:
    if not path.exists():
        add(issues, "E_SCHEMA100", path, "missing JSON schema")
        return None
    try:
        loaded = json.loads(read(path))
    except json.JSONDecodeError as exc:
        add(issues, "E_SCHEMA101", path, f"invalid JSON schema: {exc}")
        return None
    if not isinstance(loaded, dict):
        add(issues, "E_SCHEMA102", path, "JSON schema root must be an object")
        return None
    return loaded


def load_yaml_file(path: Path, issues: list[Issue]) -> dict[str, Any] | None:
    if not path.exists():
        add(issues, "E_SCHEMA103", path, "missing YAML manifest")
        return None
    try:
        import yaml  # type: ignore
    except Exception as exc:
        add(issues, "E_SCHEMA104", path, f"PyYAML is required to parse runtime manifests: {exc}")
        return None
    try:
        loaded = yaml.safe_load(read(path))
    except Exception as exc:
        add(issues, "E_SCHEMA105", path, f"invalid YAML manifest: {exc}")
        return None
    if not isinstance(loaded, dict):
        add(issues, "E_SCHEMA106", path, "YAML manifest root must be a mapping")
        return None
    return loaded


def schema_location(parts: list[str | int]) -> str:
    if not parts:
        return "<root>"
    return ".".join(str(part) for part in parts)


def type_matches(value: Any, expected: str) -> bool:
    if expected == "object":
        return isinstance(value, dict)
    if expected == "array":
        return isinstance(value, list)
    if expected == "string":
        return isinstance(value, str)
    if expected == "integer":
        return isinstance(value, int) and not isinstance(value, bool)
    if expected == "boolean":
        return isinstance(value, bool)
    if expected == "null":
        return value is None
    return True


def json_type_name(value: Any) -> str:
    if isinstance(value, dict):
        return "object"
    if isinstance(value, list):
        return "array"
    if isinstance(value, str):
        return "string"
    if isinstance(value, bool):
        return "boolean"
    if isinstance(value, int):
        return "integer"
    if value is None:
        return "null"
    return type(value).__name__


def resolve_schema_ref(ref: str, root_schema: dict[str, Any]) -> dict[str, Any]:
    if not ref.startswith("#/"):
        raise ValueError(f"unsupported schema ref {ref}")
    current: Any = root_schema
    for raw_part in ref[2:].split("/"):
        part = raw_part.replace("~1", "/").replace("~0", "~")
        current = current[part]
    if not isinstance(current, dict):
        raise ValueError(f"schema ref {ref} does not point to an object")
    return current


def _trial_validate(
    value: Any,
    schema: dict[str, Any],
    root_schema: dict[str, Any],
    path: list[str | int],
    subject_path: Path,
) -> list[Issue]:
    """Validate value against schema into a throwaway issue list.

    Returns the issues found (empty == the schema accepts the value).
    Used by anyOf/oneOf/not combinators to test branch acceptance without
    polluting the caller's issue list. Previously these combinators were
    silently skipped, so schemas relying on oneOf/anyOf/allOf were not
    actually enforced (see E_SCHEMA191..194).
    """
    trial: list[Issue] = []
    validate_against_schema(value, schema, root_schema, path, subject_path, trial)
    return trial


def validate_against_schema(
    value: Any,
    schema: dict[str, Any],
    root_schema: dict[str, Any],
    path: list[str | int],
    subject_path: Path,
    issues: list[Issue],
) -> None:
    if "$ref" in schema:
        try:
            schema = resolve_schema_ref(str(schema["$ref"]), root_schema)
        except Exception as exc:
            add(issues, "E_SCHEMA107", subject_path, f"{schema_location(path)}: {exc}")
            return

    location = schema_location(path)

    # Combinators (draft-07). Each is evaluated independently of type/const.
    if "allOf" in schema and isinstance(schema["allOf"], list):
        for idx, sub in enumerate(schema["allOf"]):
            if isinstance(sub, dict):
                validate_against_schema(
                    value, sub, root_schema, path + [f"allOf[{idx}]"],
                    subject_path, issues,
                )

    if "anyOf" in schema and isinstance(schema["anyOf"], list):
        any_ok = False
        any_failures: list[str] = []
        for idx, sub in enumerate(schema["anyOf"]):
            if not isinstance(sub, dict):
                continue
            trial = _trial_validate(value, sub, root_schema, path, subject_path)
            if not trial:
                any_ok = True
                break
            any_failures.append(f"[{idx}] {trial[0].message}")
        if not any_ok and any_failures:
            add(
                issues, "E_SCHEMA191", subject_path,
                f"{location}: value matches no anyOf schema: " + "; ".join(any_failures),
            )

    if "oneOf" in schema and isinstance(schema["oneOf"], list):
        one_matches = 0
        for sub in schema["oneOf"]:
            if not isinstance(sub, dict):
                continue
            if not _trial_validate(value, sub, root_schema, path, subject_path):
                one_matches += 1
        if one_matches != 1:
            add(
                issues, "E_SCHEMA192", subject_path,
                f"{location}: value matches {one_matches} oneOf schemas (expected exactly 1)",
            )

    if isinstance(schema.get("not"), dict):
        if not _trial_validate(value, schema["not"], root_schema, path, subject_path):
            add(
                issues, "E_SCHEMA193", subject_path,
                f"{location}: value must not match the 'not' schema",
            )

    if "const" in schema and value != schema["const"]:
        add(issues, "E_SCHEMA108", subject_path, f"{location}: expected constant {schema['const']!r}")
        return
    if "enum" in schema and value not in schema["enum"]:
        add(issues, "E_SCHEMA109", subject_path, f"{location}: value {value!r} is not one of {schema['enum']!r}")

    expected_type = schema.get("type")
    if expected_type is not None:
        expected_types = expected_type if isinstance(expected_type, list) else [expected_type]
        if not any(type_matches(value, str(item)) for item in expected_types):
            add(
                issues,
                "E_SCHEMA110",
                subject_path,
                f"{location}: expected type {expected_type!r}, got {json_type_name(value)}",
            )
            return

    if isinstance(value, str):
        if "minLength" in schema and len(value) < int(schema["minLength"]):
            add(issues, "E_SCHEMA111", subject_path, f"{location}: string is shorter than minLength")
        if "pattern" in schema and re.search(str(schema["pattern"]), value) is None:
            add(issues, "E_SCHEMA112", subject_path, f"{location}: value {value!r} does not match pattern")

    if isinstance(value, int) and not isinstance(value, bool):
        if "minimum" in schema and value < int(schema["minimum"]):
            add(issues, "E_SCHEMA113", subject_path, f"{location}: value is below minimum {schema['minimum']}")

    if isinstance(value, list):
        if "minItems" in schema and len(value) < int(schema["minItems"]):
            add(issues, "E_SCHEMA114", subject_path, f"{location}: array has fewer than minItems")
        if schema.get("uniqueItems") is True:
            seen: set[str] = set()
            for item in value:
                marker = json.dumps(item, ensure_ascii=False, sort_keys=True)
                if marker in seen:
                    add(issues, "E_SCHEMA115", subject_path, f"{location}: array items must be unique")
                    break
                seen.add(marker)
        item_schema = schema.get("items")
        if isinstance(item_schema, dict):
            for idx, item in enumerate(value):
                validate_against_schema(item, item_schema, root_schema, path + [idx], subject_path, issues)

    if isinstance(value, dict):
        if "minProperties" in schema and len(value) < int(schema["minProperties"]):
            add(issues, "E_SCHEMA116", subject_path, f"{location}: object has fewer than minProperties")
        property_name_schema = schema.get("propertyNames")
        if isinstance(property_name_schema, dict):
            for key in value:
                validate_against_schema(key, property_name_schema, root_schema, path + [f"{key}<property>"], subject_path, issues)
        required = schema.get("required", [])
        if isinstance(required, list):
            for key in required:
                if key not in value:
                    add(issues, "E_SCHEMA117", subject_path, f"{location}: missing required property {key}")
        properties = schema.get("properties", {})
        if isinstance(properties, dict):
            for key, child_schema in properties.items():
                if key in value and isinstance(child_schema, dict):
                    validate_against_schema(value[key], child_schema, root_schema, path + [key], subject_path, issues)
        additional = schema.get("additionalProperties", True)
        known = set(properties.keys()) if isinstance(properties, dict) else set()
        extras = sorted(set(value.keys()) - known)
        if additional is False and extras:
            add(issues, "E_SCHEMA118", subject_path, f"{location}: additional properties are not allowed: {extras}")
        elif isinstance(additional, dict):
            for key in extras:
                validate_against_schema(value[key], additional, root_schema, path + [key], subject_path, issues)


def project_path(project_root: Path, declared: Any) -> Path | None:
    if not isinstance(declared, str):
        return None
    if "<" in declared or "*" in declared:
        return None
    if declared.startswith(".claude/") or declared.startswith(".cairness/"):
        return project_root / declared
    return None


def require_declared_path(project_root: Path, subject_path: Path, declared: Any, field: str, issues: list[Issue]) -> None:
    if isinstance(declared, str) and declared.startswith(".cairness/"):
        return  # project state files are generated by cc-* commands, not pre-existing
    resolved = project_path(project_root, declared)
    if resolved is not None and not resolved.exists():
        add(issues, "E_SCHEMA119", subject_path, f"{field} references missing path {declared}")


def normalize_declared_path(value: Any) -> str:
    if not isinstance(value, str):
        return str(value)
    normalized = value.strip()
    if normalized.startswith("./"):
        normalized = normalized[2:]
    if normalized.startswith(".claude/"):
        normalized = normalized[len(".claude/") :]
    return normalized


def string_list(value: Any) -> list[str]:
    if not isinstance(value, list):
        return []
    return [item for item in value if isinstance(item, str)]


def ordered_unique(values: list[str]) -> list[str]:
    seen: set[str] = set()
    result: list[str] = []
    for value in values:
        if value not in seen:
            result.append(value)
            seen.add(value)
    return result


def load_registered_roles(project_root: Path, issues: list[Issue]) -> set[str]:
    path = project_root / ROLE_CONTRACTS_PATH
    if not path.exists():
        add(issues, "E_SCHEMA153", path, "missing role contracts for subagent role validation")
        return set()
    roles: set[str] = set()
    for row in table_rows(read(path)):
        if not row:
            continue
        role = row[0].strip().strip("`")
        if role and role not in {"角色", "role"}:
            roles.add(role)
    if not roles:
        add(issues, "E_SCHEMA153", path, "role contracts must register at least one role")
    return roles


def is_final_artifact_write(value: str) -> bool:
    normalized = normalize_declared_path(value)
    if normalized in {normalize_declared_path(item) for item in FINAL_ARTIFACT_WRITE_NAMES}:
        return True
    return normalized.startswith(tuple(normalize_declared_path(item) for item in FINAL_ARTIFACT_WRITE_PREFIXES))


def expected_subagent_parallel_policy(agents: list[Any]) -> str:
    has_scoped_writer = any(isinstance(agent, dict) and agent.get("mode") == "scoped_write" for agent in agents)
    return "disjoint_writes_only" if has_scoped_writer else "read_only_parallel_only"


HARNESS_CONFIG_PATH = ".claude/harness.config.yaml"


def load_runtime_protocol(project_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> dict[str, Any]:
    """Merge protocol assets, pushing failures into issues via load_yaml_file.

    Thin adapter over harness_runtime.readsets.load_protocol_assets, kept under
    the historical name because validate_agent_command_protocol calls it
    directly. The derivation chain itself now lives in the shared module.
    """
    return load_protocol_assets(project_root, core, issues, load_yaml_file)


def derive_readsets(project_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> tuple[dict[str, Any], dict[str, dict[str, Any]]]:
    """Derive readsets via the shared module; drop the config cc-readset needs.

    cc-schema-check's validate pipeline only needs (index, readsets); the
    shared module also returns a readset_config used by cc-readset for file
    paths, which we discard here.
    """
    index, readsets, _config = _derive_readsets_shared(project_root, core, issues, load_yaml_file)
    return index, readsets


def validate_runtime_readsets(claude_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> list[str]:
    if not isinstance(core, dict):
        return []
    project_root = claude_root.parent
    config = runtime_readset_config(core)
    schema_path = project_path(project_root, config["schema"])
    index_path = project_path(project_root, config["index"])
    checked: list[str] = []
    schema = None
    if schema_path is not None:
        checked.append(str(schema_path))
        schema = load_json_file(schema_path, issues)

    expected_index, expected_readsets = derive_readsets(project_root, core, issues)
    if index_path is not None:
        checked.append(str(index_path))
        index = load_yaml_file(index_path, issues)
        if isinstance(index, dict) and index != expected_index:
            add(issues, "E_SCHEMA150", index_path, "runtime readset index is stale; run cc-readset --write")

    for command, expected in expected_readsets.items():
        declared = expected_index.get("commands", {}).get(command)
        path = project_path(project_root, declared)
        if path is None:
            continue
        checked.append(str(path))
        actual = load_yaml_file(path, issues)
        if isinstance(actual, dict):
            if schema is not None:
                validate_against_schema(actual, schema, schema, [], path, issues)
            if actual != expected:
                add(issues, "E_SCHEMA151", path, f"{command} runtime readset is stale; run cc-readset --write")

    readset_dir = project_path(project_root, config["dir"])
    expected_paths = {config["index"], *expected_index.get("commands", {}).values()}
    if readset_dir is not None and readset_dir.exists():
        for path in sorted(readset_dir.glob("*.yaml")):
            declared = path.relative_to(project_root).as_posix()
            if declared not in expected_paths:
                add(issues, "E_SCHEMA152", path, "extra runtime readset file")
    return checked


def validate_technology_catalog_shape(catalog: dict[str, Any], catalog_path: Path, issues: list[Issue]) -> None:
    policy = catalog.get("decision_policy") if isinstance(catalog.get("decision_policy"), dict) else {}
    confirmation_levels = set(string_list(policy.get("confirmation_required_levels")))
    seen_groups: set[str] = set()
    for group in catalog.get("decision_groups", []) if isinstance(catalog.get("decision_groups"), list) else []:
        if not isinstance(group, dict):
            continue
        group_id = group.get("id")
        if isinstance(group_id, str):
            if group_id in seen_groups:
                add(issues, "E_SCHEMA175", catalog_path, f"duplicate technology decision group {group_id}")
            seen_groups.add(group_id)
        options = group.get("options") if isinstance(group.get("options"), list) else []
        option_ids: set[str] = set()
        for option in options:
            if not isinstance(option, dict) or not isinstance(option.get("id"), str):
                continue
            option_id = option["id"]
            if option_id in option_ids:
                add(issues, "E_SCHEMA180", catalog_path, f"decision group {group_id} has duplicate option {option_id}")
            option_ids.add(option_id)
        default = group.get("default_recommendation")
        if isinstance(default, str) and default not in option_ids:
            add(issues, "E_SCHEMA176", catalog_path, f"decision group {group_id} default_recommendation {default} is not an option")
        level = group.get("level")
        if isinstance(level, str) and level in confirmation_levels and group.get("requires_user_confirmation") is not True:
            add(issues, "E_SCHEMA177", catalog_path, f"decision group {group_id} level {level} must require user confirmation")


def validate_language_profile_and_technology_catalog(
    project_root: Path,
    profile_path: Path,
    language_profile_schema: dict[str, Any] | None,
    catalog_schema: dict[str, Any] | None,
    checked: list[str],
    issues: list[Issue],
) -> None:
    if str(profile_path) not in checked:
        checked.append(str(profile_path))
    language = load_yaml_file(profile_path, issues)
    if not isinstance(language, dict):
        return
    if language_profile_schema is not None:
        validate_against_schema(language, language_profile_schema, language_profile_schema, [], profile_path, issues)
    for field in ("version", "language", "project_detection", "verification", "fixtures", "technology_decisions"):
        if field not in language:
            add(issues, "E_SCHEMA170", profile_path, f"language profile missing {field}")
    project_detection = language.get("project_detection") if isinstance(language.get("project_detection"), dict) else {}
    module_file = project_detection.get("module_file")
    module_files = project_detection.get("module_files")
    if isinstance(module_file, str) and isinstance(module_files, list) and module_file not in string_list(module_files):
        add(issues, "E_SCHEMA181", profile_path, f"project_detection.module_file {module_file} must be listed in module_files")

    technology_decisions = language.get("technology_decisions") if isinstance(language.get("technology_decisions"), dict) else {}
    declared_catalog = technology_decisions.get("catalog")
    require_declared_path(project_root, profile_path, declared_catalog, "technology_decisions.catalog", issues)
    catalog_path = project_path(project_root, declared_catalog)
    if catalog_path is None:
        return
    if str(catalog_path) not in checked:
        checked.append(str(catalog_path))
    catalog = load_yaml_file(catalog_path, issues)
    if not isinstance(catalog, dict):
        return
    if catalog_schema is not None:
        validate_against_schema(catalog, catalog_schema, catalog_schema, [], catalog_path, issues)
    if isinstance(language.get("language"), str) and catalog.get("language") != language.get("language"):
        add(issues, "E_SCHEMA178", catalog_path, f"catalog language {catalog.get('language')} does not match profile language {language.get('language')}")
    validate_technology_catalog_shape(catalog, catalog_path, issues)


def validate_agent_command_protocol(claude_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> list[str]:
    project_root = claude_root.parent
    config = runtime_protocol_config(core)
    protocol_path = project_path(project_root, config["protocol"])
    schema_path = project_path(project_root, config["schema"])
    language_path = project_path(project_root, config["default_language_profile"])
    checked: list[str] = []

    protocol: dict[str, Any] | None = None
    schema: dict[str, Any] | None = None
    if schema_path is not None:
        checked.append(str(schema_path))
        schema = load_json_file(schema_path, issues)
    for key in ("protocol", "technology_decisions", "language_profile"):
        asset_path = project_path(project_root, config.get(key))
        if asset_path is not None:
            checked.append(str(asset_path))
    protocol = load_runtime_protocol(project_root, core, issues)
    if isinstance(protocol, dict) and schema is not None and protocol_path is not None:
        validate_against_schema(protocol, schema, schema, [], protocol_path, issues)
    language_profile_schema: dict[str, Any] | None = None
    language_profile_schema_path: Path | None = None
    catalog_schema: dict[str, Any] | None = None
    catalog_schema_path: Path | None = None
    if isinstance(protocol, dict):
        declared_language_schema = (
            protocol.get("language_profile", {}).get("schema")
            if isinstance(protocol.get("language_profile"), dict)
            else None
        )
        language_profile_schema_path = project_path(project_root, declared_language_schema)
        if language_profile_schema_path is not None:
            checked.append(str(language_profile_schema_path))
            language_profile_schema = load_json_file(language_profile_schema_path, issues)
        declared_catalog_schema = (
            protocol.get("technology_decisions", {}).get("catalog_schema")
            if isinstance(protocol.get("technology_decisions"), dict)
            else None
        )
        catalog_schema_path = project_path(project_root, declared_catalog_schema)
        if catalog_schema_path is not None:
            checked.append(str(catalog_schema_path))
            catalog_schema = load_json_file(catalog_schema_path, issues)

    if not isinstance(protocol, dict) or protocol_path is None:
        return checked

    path_roles = protocol.get("path_roles") if isinstance(protocol.get("path_roles"), dict) else {}
    error_taxonomy = protocol.get("error_taxonomy") if isinstance(protocol.get("error_taxonomy"), dict) else {}
    input_contracts = protocol.get("input_contracts") if isinstance(protocol.get("input_contracts"), dict) else {}
    _E_CODE_RE = re.compile(r"^E_[A-Z]+[0-9]+$")
    for taxon, contract in error_taxonomy.items():
        if not isinstance(contract, dict):
            continue
        error_codes = contract.get("error_codes")
        if error_codes is None:
            continue
        if not isinstance(error_codes, list):
            add(issues, "E_SCHEMA131", protocol_path, f"error_taxonomy.{taxon}.error_codes must be a list")
            continue
        for code in error_codes:
            if not isinstance(code, str) or not _E_CODE_RE.match(code):
                add(issues, "E_SCHEMA131", protocol_path, f"error_taxonomy.{taxon}.error_codes entry {code!r} is not a valid E_* code")
    for name, contract in input_contracts.items():
        if not isinstance(contract, dict):
            continue
        resolves_to = contract.get("resolves_to")
        if isinstance(resolves_to, str) and resolves_to not in path_roles:
            add(issues, "E_SCHEMA171", protocol_path, f"input_contracts.{name}.resolves_to references unknown path role {resolves_to}")
        for error_field in ("missing_error", "invalid_error"):
            error_code = contract.get(error_field)
            if isinstance(error_code, str) and error_code != "none" and error_code not in error_taxonomy:
                add(issues, "E_SCHEMA172", protocol_path, f"input_contracts.{name}.{error_field} references unknown error {error_code}")

    rendering = protocol.get("result_rendering") if isinstance(protocol.get("result_rendering"), dict) else {}
    for field in ("success_template", "error_template"):
        require_declared_path(project_root, protocol_path, rendering.get(field), f"result_rendering.{field}", issues)

    lifecycle_events = protocol.get("lifecycle_events") if isinstance(protocol.get("lifecycle_events"), dict) else {}
    for field in ("schema", "template"):
        require_declared_path(project_root, protocol_path, lifecycle_events.get(field), f"lifecycle_events.{field}", issues)

    technology_decisions = protocol.get("technology_decisions") if isinstance(protocol.get("technology_decisions"), dict) else {}
    require_declared_path(project_root, protocol_path, technology_decisions.get("catalog_schema"), "technology_decisions.catalog_schema", issues)
    blocking_error = technology_decisions.get("blocking_error")
    if isinstance(blocking_error, str) and blocking_error not in error_taxonomy:
        add(issues, "E_SCHEMA179", protocol_path, f"technology_decisions.blocking_error references unknown error {blocking_error}")

    language_profile = protocol.get("language_profile") if isinstance(protocol.get("language_profile"), dict) else {}
    require_declared_path(project_root, protocol_path, language_profile.get("schema"), "language_profile.schema", issues)
    resolution = language_profile.get("resolution") if isinstance(language_profile.get("resolution"), dict) else {}
    for error_field in ("ambiguous_error", "unsupported_error"):
        error_code = resolution.get(error_field)
        if isinstance(error_code, str) and error_code not in error_taxonomy:
            add(issues, "E_SCHEMA182", protocol_path, f"language_profile.resolution.{error_field} references unknown error {error_code}")
    profiles = language_profile.get("profiles") if isinstance(language_profile.get("profiles"), dict) else {}
    default_profile = language_profile.get("default")
    if isinstance(default_profile, str) and default_profile not in profiles:
        add(issues, "E_SCHEMA173", protocol_path, f"language_profile.default {default_profile} is not declared in profiles")
    for profile_name, declared in profiles.items():
        require_declared_path(project_root, protocol_path, declared, f"language_profile.profiles.{profile_name}", issues)
        profile_path = project_path(project_root, declared)
        if profile_path is not None:
            validate_language_profile_and_technology_catalog(project_root, profile_path, language_profile_schema, catalog_schema, checked, issues)
    if language_path is not None and profiles and str(language_path) not in {
        str(project_path(project_root, value)) for value in profiles.values() if isinstance(value, str)
    }:
        add(issues, "E_SCHEMA174", protocol_path, "runtime_protocol.default_language_profile must be declared in protocol language_profile.profiles")
    # Cache the merged protocol so validate_runtime_commands can check
    # inputs.* names against input_contracts without reloading assets.
    # validate_runtime_manifests calls validate_agent_command_protocol before
    # validate_runtime_commands (see that function).
    global _PROTOCOL_CACHE
    _PROTOCOL_CACHE = protocol if isinstance(protocol, dict) else None
    return checked


def validate_topic_rules(claude_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> list[str]:
    if not isinstance(core, dict) or not isinstance(core.get("topic_rules"), dict):
        return []
    project_root = claude_root.parent
    schema_path = claude_root / "schemas" / TOPIC_RULE_SCHEMA
    schema = load_json_file(schema_path, issues)
    checked = [str(schema_path)]

    for topic_key, declared_path in sorted(core["topic_rules"].items()):
        path = project_path(project_root, declared_path)
        if path is None:
            continue
        checked.append(str(path))
        if not path.exists():
            continue

        if declared_path.endswith(".yaml"):
            data = load_yaml_file(path, issues)
            if data is None:
                continue
            for rk in TOPIC_RULE_YAML_REQUIRED_KEYS:
                if rk not in data:
                    add(issues, "E_SCHEMA137", path, f"topic rule {topic_key} missing required key: {rk}")
            ar = data.get("anti_rationalization")
            if isinstance(ar, list):
                for i, entry in enumerate(ar):
                    if isinstance(entry, dict) and ("claim" not in entry or "reality" not in entry):
                        add(issues, "E_SCHEMA139", path, f"topic rule {topic_key} anti_rationalization[{i}] missing claim/reality")
            rel = data.get("relevance")
            if rel is not None:
                if not isinstance(rel, dict):
                    add(issues, "E_SCHEMA140", path, f"topic rule {topic_key} relevance must be a mapping")
                else:
                    cat = rel.get("category")
                    if cat not in ("always", "change_type", "default_skip"):
                        add(issues, "E_SCHEMA140", path, f"topic rule {topic_key} relevance.category must be always|change_type|default_skip, got {cat}")
                    trigs = rel.get("triggers")
                    if not isinstance(trigs, list) or len(trigs) == 0:
                        add(issues, "E_SCHEMA140", path, f"topic rule {topic_key} relevance.triggers must be a non-empty list")
        else:
            text = read(path)
            if schema is not None:
                validate_against_schema(parse_frontmatter(text), schema, schema, [], path, issues)
            previous_position = -1
            for marker in TOPIC_RULE_REQUIRED_SECTIONS:
                position = text.find(marker)
                if position == -1:
                    add(issues, "E_SCHEMA137", path, f"topic rule {topic_key} missing skill-like section {marker}")
                    continue
                if position < previous_position:
                    add(issues, "E_SCHEMA138", path, f"topic rule {topic_key} has section out of order: {marker}")
                previous_position = position
            if TOPIC_RULE_RATIONALIZATION_HEADER not in text:
                add(issues, "E_SCHEMA139", path, f"topic rule {topic_key} missing anti-rationalization table")
    return checked


def validate_runtime_core(claude_root: Path, issues: list[Issue]) -> dict[str, Any] | None:
    project_root = claude_root.parent
    core_path = claude_root / "runtime" / "core.yaml"
    schema_path = claude_root / "schemas" / RUNTIME_CORE_SCHEMA
    core = load_yaml_file(core_path, issues)
    schema = load_json_file(schema_path, issues)
    if core is None:
        return None
    if schema is not None:
        validate_against_schema(core, schema, schema, [], core_path, issues)

    for field in ("workflow_definition",):
        require_declared_path(project_root, core_path, core.get(field), field, issues)
    for section in ("runtime_readsets", "runtime_protocol", "legacy_fallback", "governance", "scripts", "topic_rules"):
        values = core.get(section)
        if isinstance(values, dict):
            for key, declared in values.items():
                require_declared_path(project_root, core_path, declared, f"{section}.{key}", issues)

    migrated = core.get("migrated_commands")
    runtime_commands = core.get("runtime_commands")
    if isinstance(migrated, list) and isinstance(runtime_commands, dict):
        migrated_set = set(migrated)
        mapped_set = set(runtime_commands.keys())
        if migrated_set != mapped_set:
            add(
                issues,
                "E_SCHEMA120",
                core_path,
                f"migrated_commands and runtime_commands differ: missing={sorted(migrated_set - mapped_set)}, extra={sorted(mapped_set - migrated_set)}",
            )
        for command in sorted(mapped_set):
            expected = f".claude/runtime/commands/{command}.yaml"
            actual = runtime_commands.get(command)
            if actual != expected:
                add(issues, "E_SCHEMA121", core_path, f"runtime_commands.{command} must be {expected}")
            require_declared_path(project_root, core_path, actual, f"runtime_commands.{command}", issues)

    # Project profiles (minimal/standard/strict) — validate structure against
    # profile.schema, symmetric to language-profile validation. A4 closes the
    # gap where these files were read (readsets.resolve_active_profile_path)
    # but never schema-validated.
    profiles_cfg = core.get("profiles")
    if isinstance(profiles_cfg, dict):
        profiles_dir = profiles_cfg.get("dir")
        default_profile = profiles_cfg.get("default")
        if isinstance(default_profile, str) and default_profile not in VALID_PROFILE_IDS:
            add(issues, "E_SCHEMA194", core_path, f"profiles.default {default_profile!r} is not one of {sorted(VALID_PROFILE_IDS)}")
        if isinstance(profiles_dir, str):
            profiles_root = project_path(project_root, profiles_dir)
            profile_schema_path = claude_root / "schemas" / PROFILE_SCHEMA
            profile_schema = load_json_file(profile_schema_path, issues)
            if profiles_root is not None and profile_schema is not None:
                for profile_id in sorted(VALID_PROFILE_IDS):
                    profile_file = profiles_root / f"{profile_id}.yaml"
                    if not profile_file.exists():
                        add(issues, "E_SCHEMA195", core_path, f"profiles.dir missing {profile_id}.yaml")
                        continue
                    profile = load_yaml_file(profile_file, issues)
                    if isinstance(profile, dict):
                        validate_against_schema(profile, profile_schema, profile_schema, [], profile_file, issues)
    return core


def effective_subagent_contract(
    project_root: Path,
    command: str,
    manifest: dict[str, Any],
    manifest_path: Path,
    contract_schema: dict[str, Any] | None,
    checked: list[str],
    issues: list[Issue],
) -> dict[str, Any] | None:
    subagents = manifest.get("subagents")
    if not isinstance(subagents, dict):
        return None
    contract_declared = subagents.get("contract")
    if not isinstance(contract_declared, str):
        return subagents

    contract_path = project_path(project_root, contract_declared)
    if contract_path is None:
        add(issues, "E_SCHEMA183", manifest_path, f"subagents.contract must be a project path: {contract_declared}")
        return subagents
    checked.append(str(contract_path))
    contract = load_yaml_file(contract_path, issues)
    if not isinstance(contract, dict):
        return subagents
    if contract_schema is not None:
        validate_against_schema(contract, contract_schema, contract_schema, [], contract_path, issues)
    if contract.get("command") != command:
        add(issues, "E_SCHEMA184", contract_path, f"subagent contract command must be {command}")

    merged = {
        "enabled": subagents.get("enabled"),
        "policy": subagents.get("policy"),
    }
    for key in ("merge_owner", "final_writes_by", "write_scope_policy", "parallel_policy", "agents", "merge_requirements"):
        if key in contract:
            merged[key] = contract[key]
    return merged


def validate_subagent_runtime_contract(
    command: str,
    manifest: dict[str, Any],
    path: Path,
    issues: list[Issue],
    registered_roles: set[str],
) -> None:
    subagents = manifest.get("subagents")
    if command in SUBAGENT_REQUIRED_COMMANDS:
        if not isinstance(subagents, dict) or subagents.get("enabled") is not True:
            add(issues, "E_SCHEMA122", path, f"{command} must declare enabled subagents")
            return
    if not isinstance(subagents, dict):
        return

    agents = subagents.get("agents")
    if not isinstance(agents, list):
        add(issues, "E_SCHEMA185", path, f"{command} subagents must declare agents inline or through subagents.contract")
        return
    parent_writes = {normalize_declared_path(item) for item in string_list(manifest.get("writes"))}
    merge_requirements = string_list(subagents.get("merge_requirements"))
    if subagents.get("write_scope_policy") != "parent_writes_subset":
        add(issues, "E_SCHEMA155", path, f"{command} subagents.write_scope_policy must be parent_writes_subset")
    expected_parallel_policy = expected_subagent_parallel_policy(agents)
    if subagents.get("parallel_policy") != expected_parallel_policy:
        add(
            issues,
            "E_SCHEMA156",
            path,
            f"{command} subagents.parallel_policy must be {expected_parallel_policy}",
        )
    if not any("main_flow" in requirement for requirement in merge_requirements):
        add(issues, "E_SCHEMA160", path, f"{command} subagents.merge_requirements must include main_flow ownership")

    names: set[str] = set()
    scoped_write_owners: dict[str, str] = {}
    for idx, agent in enumerate(agents):
        if not isinstance(agent, dict):
            continue
        name = agent.get("name")
        if isinstance(name, str):
            if name in names:
                add(issues, "E_SCHEMA123", path, f"subagents.agents[{idx}] duplicate name {name}")
            names.add(name)
        mode = agent.get("mode")
        role = agent.get("role")
        if isinstance(role, str) and registered_roles and role not in registered_roles:
            add(issues, "E_SCHEMA154", path, f"subagent {name} role {role} is not registered in role-contracts")
        output_contract = agent.get("output_contract")
        if not isinstance(output_contract, dict):
            add(issues, "E_SCHEMA162", path, f"subagent {name} must declare output_contract")
        else:
            if output_contract.get("format") != SUBAGENT_OUTPUT_FORMAT:
                add(issues, "E_SCHEMA162", path, f"subagent {name} output_contract.format must be {SUBAGENT_OUTPUT_FORMAT}")
            output_fields = set(string_list(output_contract.get("required_fields")))
            if output_fields != SUBAGENT_OUTPUT_REQUIRED_FIELDS:
                add(
                    issues,
                    "E_SCHEMA163",
                    path,
                    f"subagent {name} output_contract.required_fields must be {sorted(SUBAGENT_OUTPUT_REQUIRED_FIELDS)}",
                )
            evidence_quality = output_contract.get("evidence_quality")
            if not isinstance(evidence_quality, dict):
                add(issues, "E_SCHEMA175", path, f"subagent {name} output_contract must declare evidence_quality")
            else:
                for key, expected in SUBAGENT_QUALITY_REQUIRED.items():
                    if evidence_quality.get(key) != expected:
                        add(issues, "E_SCHEMA176", path, f"subagent {name} evidence_quality.{key} must be {expected!r}")
        writes = agent.get("writes")
        if mode in READ_ONLY_SUBAGENT_MODES and isinstance(writes, list) and writes:
            add(issues, "E_SCHEMA124", path, f"subagent {name} mode {mode} must not declare writes")
        if mode == "scoped_write" and isinstance(writes, list) and not writes:
            add(issues, "E_SCHEMA125", path, f"subagent {name} mode scoped_write must declare writes")
        if mode != "scoped_write" or not isinstance(writes, list):
            continue
        for write in string_list(writes):
            normalized_write = normalize_declared_path(write)
            if normalized_write not in parent_writes:
                add(
                    issues,
                    "E_SCHEMA157",
                    path,
                    f"subagent {name} write {write} is outside parent command writes",
                )
            if is_final_artifact_write(write):
                add(
                    issues,
                    "E_SCHEMA158",
                    path,
                    f"subagent {name} must not write final artifact {write}",
                )
            previous_owner = scoped_write_owners.get(normalized_write)
            if previous_owner is not None:
                add(
                    issues,
                    "E_SCHEMA159",
                    path,
                    f"subagent {name} overlaps scoped write {write} with {previous_owner}",
                )
            scoped_write_owners[normalized_write] = str(name)
    if len(scoped_write_owners) > 1 and not any(
        "disjoint" in requirement or "parallel" in requirement for requirement in merge_requirements
    ):
        add(
            issues,
            "E_SCHEMA161",
            path,
            f"{command} subagents.merge_requirements must declare disjoint parallel write handling",
        )


def result_sources(result_contract: dict[str, Any], section: str) -> set[str]:
    value = result_contract.get(section)
    if not isinstance(value, dict) or not isinstance(value.get("sources"), list):
        return set()
    return {item for item in value["sources"] if isinstance(item, str)}


def effective_result_contract(
    project_root: Path,
    manifest: dict[str, Any],
    path: Path,
    checked: list[str],
    issues: list[Issue],
) -> dict[str, Any] | None:
    result_contract = manifest.get("result_contract")
    if not isinstance(result_contract, dict):
        return None

    effective: dict[str, Any] = {}
    profile_declared = result_contract.get("profile")
    if isinstance(profile_declared, str):
        profile_path = project_path(project_root, profile_declared)
        if profile_path is not None:
            checked.append(str(profile_path))
            profile = load_yaml_file(profile_path, issues)
            if isinstance(profile, dict):
                effective.update(profile)

    for key, value in result_contract.items():
        if key == "profile":
            continue
        if key in {"evidence", "risks"} and isinstance(value, dict) and isinstance(effective.get(key), dict):
            merged = dict(effective[key])
            merged.update(value)
            effective[key] = merged
        else:
            effective[key] = value
    return effective


def validate_result_contract(
    project_root: Path,
    command: str,
    manifest: dict[str, Any],
    path: Path,
    checked: list[str],
    issues: list[Issue],
) -> None:
    result_contract = effective_result_contract(project_root, manifest, path, checked, issues)
    if not isinstance(result_contract, dict):
        return

    required_fields = set(result_contract.get("required_fields", []) if isinstance(result_contract.get("required_fields"), list) else [])
    if required_fields != RESULT_REQUIRED_FIELDS:
        add(
            issues,
            "E_SCHEMA140",
            path,
            f"{command} result_contract.required_fields must be {sorted(RESULT_REQUIRED_FIELDS)}",
        )

    status_values = set(result_contract.get("status_values", []) if isinstance(result_contract.get("status_values"), list) else [])
    if status_values != RESULT_STATUS_VALUES:
        add(
            issues,
            "E_SCHEMA141",
            path,
            f"{command} result_contract.status_values must be {sorted(RESULT_STATUS_VALUES)}",
        )

    if result_contract.get("writes") != "manifest_writes":
        add(issues, "E_SCHEMA142", path, f"{command} result_contract.writes must be manifest_writes")

    evidence = result_contract.get("evidence")
    if isinstance(evidence, dict) and evidence.get("required") is not True:
        add(issues, "E_SCHEMA143", path, f"{command} result_contract.evidence.required must be true")
    evidence_sources = result_sources(result_contract, "evidence")
    if isinstance(manifest.get("auto_validation"), list) and manifest.get("auto_validation") and "auto_validation" not in evidence_sources:
        add(issues, "E_SCHEMA144", path, f"{command} result_contract.evidence.sources must include auto_validation")
    if isinstance(manifest.get("writes"), list) and manifest.get("writes") and "written_artifacts" not in evidence_sources:
        add(issues, "E_SCHEMA145", path, f"{command} result_contract.evidence.sources must include written_artifacts")

    risks = result_contract.get("risks")
    if isinstance(risks, dict) and risks.get("required") is not True:
        add(issues, "E_SCHEMA146", path, f"{command} result_contract.risks.required must be true")
    risk_sources = result_sources(result_contract, "risks")
    for source in ("stop_conditions", "forbids"):
        if source not in risk_sources:
            add(issues, "E_SCHEMA147", path, f"{command} result_contract.risks.sources must include {source}")
    if isinstance(manifest.get("red_flags"), list) and manifest.get("red_flags") and "red_flags" not in risk_sources:
        add(issues, "E_SCHEMA148", path, f"{command} result_contract.risks.sources must include red_flags")

    if not isinstance(result_contract.get("next_actions"), list) or not result_contract.get("next_actions"):
        add(issues, "E_SCHEMA149", path, f"{command} result_contract.next_actions must not be empty")


def validate_interaction_contract(command: str, manifest: dict[str, Any], path: Path, issues: list[Issue]) -> None:
    if command not in INTERACTION_CONTRACT_COMMANDS:
        return
    contract = manifest.get("interaction_contract")
    if not isinstance(contract, dict):
        add(issues, "E_SCHEMA164", path, f"{command} must declare interaction_contract")
        return
    if contract.get("mode") != "interactive_required":
        add(issues, "E_SCHEMA165", path, f"{command} interaction_contract.mode must be interactive_required")

    section_names = {"clarification", "hard_gate", "confirmation", "selection"}
    if not any(isinstance(contract.get(section), dict) for section in section_names):
        add(issues, "E_SCHEMA166", path, f"{command} interaction_contract must declare at least one interaction section")

    requirements = INTERACTION_REQUIREMENTS.get(command, {})
    for (section_name, field), required_values in requirements.items():
        section = contract.get(section_name)
        if not isinstance(section, dict):
            add(issues, "E_SCHEMA167", path, f"{command} interaction_contract.{section_name} must be an object")
            continue
        if section_name == "clarification" and section.get("resolution_required_before_ready") is not True:
            add(
                issues,
                "E_SCHEMA168",
                path,
                f"{command} {section_name}.resolution_required_before_ready must be true",
            )
        actual_values = set(string_list(section.get(field)))
        missing = sorted(required_values - actual_values)
        if missing:
            add(issues, "E_SCHEMA169", path, f"{command} {section_name}.{field} missing {missing}")


def validate_runtime_command_references(
    project_root: Path,
    core: dict[str, Any] | None,
    command: str,
    manifest: dict[str, Any],
    path: Path,
    issues: list[Issue],
) -> None:
    registered_topics: set[str] = set()
    if isinstance(core, dict) and isinstance(core.get("topic_rules"), dict):
        registered_topics = {value for value in core["topic_rules"].values() if isinstance(value, str)}

    if manifest.get("command") != command:
        add(issues, "E_SCHEMA126", path, f"command field must match runtime core key {command}")
    if path.name != f"{command}.yaml":
        add(issues, "E_SCHEMA127", path, f"filename must be {command}.yaml")

    state = manifest.get("state")
    if isinstance(state, dict) and state.get("change_to") == "done" and command != "cc-archive":
        add(issues, "E_SCHEMA128", path, "only cc-archive may set change_to done")

    if command in ANTI_RATIONALIZATION_COMMANDS:
        for key in ("anti_rationalizations", "red_flags"):
            if not isinstance(manifest.get(key), list) or not manifest.get(key):
                add(issues, "E_SCHEMA129", path, f"{command} must declare non-empty {key}")

    for idx, declared in enumerate(manifest.get("required_reads", []) if isinstance(manifest.get("required_reads"), list) else []):
        require_declared_path(project_root, path, declared, f"required_reads[{idx}]", issues)
    conditional_reads = manifest.get("conditional_reads")
    if isinstance(conditional_reads, dict):
        for condition, reads in conditional_reads.items():
            if not isinstance(reads, list):
                continue
            for idx, declared in enumerate(reads):
                require_declared_path(project_root, path, declared, f"conditional_reads.{condition}[{idx}]", issues)
    template_requirements = TEMPLATE_READ_REQUIREMENTS.get(command, {})
    conditional_read_map = conditional_reads if isinstance(conditional_reads, dict) else {}
    for condition, templates in sorted(template_requirements.items()):
        actual_reads = conditional_read_map.get(condition)
        if not isinstance(actual_reads, list):
            add(issues, "E_SCHEMA189", path, f"{command} missing conditional_reads.{condition} for template artifacts")
            continue
        for template in templates:
            if template not in actual_reads:
                add(issues, "E_SCHEMA190", path, f"{command} must conditionally read template {template} under {condition}")

    topic_rules = manifest.get("topic_rules")
    if isinstance(topic_rules, dict):
        for condition, rules in topic_rules.items():
            if not isinstance(rules, list):
                continue
            for idx, rule_path in enumerate(rules):
                if registered_topics and rule_path not in registered_topics:
                    add(issues, "E_SCHEMA130", path, f"topic_rules.{condition}[{idx}] is not registered in runtime/core.yaml: {rule_path}")
                require_declared_path(project_root, path, rule_path, f"topic_rules.{condition}[{idx}]", issues)

    subagents = manifest.get("subagents")
    if isinstance(subagents, dict):
        require_declared_path(project_root, path, subagents.get("policy"), "subagents.policy", issues)
        if isinstance(subagents.get("contract"), str):
            require_declared_path(project_root, path, subagents.get("contract"), "subagents.contract", issues)
    result_contract = manifest.get("result_contract")
    if isinstance(result_contract, dict):
        require_declared_path(project_root, path, result_contract.get("profile"), "result_contract.profile", issues)


def validate_inputs_registered(command: str, manifest: dict[str, Any], manifest_path: Path, issues: list[Issue]) -> None:
    """Check manifest.inputs.* names are registered in protocol.yaml input_contracts.

    E_SCHEMA133: a required/optional input name is not declared in input_contracts.
    E_SCHEMA134: a required input's contract uses missing_error: none (a required
                 input cannot use the 'no error' sentinel).
    E_SCHEMA199: an enum input contract is missing its values array.
    Relies on _PROTOCOL_CACHE populated by validate_agent_command_protocol.
    """
    protocol = _PROTOCOL_CACHE
    if not isinstance(protocol, dict):
        return
    input_contracts = protocol.get("input_contracts") if isinstance(protocol.get("input_contracts"), dict) else {}
    inputs = manifest.get("inputs") if isinstance(manifest.get("inputs"), dict) else {}
    for slot in ("required", "optional"):
        names = inputs.get(slot)
        if not isinstance(names, list):
            continue
        for name in names:
            if not isinstance(name, str):
                continue
            contract = input_contracts.get(name)
            if contract is None:
                add(issues, "E_SCHEMA133", manifest_path, f"{command}.inputs.{slot}: '{name}' is not declared in protocol.yaml input_contracts")
                continue
            if not isinstance(contract, dict):
                continue
            if contract.get("type") == "enum":
                values = contract.get("values")
                if not isinstance(values, list) or not values:
                    add(issues, "E_SCHEMA199", manifest_path, f"input_contracts.{name}: enum contract missing values array")
            if slot == "required" and contract.get("missing_error") == "none":
                add(issues, "E_SCHEMA134", manifest_path, f"{command}.inputs.required: '{name}' contract uses missing_error: none (required input cannot use the 'no error' sentinel)")


def validate_runtime_commands(claude_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> list[str]:
    project_root = claude_root.parent
    schema_path = claude_root / "schemas" / RUNTIME_COMMAND_SCHEMA
    schema = load_json_file(schema_path, issues)
    subagent_schema_path = claude_root / "schemas" / RUNTIME_SUBAGENT_CONTRACT_SCHEMA
    subagent_schema = load_json_file(subagent_schema_path, issues)
    registered_roles = load_registered_roles(project_root, issues)
    runtime_commands = core.get("runtime_commands") if isinstance(core, dict) else None
    if isinstance(runtime_commands, dict):
        command_paths = [(command, project_path(project_root, path)) for command, path in sorted(runtime_commands.items())]
    else:
        command_paths = [(path.stem, path) for path in sorted((claude_root / "runtime" / "commands").glob("cc-*.yaml"))]

    checked: list[str] = [str(subagent_schema_path)]
    for command, resolved_path in command_paths:
        if resolved_path is None:
            continue
        checked.append(str(resolved_path))
        manifest = load_yaml_file(resolved_path, issues)
        if manifest is None:
            continue
        if schema is not None:
            validate_against_schema(manifest, schema, schema, [], resolved_path, issues)
        validate_runtime_command_references(project_root, core, command, manifest, resolved_path, issues)
        effective_manifest = dict(manifest)
        effective_subagents = effective_subagent_contract(
            project_root,
            command,
            manifest,
            resolved_path,
            subagent_schema,
            checked,
            issues,
        )
        if effective_subagents is not None:
            effective_manifest["subagents"] = effective_subagents
        validate_subagent_runtime_contract(command, effective_manifest, resolved_path, issues, registered_roles)
        validate_result_contract(project_root, command, manifest, resolved_path, checked, issues)
        validate_interaction_contract(command, manifest, resolved_path, issues)
        validate_inputs_registered(command, manifest, resolved_path, issues)
    return checked


def validate_runtime_manifests(claude_root: Path, issues: list[Issue]) -> tuple[list[str], list[str]]:
    core = validate_runtime_core(claude_root, issues)
    checked = [str(claude_root / "runtime" / "core.yaml")]
    checked.extend(validate_agent_command_protocol(claude_root, core, issues))
    checked.extend(validate_runtime_commands(claude_root, core, issues))
    checked.extend(validate_runtime_readsets(claude_root, core, issues))
    checked.extend(validate_knowledge_categories(claude_root, issues))
    checked.extend(validate_enums(claude_root, issues))
    checked_topic_rules = validate_topic_rules(claude_root, core, issues)
    return checked, checked_topic_rules


def validate_knowledge_categories(claude_root: Path, issues: list[Issue]) -> list[str]:
    catalog_path = claude_root / "runtime" / "knowledge-categories.yaml"
    schema_path = claude_root / "schemas" / KNOWLEDGE_CATEGORIES_SCHEMA
    catalog = load_yaml_file(catalog_path, issues)
    schema = load_json_file(schema_path, issues)
    if catalog is None or schema is None:
        return [str(catalog_path)] if catalog_path.exists() else []
    validate_against_schema(catalog, schema, schema, [], catalog_path, issues)

    seen_subdirs: set[str] = set()
    seen_display: set[str] = set()
    for entry in catalog.get("categories", []) or []:
        if not isinstance(entry, dict):
            continue
        subdir = entry.get("subdir")
        if isinstance(subdir, str):
            if subdir in seen_subdirs:
                add(
                    issues,
                    "E_SCHEMA160",
                    catalog_path,
                    f"duplicate knowledge category subdir: {subdir}",
                )
            seen_subdirs.add(subdir)
        display = entry.get("display_name")
        if isinstance(display, str):
            if display in seen_display:
                add(
                    issues,
                    "E_SCHEMA161",
                    catalog_path,
                    f"duplicate knowledge category display_name: {display}",
                )
            seen_display.add(display)
    return [str(catalog_path)]


def validate_change_id(value: Any) -> bool:
    return isinstance(value, str) and bool(CHANGE_ID_RE.match(value))


# enums.yaml required enums and their subset relationships. Lightweight code
# validation (no schema) — mirrors validate_knowledge_categories' approach for
# runtime/*.yaml structural checks. The source-of-truth structure is also
# guarded by tests/test_enums_single_source.py.
ENUMS_REQUIRED = {
    "change_status": ("core",),
    "task_status": ("core",),
    "finding_status": ("core",),
    "validation_mapping_status": ("core",),
    "test_mode": ("core",),
}


def validate_enums(claude_root: Path, issues: list[Issue]) -> list[str]:
    enums_path = claude_root / "runtime" / "enums.yaml"
    if not enums_path.exists():
        add(issues, "E_SCHEMA196", enums_path, "enums.yaml not found (lifecycle enum single source)")
        return []
    enums = load_yaml_file(enums_path, issues)
    if not isinstance(enums, dict):
        add(issues, "E_SCHEMA196", enums_path, "enums.yaml root must be a mapping")
        return [str(enums_path)]
    for name, required_subsets in ENUMS_REQUIRED.items():
        entry = enums.get(name)
        if not isinstance(entry, dict):
            add(issues, "E_SCHEMA196", enums_path, f"enums.yaml missing enum {name!r}")
            continue
        for subset in required_subsets:
            values = entry.get(subset)
            if not isinstance(values, list) or not values:
                add(issues, "E_SCHEMA197", enums_path, f"enums.yaml {name}.{subset} must be a non-empty list")
    # Subset relationships (core ⊆ from_set/to_set; closed ⊆ core).
    cs = enums.get("change_status")
    if isinstance(cs, dict):
        core = _enum_values(cs.get("core"))
        from_set = _enum_values(cs.get("from_set"))
        to_set = _enum_values(cs.get("to_set"))
        if core and from_set and not core <= from_set:
            add(issues, "E_SCHEMA198", enums_path, "change_status.core must be a subset of from_set")
        if core and to_set and not core <= to_set:
            add(issues, "E_SCHEMA198", enums_path, "change_status.core must be a subset of to_set")
    vm = enums.get("validation_mapping_status")
    if isinstance(vm, dict):
        core = _enum_values(vm.get("core"))
        closed = _enum_values(vm.get("closed"))
        if core and closed and not closed <= core:
            add(issues, "E_SCHEMA198", enums_path, "validation_mapping_status.closed must be a subset of core")
    return [str(enums_path)]


def _enum_values(value: Any) -> set[str]:
    if not isinstance(value, list):
        return set()
    return {str(v) for v in value}


def validate_spec(path: Path, issues: list[Issue]) -> set[str]:
    text = read(path)
    meta = parse_meta(text)
    if not validate_change_id(meta.get("change_id")):
        add(issues, "E_SCHEMA001", path, "invalid or missing change_id")
    if meta.get("status") not in VALID_CHANGE_STATUS:
        add(issues, "E_SCHEMA002", path, "invalid or missing status")
    for key in ("depends_on", "parallel_safe", "branch", "created", "updated", "complexity"):
        if key not in meta:
            add(issues, "E_SCHEMA003", path, f"missing metadata field {key}")
    depends_on = meta.get("depends_on")
    if depends_on is not None and not isinstance(depends_on, list):
        add(issues, "E_SCHEMA004", path, "depends_on must be a list")
    if "parallel_safe" in meta and not isinstance(meta.get("parallel_safe"), bool):
        add(issues, "E_SCHEMA005", path, "parallel_safe must be boolean")

    mapping_ids: set[str] = set()
    rows = validation_rows(text)
    if not rows:
        add(issues, "E_SCHEMA006", path, "missing validation mapping rows")
    for row in rows:
        if len(row) < 7:
            add(issues, "E_SCHEMA007", path, f"validation row {row[0]} has fewer than 7 columns")
            continue
        vid, level, evidence, status = row[0], row[2], row[3], row[6]
        mapping_ids.add(vid)
        if level not in EVIDENCE_BY_LEVEL:
            add(issues, "E_SCHEMA008", path, f"{vid} has invalid level {level}")
        elif evidence not in EVIDENCE_BY_LEVEL[level]:
            add(issues, "E_SCHEMA009", path, f"{vid} evidence {evidence} does not match {level}")
        if status not in VALID_MAPPING_STATUS:
            add(issues, "E_SCHEMA010", path, f"{vid} has invalid closure status {status}")

    for field in HARD_GATE_FIELDS:
        if f"**{field}**" not in text:
            add(issues, "E_SCHEMA011", path, f"HARD-GATE missing {field}")
    return mapping_ids


def validate_tasks(path: Path, mapping_ids: set[str], issues: list[Issue]) -> None:
    text = read(path)
    meta = parse_meta(text)
    if not validate_change_id(meta.get("change_id")):
        add(issues, "E_SCHEMA012", path, "invalid or missing change_id")
    sections = task_sections(text)
    if not sections:
        add(issues, "E_SCHEMA013", path, "no task sections found")
    for section in sections:
        title = section.splitlines()[0].strip()
        for field in TASK_FIELDS:
            if field not in section:
                add(issues, "E_SCHEMA014", path, f"{title} missing {field}")
        match = re.search(r"\*\*完成后状态\*\*\s*:\s*`?([a-z_]+)`?", section)
        if match and match.group(1) not in VALID_TASK_STATUS:
            add(issues, "E_SCHEMA015", path, f"{title} has invalid task status {match.group(1)}")
    for vid in mapping_ids:
        if vid not in text:
            add(issues, "E_SCHEMA016", path, f"missing validation mapping {vid}")


def validate_review(path: Path, issues: list[Issue]) -> None:
    if not path.exists():
        return
    text = read(path)
    meta = parse_meta(text)
    for key, allowed in VALID_REVIEW_STATUS.items():
        if meta.get(key) not in allowed:
            add(issues, "E_SCHEMA017", path, f"invalid or missing {key}")
    for row in finding_rows(text):
        status = row[4].strip("` ")
        if row[0] != "无" and status not in _FINDING_STATUS:
            add(issues, "E_SCHEMA018", path, f"finding has invalid status {status}")
    accepted_rows = [row for row in finding_rows(text) if len(row) >= 5 and row[4].strip("` ") == "accepted"]
    confirmations = {row[0].strip(): row for row in accepted_confirmation_rows(text) if row[0].strip()}
    for row in accepted_rows:
        description = row[1].strip()
        reason_text = " ".join(row[:4]).strip()
        if len(reason_text) < 20:
            add(issues, "E_SCHEMA186", path, f"accepted finding '{description}' lacks reason")
        confirmation = confirmations.get(description)
        if not confirmation:
            add(issues, "E_SCHEMA187", path, f"accepted finding '{description}' missing accepted confirmation record")
            continue
        if any(not cell.strip() for cell in confirmation[:5]):
            add(issues, "E_SCHEMA188", path, f"accepted finding '{description}' has incomplete confirmation record")


def validate_test_spec(path: Path, issues: list[Issue]) -> None:
    if not path.exists():
        return
    text = read(path)
    meta = parse_meta(text)
    if meta and meta.get("status") not in VALID_CHANGE_STATUS:
        add(issues, "E_SCHEMA019", path, "invalid status")
    for row in table_rows(text):
        if len(row) >= 2 and row[0].replace("`", "") == "cc-test 模式":
            mode = row[1].strip("` ")
            if mode not in VALID_TEST_MODE:
                add(issues, "E_SCHEMA020", path, f"invalid cc-test mode {mode}")
            return
    add(issues, "E_SCHEMA021", path, "missing cc-test mode row")


def discover_change_dirs(inputs: list[Path]) -> list[Path]:
    dirs: set[Path] = set()
    for item in inputs:
        if item.is_file():
            parent = item.parent
            if (parent / "spec.md").exists() and (parent / "tasks.md").exists():
                dirs.add(parent)
            continue
        if (item / "spec.md").exists() and (item / "tasks.md").exists():
            dirs.add(item)
            continue
        if item.is_dir():
            for spec in item.rglob("spec.md"):
                if "templates" in spec.parts:
                    continue
                parent = spec.parent
                if (parent / "tasks.md").exists():
                    dirs.add(parent)
    return sorted(dirs)


def default_input() -> Path:
    cwd = Path.cwd()
    if (cwd / ".cairness" / "changes").exists():
        return cwd / ".cairness" / "changes"
    return Path(__file__).resolve().parent.parent.parent / ".cairness" / "changes"


def build_report(inputs: list[Path]) -> dict[str, Any]:
    issues: list[Issue] = []
    claude_root = Path(__file__).resolve().parent.parent
    checked_runtime, checked_topic_rules = validate_runtime_manifests(claude_root, issues)
    change_dirs = discover_change_dirs(inputs)
    for change_dir in change_dirs:
        mapping_ids = validate_spec(change_dir / "spec.md", issues)
        validate_tasks(change_dir / "tasks.md", mapping_ids, issues)
        validate_review(change_dir / "review.md", issues)
        validate_test_spec(change_dir / "test-spec.md", issues)
    return {
        "tool": "cc-schema-check",
        "status": "failed" if issues else "passed",
        "checked_runtime": checked_runtime,
        "checked_topic_rules": checked_topic_rules,
        "checked_changes": [str(path) for path in change_dirs],
        "issues": issues_to_dicts(issues),
    }


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Check cc_spec Harness document metadata and shape.")
    parser.add_argument("paths", nargs="*", help="Change directories, files, or changes root.")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    args = parser.parse_args(argv)

    inputs = [Path(path) for path in args.paths] if args.paths else [default_input()]
    report = build_report(inputs)
    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    elif report["status"] == "passed":
        print("cc-schema-check: ok")
    else:
        for issue in report["issues"]:
            print(f"{issue['code']} {issue['path']}: {issue['message']}", file=sys.stderr)
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
