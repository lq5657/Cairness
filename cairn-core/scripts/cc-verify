def command_text(command: list[str]) -> str:
    return " ".join(command)


def _find_section_marker(lines: list[str], marker: str) -> int:
    """Find the line index of a <!-- cc-verify-key: ... --> marker."""
    for i, line in enumerate(lines):
        if marker in line:
            return i
    return -1


def check_review_coverage(project_root: Path, change_id: str) -> dict[str, object]:
    """Check that review.md has a complete file_review_scope table."""
    review_path = project_root / ".cairness" / "changes" / change_id / "review.md"
    log_path = project_root / ".cairness" / "changes" / change_id / "log.md"

    if not review_path.exists():
        return {
            "name": "review-coverage",
            "kind": "harness",
            "command": [],
            "cwd": str(project_root),
            "status": "failed",
            "exit_code": 1,
            "duration_ms": 0,
            "stdout": "",
            "stderr": f"{review_path} not found",
            "fingerprints": [f"{review_path} not found"],
            "warnings": [],
        }

    lines = review_path.read_text(encoding="utf-8").splitlines()

    marker_idx = _find_section_marker(lines, "cc-verify-key: file_review_scope")
    if marker_idx < 0:
        return {
            "name": "review-coverage",
            "kind": "harness",
            "command": [],
            "cwd": str(project_root),
            "status": "failed",
            "exit_code": 1,
            "duration_ms": 0,
            "stdout": "",
            "stderr": "file_review_scope section not found in review.md",
            "fingerprints": ["file_review_scope missing"],
            "warnings": [],
        }

    # Skip blank and comment lines between marker and table
    table_start = marker_idx + 1
    while table_start < len(lines) and (not lines[table_start].strip() or lines[table_start].strip().startswith("<!--")):
        table_start += 1
    rows = named_table_rows(lines, table_start)
    if not rows:
        return {
            "name": "review-coverage",
            "kind": "harness",
            "command": [],
            "cwd": str(project_root),
            "status": "failed",
            "exit_code": 1,
            "duration_ms": 0,
            "stdout": "",
            "stderr": "file_review_scope table is empty or unparseable",
            "fingerprints": ["file_review_scope empty"],
            "warnings": [],
        }

    errors: list[str] = []
    warnings_list: list[str] = []

    # Check for not_reviewed without notes
    for row in rows:
        status = row.get("Review Status", row.get("review_status", ""))
        notes = row.get("Notes", row.get("notes", ""))
        filename = row.get("File", row.get("file", "unknown"))

        if status == "not_reviewed" and not notes:
            errors.append(f"{filename}: not_reviewed but no notes explaining why")

        if status == "out_of_scope_flagged" and log_path.exists():
            log_content = log_path.read_text(encoding="utf-8")
            if f"spec_review_flag" not in log_content:
                warnings_list.append(f"{filename}: out_of_scope_flagged but no spec_review_flag found in log.md")

    status = "failed" if errors else "passed"
    return {
        "name": "review-coverage",
        "kind": "harness",
        "command": [],
        "cwd": str(project_root),
        "status": status,
        "exit_code": 1 if errors else 0,
        "duration_ms": 0,
        "stdout": f"files in scope: {len(rows)}" if not errors else "",
        "stderr": "\n".join(errors + warnings_list),
        "fingerprints": errors + warnings_list,
        "warnings": warnings_list,
    }


def check_finding_locations(project_root: Path, change_id: str) -> dict[str, object]:
    """Check that finding existing_code matches actual file content."""
    review_path = project_root / ".cairness" / "changes" / change_id / "review.md"

    if not review_path.exists():
        return {
            "name": "finding-locations",
            "kind": "harness",
            "command": [],
            "cwd": str(project_root),
            "status": "failed",
            "exit_code": 1,
            "duration_ms": 0,
            "stdout": "",
            "stderr": f"{review_path} not found",
            "fingerprints": [f"{review_path} not found"],
            "warnings": [],
        }

    lines = review_path.read_text(encoding="utf-8").splitlines()
    content = "\n".join(lines)

    mismatches: list[str] = []
    warnings_list: list[str] = []
    matched: int = 0
    no_existing_code: int = 0
    important_with_location_no_code: list[str] = []

    # Delegate Finding-detail parsing to the shared parse_findings (blessed
    # `### Finding #N:` header, info-string-aware Existing Code extraction).
    # The old inline parser's _extract_code_block swallowed ```go fences to EOF
    # (closing-fence bug) and special-cased only Go via a `not startswith("```go")`
    # band-aid that left the `**Existing Code**:` path broken.
    for detail in parse_findings(content):
        if not detail.location:
            continue
        # Split path:line-line (preserve the original guard: bare paths skip)
        parts = detail.location.rsplit(":", 1)
        if len(parts) != 2:
            continue
        file_path = parts[0]
        finding_level = detail.level or "unknown"
        code = detail.existing_code

        if not code.strip():
            no_existing_code += 1
            if finding_level in ("Critical", "Important"):
                important_with_location_no_code.append(f"{file_path} ({finding_level}): has Location but no Existing Code")
            continue

        # Normalize code for matching: strip leading/trailing whitespace, normalize indentation
        normalized_code = "\n".join(line.strip() for line in code.strip().splitlines() if line.strip())

        # Try to match against the target file
        target_path = project_root / file_path
        if not target_path.exists():
            mismatches.append(f"{file_path}: target file not found")
            continue

        file_content = target_path.read_text(encoding="utf-8")
        # Try exact match first, then normalized
        if code.strip() in file_content:
            matched += 1
        elif normalized_code and normalized_code in "\n".join(l.strip() for l in file_content.splitlines()):
            matched += 1
        else:
            # Try first meaningful line as fallback
            meaningful_lines = [l for l in code.strip().splitlines() if l.strip() and not l.strip().startswith("//")]
            if meaningful_lines and meaningful_lines[0].strip() in file_content:
                matched += 1
            else:
                first_line = code.strip().split("\n")[0].strip() if code.strip() else ""
                mismatches.append(f"{file_path}:{parts[1]} — existing_code not found in file (first line: {first_line[:80]})")

    status = "failed" if mismatches else "passed"
    stderr_lines = list(mismatches)
    if important_with_location_no_code:
        stderr_lines.append(f"Important/Critical findings with Location but no Existing Code: {len(important_with_location_no_code)}")
        stderr_lines.extend(f"  - {item}" for item in important_with_location_no_code)
    return {
        "name": "finding-locations",
        "kind": "harness",
        "command": [],
        "cwd": str(project_root),
        "status": status,
        "exit_code": 1 if mismatches else 0,
        "duration_ms": 0,
        "stdout": f"locations checked: {matched + len(mismatches) + no_existing_code} (matched: {matched}, no existing_code: {no_existing_code})",
        "stderr": "\n".join(stderr_lines),
        "fingerprints": mismatches + [f"no_existing_code:{item.split(':')[0]}" for item in important_with_location_no_code],
        "warnings": [f"Important/Critical finding lacking Existing Code: {item}" for item in important_with_location_no_code],
    }


def check_risk_triage(project_root: Path, change_id: str) -> dict[str, object]:
    """Check that if risk_triage marker exists, the table is populated."""
    review_path = project_root / ".cairness" / "changes" / change_id / "review.md"

    if not review_path.exists():
        return {
            "name": "risk-triage",
            "kind": "harness",
            "command": [],
            "cwd": str(project_root),
            "status": "skipped",
            "exit_code": 0,
            "duration_ms": 0,
            "stdout": "",
            "stderr": f"{review_path} not found",
            "fingerprints": [],
            "warnings": [],
        }

    lines = review_path.read_text(encoding="utf-8").splitlines()

    marker_idx = _find_section_marker(lines, "cc-verify-key: risk_triage")
    if marker_idx < 0:
        # No risk_triage marker — Agent decided it wasn't needed. OK.
        return {
            "name": "risk-triage",
            "kind": "harness",
            "command": [],
            "cwd": str(project_root),
            "status": "passed",
            "exit_code": 0,
            "duration_ms": 0,
            "stdout": "risk_triage not present (change below threshold or Agent chose to skip)",
            "stderr": "",
            "fingerprints": [],
            "warnings": [],
        }

    # Skip blank/comment lines
    table_start = marker_idx + 1
    while table_start < len(lines) and (not lines[table_start].strip() or lines[table_start].strip().startswith("<!--")):
        table_start += 1

    rows = named_table_rows(lines, table_start)
    if not rows:
        return {
            "name": "risk-triage",
            "kind": "harness",
            "command": [],
            "cwd": str(project_root),
            "status": "failed",
            "exit_code": 1,
            "duration_ms": 0,
            "stdout": "",
            "stderr": "risk_triage marker present but table is empty — risk_triage was indicated but not completed",
            "fingerprints": ["risk_triage table empty"],
            "warnings": [],
        }

    return {
        "name": "risk-triage",
        "kind": "harness",
        "command": [],
        "cwd": str(project_root),
        "status": "passed",
        "exit_code": 0,
        "duration_ms": 0,
        "stdout": f"risk_triage populated with {len(rows)} risk area(s)",
        "stderr": "",
        "fingerprints": [],
        "warnings": [],
    }


def run_step(
    name: str,
    kind: str,
    command: list[str],
    cwd: Path,
    *,
    collect_issues: bool = False,
) -> dict[str, object]:
    """Run a sub-check subprocess and record its result.

    When ``collect_issues`` is True, ``--json`` is appended to the command and
    the child's structured ``issues`` are parsed into the result. This lets
    cc-verify aggregate sub-check findings by code/path/message instead of only
    by truncated stderr text (fingerprints). Scripts that do not emit the
    canonical Issue JSON (cc-sync-check free-text, cc-index-check's level/
    summary schema) keep relying on exit code + fingerprints.
    """
    started = time.time()
    try:
        env = os.environ.copy()
        if kind.startswith("project:golang") and "GOCACHE" not in env:
            env["GOCACHE"] = "/tmp/cc-go-build"
        run_command = [*command, "--json"] if collect_issues else command
        completed = subprocess.run(
            run_command,
            cwd=str(cwd),
            text=True,
            capture_output=True,
            check=False,
            env=env,
        )
        duration_ms = int((time.time() - started) * 1000)
        status = "passed" if completed.returncode == 0 else "failed"
        result = {
            "name": name,
            "kind": kind,
            "command": run_command,
            "cwd": str(cwd),
            "status": status,
            "exit_code": completed.returncode,
            "duration_ms": duration_ms,
            "stdout": completed.stdout,
            "stderr": completed.stderr,
            "fingerprints": fingerprints(completed.stdout, completed.stderr) if completed.returncode else [],
            "warnings": warnings(completed.stdout, completed.stderr),
        }
        if collect_issues:
            result["issues"] = _collect_issues_from_json(completed.stdout)
        result["diagnosis"] = diagnosis_for(name, status, completed.stderr)
        return result
    except FileNotFoundError as exc:
        duration_ms = int((time.time() - started) * 1000)
        message = str(exc)
        return {
            "name": name,
            "kind": kind,
            "command": command,
            "cwd": str(cwd),
            "status": "failed",
            "exit_code": 127,
            "duration_ms": duration_ms,
            "stdout": "",
            "stderr": message,
            "fingerprints": [message],
            "warnings": [],
            "diagnosis": diagnosis_for(name, "failed", message),
        }


def build_report(args: argparse.Namespace, context: HarnessContext | None = None) -> dict[str, object]:
    context = context or load_harness_context(framework_hint=Path(__file__).resolve().parent.parent)
    claude_root = context.framework_root
    project_root = context.project_root
    changes_root = project_root / ".cairness" / "changes"
    target_project_root = (project_root / args.fixture).resolve() if args.fixture else project_root
    config_path = claude_root / "harness.config.yaml"
    try:
        config = load_harness_config(config_path).values
        config_error = ""
    except HarnessConfigError as exc:
        config = {}
        config_error = str(exc)
    change_dir = changes_root / args.change if args.change else None
    changed_paths = git_changed_paths(project_root) if args.changed_only else []
    changed_dirs = changed_change_dirs(changed_paths, project_root) if args.changed_only else []
    harness_changed = has_harness_changes(changed_paths, project_root) if args.changed_only else False
    resolution = (
        resolve_language_profile(
            project_root,
            target_root=target_project_root,
            include_project_state=False,
            framework_root=claude_root,
        )
        if args.fixture
        else resolve_language_profile(project_root, framework_root=claude_root)
    )

    results: list[dict[str, object]] = []
    if config_error:
        results.append(failed_step("harness-config", "harness", config_error, project_root))
    if args.change and change_dir and not change_dir.exists():
        results.append(
            {
                "name": "change-dir",
                "kind": "harness",
                "command": [],
                "cwd": str(project_root),
                "status": "failed",
                "exit_code": 1,
                "duration_ms": 0,
                "stdout": "",
                "stderr": f"{change_dir} not found",
                "fingerprints": [f"{change_dir} not found"],
                "warnings": [],
            }
        )
    if not args.project_only:
        cc_lint = claude_root / "scripts" / "cc-lint"
        cc_sync_check = claude_root / "scripts" / "cc-sync-check"
        cc_readset = claude_root / "scripts" / "cc-readset"
        cc_workflow_gen = claude_root / "scripts" / "cc-workflow-gen"
        cc_doctor_check = claude_root / "scripts" / "cc-doctor-check"
        cc_event_check = claude_root / "scripts" / "cc-event-check"
        cc_behavior_check = claude_root / "scripts" / "cc-behavior-check"
        cc_upgrade_check = claude_root / "scripts" / "cc-upgrade-check"
        cc_schema_check = claude_root / "scripts" / "cc-schema-check"
        cc_role_check = claude_root / "scripts" / "cc-role-check"
        cc_index_check = claude_root / "scripts" / "cc-index-check"
        cc_deps = claude_root / "scripts" / "cc-deps"
        cc_spec_scope_check = claude_root / "scripts" / "cc-spec-scope-check"
        cc_subagent_evidence_check = claude_root / "scripts" / "cc-subagent-evidence-check"
        cc_wave_plan = claude_root / "scripts" / "cc-wave-plan"
        knowledge_index_path = project_root / ".cairness" / "knowledge" / "index.md"
        sync_target = change_dir if change_dir and change_dir.exists() else changes_root
        if args.changed_only:
            if not harness_changed and not changed_dirs:
                results.append(skipped_step("changed-only", "harness", "no changed Harness or change files detected"))
            lint_targets = [str(claude_root)] if harness_changed else []
            lint_targets.extend(str(path) for path in changed_dirs)
            if lint_targets:
                results.append(run_step("cc-lint", "harness", [str(cc_lint), *lint_targets], project_root, collect_issues=True))
            if changed_dirs:
                changed_dir_args = [str(path) for path in changed_dirs]
                results.append(run_step("cc-sync-check", "harness", [str(cc_sync_check), *changed_dir_args], project_root, collect_issues=True))
                results.append(run_step("cc-event-check", "harness", [str(cc_event_check), *changed_dir_args], project_root, collect_issues=True))
                results.append(run_step("cc-schema-check", "harness", [str(cc_schema_check), *changed_dir_args], project_root, collect_issues=True))
                results.append(run_step("cc-spec-scope-check", "harness", [str(cc_spec_scope_check), *changed_dir_args], project_root, collect_issues=True))
                results.append(run_step("cc-subagent-evidence-check", "harness", [str(cc_subagent_evidence_check), *changed_dir_args], project_root, collect_issues=True))
            if harness_changed:
                results.append(run_step("cc-readset", "harness", [str(cc_readset), "--check"], project_root, collect_issues=True))
                results.append(run_step("cc-workflow-gen", "harness", [str(cc_workflow_gen), "--check"], project_root, collect_issues=True))
                results.append(run_step("cc-doctor-check", "harness", [str(cc_doctor_check)], project_root, collect_issues=True))
                if os.environ.get("CC_BEHAVIOR_REPLAY") != "1":
                    results.append(run_step("cc-behavior-check", "harness", [str(cc_behavior_check)], project_root, collect_issues=True))
                results.append(run_step("cc-upgrade-check", "harness", [str(cc_upgrade_check)], project_root, collect_issues=True))
                results.append(run_step("cc-schema-check", "harness", [str(cc_schema_check), str(sync_target)], project_root, collect_issues=True))
                if knowledge_index_path.is_file():
                    results.append(run_step("cc-index-check", "harness", [str(cc_index_check)], project_root, collect_issues=True))
            results.append(run_step("cc-deps-orphans", "harness", [str(cc_deps), "orphans"], project_root, collect_issues=True))
        else:
            lint_targets = [str(claude_root)]
            if sync_target.exists():
                lint_targets.append(str(sync_target))
            results.append(run_step("cc-lint", "harness", [str(cc_lint), *lint_targets], project_root, collect_issues=True))
            results.append(run_step("cc-sync-check", "harness", [str(cc_sync_check), str(sync_target)], project_root, collect_issues=True))
            results.append(run_step("cc-spec-scope-check", "harness", [str(cc_spec_scope_check), str(sync_target)], project_root, collect_issues=True))
            results.append(run_step("cc-subagent-evidence-check", "harness", [str(cc_subagent_evidence_check), str(sync_target)], project_root, collect_issues=True))
            results.append(run_step("cc-readset", "harness", [str(cc_readset), "--check"], project_root, collect_issues=True))
            results.append(run_step("cc-workflow-gen", "harness", [str(cc_workflow_gen), "--check"], project_root, collect_issues=True))
            results.append(run_step("cc-doctor-check", "harness", [str(cc_doctor_check)], project_root, collect_issues=True))
            results.append(run_step("cc-event-check", "harness", [str(cc_event_check), str(sync_target)], project_root, collect_issues=True))
            if os.environ.get("CC_BEHAVIOR_REPLAY") != "1":
                results.append(run_step("cc-behavior-check", "harness", [str(cc_behavior_check)], project_root, collect_issues=True))
            results.append(run_step("cc-upgrade-check", "harness", [str(cc_upgrade_check)], project_root, collect_issues=True))
            results.append(run_step("cc-schema-check", "harness", [str(cc_schema_check), str(sync_target)], project_root, collect_issues=True))
            if knowledge_index_path.is_file():
                results.append(run_step("cc-index-check", "harness", [str(cc_index_check)], project_root, collect_issues=True))
            results.append(run_step("cc-deps-orphans", "harness", [str(cc_deps), "orphans"], project_root, collect_issues=True))
        if args.command:
            command = [str(cc_role_check), "--command", args.command]
            if args.change:
                command.extend(["--change", args.change])
            results.append(run_step("cc-role-check", "harness", command, project_root))

        if args.check_review_coverage and args.change and change_dir and change_dir.exists():
            results.append(check_review_coverage(project_root, args.change))

        if args.check_finding_locations and args.change and change_dir and change_dir.exists():
            results.append(check_finding_locations(project_root, args.change))

        if args.check_risk_triage and args.change and change_dir and change_dir.exists():
            results.append(check_risk_triage(project_root, args.change))

        if args.check_wave_plan and args.change and change_dir and change_dir.exists():
            results.append(run_step("cc-wave-plan-check", "project", [str(cc_wave_plan), "--check", "--change", args.change], project_root, collect_issues=True))

    run_project_checks = not args.harness_only
    if args.changed_only and not args.fixture and not args.project_only:
        run_project_checks = resolution.status == "resolved" and resolution.profile is not None and has_profile_changes(changed_paths, project_root, resolution.profile)
    if run_project_checks:
        if args.fixture and not target_project_root.exists():
            results.append(
                failed_step(
                    "project checks",
                    "project",
                    f"explicit fixture {args.fixture} is invalid: {target_project_root} not found",
                    target_project_root,
                )
            )
        elif resolution.status != "resolved" or resolution.profile is None:
            reason = resolution_error_message(resolution.status, resolution.errors)
            if args.fixture:
                results.append(
                    failed_step(
                        "project checks",
                        "project",
                        f"explicit fixture {args.fixture} is invalid: {reason}",
                        target_project_root,
                    )
                )
            else:
                results.append(skipped_step("project checks", "project", f"language profile unresolved: {reason}"))
        else:
            profile = resolution.profile
            entries = verification_entries(profile)
            if not entries:
                results.append(skipped_step("project checks", capability_kind(profile, "none"), f"{profile.name} profile declares no verification capabilities"))
            for capability, entry in entries:
                enabled = capability_enabled(config, profile, capability, default=entry.get("optional") is not True)
                if not enabled:
                    continue
                fallback = default_verification_command(profile, capability)
                command = profile_command(profile.data, capability, fallback)
                if not command:
                    results.append(skipped_step(capability, capability_kind(profile, capability), f"{profile.name} profile has no command for {capability}"))
                    continue
                name = capability_display_name(command, capability)
                if shutil.which(command[0]) is None:
                    missing_tool = f"{command[0]} not found"
                    if entry.get("optional") is True:
                        results.append(skipped_step(name, capability_kind(profile, capability), missing_tool))
                    else:
                        results.append(blocked_step(name, capability_kind(profile, capability), missing_tool, target_project_root))
                    continue
                results.append(run_step(name, capability_kind(profile, capability), command, target_project_root))

    failed = [result for result in results if result["status"] == "failed"]
    blocked = [result for result in results if result["status"] == "blocked"]
    report = {
        "schema_version": 1,
        "tool": "cc-verify",
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "project_root": str(project_root),
        "claude_root": str(claude_root),
        "change_id": args.change or "",
        "fixture": args.fixture or "",
        "command": args.command or "",
        "mode": "changed-only" if args.changed_only else "harness-only" if args.harness_only else "project-only" if args.project_only else "full",
        "language_profile": resolution.profile_name,
        "language_profile_source": resolution.source,
        "changed_files": [str(path) for path in changed_paths],
        "status": "failed" if failed else "blocked" if blocked else "passed",
        "results": results,
    }
    return report


def print_text(report: dict[str, object], verbose: bool) -> None:
    print(f"cc-verify: {report['status']} ({report['mode']})")
    for result in report["results"]:
        status = str(result["status"]).upper()
        command = command_text(result["command"]) if result["command"] else str(result["stderr"])
        print(f"{status:7} {result['name']}: {command}")
        if verbose or result["status"] in {"failed", "blocked"}:
            stdout = str(result["stdout"]).strip()
            stderr = str(result["stderr"]).strip()
            if stdout:
                print(stdout)
            if stderr:
                print(stderr, file=sys.stderr)
            diagnosis = result.get("diagnosis")
            if isinstance(diagnosis, dict) and diagnosis:
                cause = diagnosis.get("cause", "")
                fix_hint = diagnosis.get("fix_hint", "")
                doc_ref = diagnosis.get("doc_ref", "")
                if cause:
                    print(f"cause: {cause}")
                if fix_hint:
                    print(f"fix_hint: {fix_hint}")
                if doc_ref:
                    print(f"doc_ref: {doc_ref}")


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Run Harness verification checks.")
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--harness-only", action="store_true", help="Only run Harness document checks.")
    mode.add_argument("--project-only", dest="project_only", action="store_true", help="Only run project language verification checks.")
    mode.add_argument("--go-only", dest="project_only", action="store_true", help="Legacy alias for --project-only.")
    parser.add_argument("--change", help="Limit sync checks and report metadata to one change-id.")
    parser.add_argument("--fixture", help="Run project verification checks from a fixture path relative to the project root.")
    parser.add_argument("--command", help="Run role/write-scope checks for a cc-* command.")
    parser.add_argument("--changed-only", action="store_true", help="Run the smallest deterministic check set for changed files.")
    parser.add_argument("--check-review-coverage", action="store_true", help="Validate file_review_scope completeness in review.md.")
    parser.add_argument("--check-finding-locations", action="store_true", help="Validate finding existing_code matches actual file content.")
    parser.add_argument("--check-risk-triage", action="store_true", help="Validate risk_triage table is populated when present in review.md.")
    parser.add_argument("--check-wave-plan", action="store_true", help="Validate wave-plan.json consistency with tasks.md declaration (E_WAVE003).")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    parser.add_argument("--output", help="Write JSON report to this file.")
    parser.add_argument("--verbose", action="store_true", help="Show command output for passing steps.")
    parser.add_argument("--root", help="Explicit Cairness project root; overrides automatic discovery.")
    args = parser.parse_args(argv)

    try:
        context = load_harness_context(
            explicit_root=Path(args.root) if args.root else None,
            framework_hint=None if args.root else Path(__file__).resolve().parent.parent,
        )
    except HarnessContextError as exc:
        print(f"E_CONTEXT001 {exc}", file=sys.stderr)
        return 2
    report = build_report(args, context)
    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(json.dumps(report, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    if args.json and not args.output:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        print_text(report, args.verbose)
        if args.output:
            print(f"report: {args.output}")
    return 1 if report["status"] in {"failed", "blocked"} else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
