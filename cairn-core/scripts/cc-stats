#!/usr/bin/env python3
"""cc-stats — 项目可观测性统计。

从 events.jsonl 和 review.md 中提取遥测数据，输出：
  - 命令使用分布
  - 验证门禁通过率
  - Finding 趋势（按严重程度、lens、状态、根因聚类）
  - Token 消耗趋势
  - 子 agent 调度统计

用法:
  cc-stats                    默认输出可读摘要
  cc-stats --findings         仅输出 finding 统计
  cc-stats --root-causes      根因聚类与改进建议
  cc-stats --trend            输出时间趋势
  cc-stats --json             JSON 格式输出
"""

from __future__ import annotations

import argparse
import json
import re
import sys
from collections import Counter, defaultdict
from pathlib import Path
from typing import Any

from harness_runtime.enums import enum_set, load_enums as _load_enums
from harness_runtime.context import HarnessContextError, load_harness_context
from harness_runtime.observability import (
    command_metrics,
    collection_summary,
    discover_runtime_events,
    execution_metrics,
    phase_metrics,
    upgrade_metrics,
    verification_metrics,
)

from change_docs import parse_findings


CHANGE_ID_RE = re.compile(r"^[a-z0-9]+(-[a-z0-9]+)*$")
COMMAND_RE = re.compile(r"^cc-[a-z0-9-]+$")
_FINDING_STATUS = enum_set(_load_enums(), "finding_status", "core")
_FINDING_STATUS_PATTERN = "|".join(sorted(_FINDING_STATUS, key=len, reverse=True))

ROOT_CAUSE_SUGGESTIONS: dict[str, str] = {
    "missing_error_handling": "建议在 code review checklist 中增加错误处理检查项，或引入 errcheck/linter 规则",
    "missing_validation": "建议引入输入校验层（middleware/decorator），统一参数校验逻辑",
    "missing_test": "建议在 cc-propose 阶段提高最低测试覆盖率要求，或增加 task-level test_requirement",
    "incorrect_state_transition": "建议引入集中式状态机校验，禁止直接赋值 status 字段",
    "incorrect_amount_type": "建议在 code review 中增加金额类型检查（int64/分），或引入 domain-rules lint",
    "incorrect_time_type": "建议统一使用 time.Time 类型，在 code review 中检查时间戳裸用",
    "missing_timeout": "建议在 harness.config.yaml 中开启默认超时检查，或引入 context.WithTimeout lint",
    "missing_auth_check": "建议将 auth middleware 纳入 cc-propose security lens 默认检查项",
    "race_condition": "建议在 CI 中开启 race detector，或对共享状态访问增加 review lens",
    "api_contract_break": "建议在 cc-review 中强制 api-compatibility topic rule，或在 CI 中增加契约测试",
    "database_schema_mismatch": "建议在 cc-apply 的 database topic rule 中增加 schema diff 检查",
    "config_drift": "建议将配置项变更纳入 cc-propose configuration lens，强制环境差异检查",
    "observability_gap": "建议在 cc-propose 中为每个 change 要求日志/metrics 计划",
    "security_vulnerability": "建议在 cc-review 中启用 security lens 作为默认（非条件触发）",
    "performance_regression": "建议在 CI 中增加 benchmark 对比，或对关键路径增加性能断言",
    "spec_implementation_gap": "建议加强 cc-review stage1 spec compliance 检查深度",
    "dependency_order_error": "建议在 cc-propose 中强制运行 cc-deps check，验证 depends_on 和 parallel_safe",
    "other": "建议在 cc-fix 中细化 root_cause_tag 分类，避免使用 other 标签",
}


def project_root() -> Path:
    return load_harness_context(
        framework_hint=Path(__file__).resolve().parent.parent,
    ).project_root


def read_jsonl(path: Path) -> list[dict[str, Any]]:
    events: list[dict[str, Any]] = []
    if not path.exists():
        return events
    for line in path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            events.append(json.loads(line))
        except json.JSONDecodeError:
            continue
    return events


def discover_events(project_root: Path) -> list[dict[str, Any]]:
    events: list[dict[str, Any]] = []
    changes_dir = project_root / ".cairness" / "changes"
    if not changes_dir.exists():
        return events
    for event_file in sorted(changes_dir.rglob("events.jsonl")):
        if ".claude" in event_file.parts:
            continue
        events.extend(read_jsonl(event_file))
    return events


def discover_reviews(project_root: Path) -> list[dict[str, Any]]:
    """从 review.md 中提取 finding 统计。"""
    reviews: list[dict[str, Any]] = []
    changes_dir = project_root / ".cairness" / "changes"
    if not changes_dir.exists():
        return reviews
    for review_file in sorted(changes_dir.rglob("review.md")):
        if ".claude" in review_file.parts:
            continue
        review = parse_review(review_file)
        if review:
            reviews.append(review)
    return reviews


def parse_review(path: Path) -> dict[str, Any] | None:
    """从 review.md 提取结构化 finding 数据。"""
    content = path.read_text(encoding="utf-8")
    change_id = path.parent.name
    result: dict[str, Any] = {
        "change_id": change_id,
        "findings": [],
        "stage1_status": "unknown",
        "stage2_status": "unknown",
        "final_status": "unknown",
    }
    # Extract YAML frontmatter
    m = re.search(r'^---\s*\n(.*?)\n---', content, re.DOTALL)
    if m:
        try:
            import yaml
            fm = yaml.safe_load(m.group(1))
            if isinstance(fm, dict):
                result["stage1_status"] = fm.get("stage1_status", "unknown")
                result["stage2_status"] = fm.get("stage2_status", "unknown")
                result["final_status"] = fm.get("final_status", "unknown")
        except Exception:
            pass
    # Findings: delegate to the shared parse_findings (blessed `### Finding #N:`
    # header). The old `### F\d+` header matched no template/doc/test and
    # returned 0 findings on review.md written per the template.
    for detail in parse_findings(content):
        sev = detail.level.lower()
        if sev not in {"critical", "important", "minor", "cosmetic"}:
            sev = "unknown"
        status = detail.status if detail.status in _FINDING_STATUS else "open"
        result["findings"].append({
            "id": f"F{detail.number}",
            "severity": sev,
            "status": status,
            "lens": detail.detected_by_gate or "unknown",
            "root_cause_tag": detail.root_cause_tag,
        })
    return result


def compute_stats(
    events: list[dict[str, Any]],
    reviews: list[dict[str, Any]],
    runtime_events: list[dict[str, Any]] | None = None,
) -> dict[str, Any]:
    # Command usage
    cmd_counts: Counter = Counter()
    verification_results: Counter = Counter()
    total_duration_ms = 0
    total_tokens = 0
    total_subagents = 0
    total_files = 0
    events_with_telemetry = 0
    events_by_date: dict[str, list[dict[str, Any]]] = defaultdict(list)

    for e in events:
        cmd = e.get("command", "unknown")
        if isinstance(cmd, str) and COMMAND_RE.match(cmd):
            cmd_counts[cmd] += 1

        vs = e.get("verification_status")
        if isinstance(vs, str):
            verification_results[vs] += 1

        d = e.get("duration_ms")
        t = e.get("token_count")
        s = e.get("subagent_count")
        f = e.get("files_changed")
        if isinstance(d, (int, float)) and isinstance(t, (int, float)) and d >= 0:
            total_duration_ms += int(d)
            total_tokens += int(t)
            total_subagents += int(s) if isinstance(s, (int, float)) else 0
            total_files += int(f) if isinstance(f, (int, float)) else 0
            events_with_telemetry += 1

        occurred = e.get("occurred_at", "")
        if isinstance(occurred, str) and occurred:
            date_key = occurred[:10]  # YYYY-MM-DD
            events_by_date[date_key].append(e)

    # Finding stats
    all_findings: list[dict[str, Any]] = []
    for r in reviews:
        all_findings.extend(r["findings"])
    finding_severity: Counter = Counter(f["severity"] for f in all_findings)
    finding_status: Counter = Counter(f["status"] for f in all_findings)
    finding_lens: Counter = Counter(f["lens"] for f in all_findings)

    # Time trend
    date_cmd_trend = {d: dict(Counter(e.get("command") for e in el)) for d, el in sorted(events_by_date.items())}

    # Root cause clustering
    root_cause_counter: Counter = Counter()
    root_cause_gates: dict[str, set[str]] = defaultdict(set)
    root_cause_changes: dict[str, set[str]] = defaultdict(set)
    for f in all_findings:
        rc = f.get("root_cause_tag")
        if rc:
            root_cause_counter[rc] += 1
            gate = f.get("lens", "unknown")
            root_cause_gates[rc].add(gate)
            root_cause_changes[rc].add(f.get("id", ""))
    root_causes_sorted = [
        {
            "tag": tag,
            "count": count,
            "associated_gates": sorted(root_cause_gates.get(tag, set())),
            "suggestion": ROOT_CAUSE_SUGGESTIONS.get(tag, ""),
        }
        for tag, count in root_cause_counter.most_common()
    ]

    runtime_events = runtime_events or []
    return {
        "total_events": len(events),
        "total_changes_with_reviews": len(reviews),
        "command_counts": dict(cmd_counts.most_common()),
        "verification_results": dict(verification_results),
        "telemetry": {
            "events_with_telemetry": events_with_telemetry,
            "total_duration_ms": total_duration_ms,
            "total_tokens": total_tokens,
            "total_subagents": total_subagents,
            "total_files_changed": total_files,
            "avg_duration_ms": total_duration_ms // events_with_telemetry if events_with_telemetry else 0,
            "avg_tokens_per_event": total_tokens // events_with_telemetry if events_with_telemetry else 0,
        },
        "findings": {
            "total": len(all_findings),
            "by_severity": dict(finding_severity),
            "by_status": dict(finding_status),
            "by_lens": dict(finding_lens),
            "root_causes": root_causes_sorted,
        },
        "trends": {
            "by_date": date_cmd_trend,
        },
        "collection": collection_summary(events, runtime_events),
        "commands": command_metrics(events),
        "verification": verification_metrics(runtime_events),
        "verification_efficiency": verification_metrics(runtime_events, extended=True),
        "verification_quality": verification_metrics(runtime_events, extended=True).get("quality_gate", {}),
        "phases": phase_metrics([*events, *runtime_events]),
        "execution": execution_metrics(runtime_events),
        "upgrade": upgrade_metrics(runtime_events),
    }


def print_root_causes(stats: dict[str, Any]) -> None:
    """打印根因聚类与改进建议。"""
    print("=== Finding 根因聚类与改进建议 ===\n")
    root_causes = stats["findings"].get("root_causes", [])
    if not root_causes:
        print("  (无数据 — 需要 cc-fix 记录 root_cause_tag)")
        return

    total = sum(rc["count"] for rc in root_causes)
    print(f"  根因标签总数: {len(root_causes)} 种, 覆盖 {total} 个 finding\n")

    for rc in root_causes:
        pct = rc["count"] * 100 // total if total else 0
        bar = "█" * min(rc["count"], 30)
        gates_str = ", ".join(rc["associated_gates"]) if rc["associated_gates"] else "未标记"
        print(f"  ▸ {rc['tag']}")
        print(f"    出现 {rc['count']} 次 ({pct}%)  {bar}")
        print(f"    关联门禁: {gates_str}")
        if rc["suggestion"]:
            print(f"    💡 {rc['suggestion']}")
        print()

    # Top systemic weakness
    if root_causes:
        top = root_causes[0]
        if top["count"] >= 3:
            print("  ── 系统性弱项 ──\n")
            print(f"  最频繁根因: {top['tag']} ({top['count']} 次)")
            print(f"  建议优先处理: {top['suggestion']}")
            # Find second distinct weakness
            if len(root_causes) >= 2:
                second = root_causes[1]
                print(f"  次频繁根因: {second['tag']} ({second['count']} 次)")


def print_readable(stats: dict[str, Any]) -> None:
    print("=== cc_spec 项目可观测性报告 ===\n")

    collection = stats["collection"]
    commands = stats["commands"]
    verification = stats["verification"]
    upgrade = stats["upgrade"]
    quality = stats.get("verification_quality", {})
    pass_rate = quality.get("pass_rate")
    average_duration = verification["average_duration_ms"]
    pass_rate_label = f"{pass_rate:.1%}" if pass_rate is not None else "无样本"
    duration_label = f"{average_duration} ms" if average_duration is not None else "无样本"
    failure_rate = upgrade["failure_rate"]
    failure_rate_label = f"{failure_rate:.1%}" if failure_rate is not None else "无样本"
    upgrade_duration = upgrade["average_duration_ms"]
    upgrade_duration_label = (
        f"{upgrade_duration} ms" if upgrade_duration is not None else "无样本"
    )
    blocking_rate = commands["blocking_rate"]
    blocking_rate_label = (
        f"{blocking_rate:.1%}" if blocking_rate is not None else "无样本"
    )
    result_status_coverage = commands["result_status_coverage"]
    result_status_coverage_label = (
        f"{result_status_coverage:.1%}"
        if result_status_coverage is not None
        else "无样本"
    )
    print(
        "── 采集完整度 ──\n"
        f"  采集完整度: {collection['status']}\n"
        f"  自动 verification runs: {collection['automatic_verification_runs']}\n"
        f"  自动 upgrade runs: {collection['automatic_upgrade_runs']}\n"
        f"  Lifecycle events: {collection['lifecycle_events']}\n"
        f"  命令结果状态覆盖率: {result_status_coverage_label}\n"
        f"  命令阻塞率: {blocking_rate_label}\n"
        f"  自动验证通过率: {pass_rate_label}\n"
        f"  质量门禁通过率（终态样本）: {pass_rate_label}\n"
        f"  原始 verification 事件通过率: {verification.get('pass_rate') if verification.get('pass_rate') is not None else '无样本'}\n"
        f"  自动验证平均耗时: {duration_label}\n"
        f"  升级失败率: {failure_rate_label}\n"
        f"  升级平均耗时: {upgrade_duration_label}\n"
    )

    print("── 命令使用分布 ──")
    for cmd, count in sorted(stats["command_counts"].items()):
        bar = "█" * min(count, 40)
        print(f"  {cmd:<22} {count:>4}  {bar}")

    print("\n── 验证门禁通过率 ──")
    vr = stats["verification_results"]
    total = sum(vr.values())
    if total:
        for status, count in sorted(vr.items()):
            pct = count * 100 // total
            print(f"  {status:<10} {count:>4}  ({pct}%)")

    t = stats["telemetry"]
    print("\n── Token 与性能 ──")
    print(f"  有遥测数据的事件数: {t['events_with_telemetry']}")
    if t["events_with_telemetry"]:
        print(f"  总 token 消耗:       {t['total_tokens']:,}")
        print(f"  总耗时:              {t['total_duration_ms'] / 1000:.1f}s")
        print(f"  平均 token/事件:     {t['avg_tokens_per_event']:,}")
        print(f"  平均耗时/事件:       {t['avg_duration_ms'] / 1000:.1f}s")
        print(f"  总调度子 agent:      {t['total_subagents']}")
        print(f"  总修改文件数:        {t['total_files_changed']}")

    execution = stats.get("execution", {})
    print("\n── 执行成本遥测 ──")
    print(f"  execution runs:      {execution.get('total_runs', 0)}")
    for name, metric in sorted(execution.get("metrics", {}).items()):
        print(
            f"  {name:<20} median={metric['median']} p95={metric['p95']} "
            f"n={metric['count']}"
        )

    f = stats["findings"]
    print("\n── Finding 统计 ──")
    print(f"  总 findings: {f['total']}")
    if f["by_severity"]:
        print(f"  按严重程度: {f['by_severity']}")
    if f["by_status"]:
        print(f"  按状态:     {f['by_status']}")
    if f["by_lens"]:
        print(f"  按审查维度: {f['by_lens']}")

    print("\n── 每日命令趋势 ──")
    for date, cmds in sorted(stats["trends"]["by_date"].items()):
        summary = " ".join(f"{c}x{n}" for c, n in sorted(cmds.items()))
        print(f"  {date}:  {summary}")

    print()
    print_root_causes(stats)


def main() -> None:
    parser = argparse.ArgumentParser(description="Harness observability statistics")
    parser.add_argument("--json", action="store_true", help="JSON 格式输出")
    parser.add_argument("--findings", action="store_true", help="仅输出 finding 统计")
    parser.add_argument("--root-causes", action="store_true", help="根因聚类与改进建议")
    parser.add_argument("--trend", action="store_true", help="输出时间趋势")
    parser.add_argument("--root", help="显式 Cairness 项目根目录；默认自动发现")
    args = parser.parse_args()

    try:
        context = load_harness_context(
            explicit_root=Path(args.root) if args.root else None,
            framework_hint=None if args.root else Path(__file__).resolve().parent.parent,
        )
    except HarnessContextError as exc:
        print(f"E_CONTEXT001 {exc}", file=sys.stderr)
        sys.exit(2)
    root = context.project_root
    events = discover_events(root)
    reviews = discover_reviews(root)
    stats = compute_stats(events, reviews, discover_runtime_events(root))

    if args.json:
        if args.findings:
            print(json.dumps(stats["findings"], indent=2, ensure_ascii=False))
        elif args.root_causes:
            print(json.dumps(stats["findings"]["root_causes"], indent=2, ensure_ascii=False))
        elif args.trend:
            print(json.dumps(stats["trends"], indent=2, ensure_ascii=False))
        else:
            print(json.dumps({"project_root": str(root), **stats}, indent=2, ensure_ascii=False))
    else:
        if args.findings:
            f = stats["findings"]
            print("=== Finding 统计 ===")
            print(f"总 findings: {f['total']}")
            print(f"按严重程度: {f['by_severity']}")
            print(f"按状态: {f['by_status']}")
            print(f"按审查维度: {f['by_lens']}")
        elif args.root_causes:
            print_root_causes(stats)
        elif args.trend:
            print("=== 每日命令趋势 ===")
            for date, cmds in sorted(stats["trends"]["by_date"].items()):
                summary = " ".join(f"{c}x{n}" for c, n in sorted(cmds.items()))
                print(f"{date}: {summary}")
        else:
            print_readable(stats)


if __name__ == "__main__":
    main()
