{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/command-protocol.schema.json",
  "title": "Agent Command Protocol",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "protocol_id",
    "summary",
    "command_flow",
    "path_roles",
    "input_contracts",
    "error_taxonomy",
    "result_rendering",
    "technology_decisions",
    "language_profile"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "protocol_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "command_flow": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/snakeId"
      }
    },
    "path_roles": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/snakeId"
      },
      "additionalProperties": {
        "$ref": "#/$defs/pathRole"
      }
    },
    "input_contracts": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/snakeId"
      },
      "additionalProperties": {
        "$ref": "#/$defs/inputContract"
      }
    },
    "error_taxonomy": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/snakeId"
      },
      "additionalProperties": {
        "$ref": "#/$defs/errorContract"
      }
    },
    "result_rendering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success_template", "error_template"],
      "properties": {
        "success_template": {
          "type": "string",
          "pattern": "^\\.claude/templates/results/.+\\.md$"
        },
        "error_template": {
          "type": "string",
          "pattern": "^\\.claude/templates/results/.+\\.md$"
        }
      }
    },
    "lifecycle_events": {
      "type": "object",
      "additionalProperties": false,
      "required": ["change_event_log", "schema", "template"],
      "properties": {
        "change_event_log": {
          "type": "string",
          "pattern": "^\\.cairness/changes/<change-id>/events\\.jsonl$"
        },
        "schema": {
          "type": "string",
          "pattern": "^\\.claude/schemas/command-event\\.schema\\.json$"
        },
        "template": {
          "type": "string",
          "pattern": "^\\.claude/templates/changes/events\\.jsonl$"
        }
      }
    },
    "technology_decisions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog_schema",
        "applies_to_commands",
        "selection_rules",
        "project_outputs",
        "change_outputs",
        "blocking_error"
      ],
      "properties": {
        "catalog_schema": {
          "type": "string",
          "pattern": "^\\.claude/schemas/technology-decision-catalog\\.schema\\.json$"
        },
        "applies_to_commands": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^cc-[a-z0-9]+(-[a-z0-9]+)*$"
          }
        },
        "selection_rules": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/snakeId"
          }
        },
        "project_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/statePath"
          }
        },
        "change_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/statePath"
          }
        },
        "blocking_error": {
          "$ref": "#/$defs/snakeId"
        }
      }
    },
    "language_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default", "schema", "resolution", "profiles"],
      "properties": {
        "default": {
          "$ref": "#/$defs/snakeId"
        },
        "schema": {
          "type": "string",
          "pattern": "^\\.claude/schemas/language-profile\\.schema\\.json$"
        },
        "resolution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "order",
            "project_state_paths",
            "new_project_requires_confirmation",
            "ambiguous_error",
            "unsupported_error",
            "selection_outputs"
          ],
          "properties": {
            "order": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["project_state", "repository_detection", "user_confirmation", "default_if_single_profile"]
              }
            },
            "project_state_paths": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/statePath"
              }
            },
            "new_project_requires_confirmation": {
              "type": "boolean"
            },
            "ambiguous_error": {
              "$ref": "#/$defs/snakeId"
            },
            "unsupported_error": {
              "$ref": "#/$defs/snakeId"
            },
            "selection_outputs": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/statePath"
              }
            }
          }
        },
        "profiles": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/snakeId"
          },
          "additionalProperties": {
            "type": "string",
            "pattern": "^\\.claude/runtime/languages/[a-z0-9_-]+\\.yaml$"
          }
        }
      }
    }
  },
  "$defs": {
    "snakeId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "pathRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["file", "dir"]
        }
      }
    },
    "statePath": {
      "type": "string",
      "pattern": "^\\.cairness/.+$"
    },
    "inputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "missing_error", "invalid_error"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "enum"]
        },
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "resolves_to": {
          "$ref": "#/$defs/snakeId"
        },
        "missing_error": {
          "$ref": "#/$defs/snakeId"
        },
        "invalid_error": {
          "$ref": "#/$defs/snakeId"
        }
      }
    },
    "errorContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "blocking"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "blocked", "partial"]
        },
        "blocking": {
          "type": "boolean"
        },
        "error_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^E_[A-Z]+[0-9]+$"
          }
        }
      }
    }
  }
}
