#!/usr/bin/env python3
"""Replay lightweight Harness behavior eval cases."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any

from harness_runtime.issues import Issue, issues_to_dicts
from harness_runtime.context import HarnessContext, HarnessContextError, load_harness_context


def read(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def load_yaml(path: Path, issues: list[Issue]) -> Any:
    try:
        import yaml  # type: ignore
    except Exception as exc:
        issues.append(Issue("E_BEHAVIOR001", str(path), f"PyYAML is required: {exc}"))
        return None
    try:
        return yaml.safe_load(read(path))
    except Exception as exc:
        issues.append(Issue("E_BEHAVIOR002", str(path), f"invalid YAML: {exc}"))
        return None


def discover_cases(project_root: Path, inputs: list[Path], context: HarnessContext | None = None) -> list[Path]:
    if inputs:
        candidates = inputs
    else:
        candidates = [
            context.resolve_path(".claude/evals/behavior")
            if context is not None
            else project_root / ".claude" / "evals" / "behavior"
        ]
    cases: set[Path] = set()
    for item in candidates:
        if item.is_file() and item.suffix in {".yaml", ".yml"}:
            cases.add(item)
        elif item.is_dir():
            cases.update(sorted(item.glob("*.yaml")))
            cases.update(sorted(item.glob("*.yml")))
    return sorted(cases)


def validate_case_shape(path: Path, case: Any, issues: list[Issue]) -> dict[str, Any] | None:
    if not isinstance(case, dict):
        issues.append(Issue("E_BEHAVIOR003", str(path), "case root must be a mapping"))
        return None
    required = {"id", "command", "expect_exit_code", "expect_output_contains"}
    missing = sorted(required - set(case))
    if missing:
        issues.append(Issue("E_BEHAVIOR004", str(path), f"missing {missing}"))
        return None
    command = case.get("command")
    if not isinstance(command, list) or not command or not all(isinstance(item, str) and item for item in command):
        issues.append(Issue("E_BEHAVIOR005", str(path), "command must be a non-empty string list"))
        return None
    if not isinstance(case.get("expect_exit_code"), int):
        issues.append(Issue("E_BEHAVIOR006", str(path), "expect_exit_code must be an integer"))
        return None
    expected_output = case.get("expect_output_contains")
    if not isinstance(expected_output, list) or not expected_output or not all(isinstance(item, str) and item for item in expected_output):
        issues.append(Issue("E_BEHAVIOR007", str(path), "expect_output_contains must be a non-empty string list"))
        return None
    return case


def run_case(
    path: Path,
    case: dict[str, Any],
    project_root: Path,
    issues: list[Issue],
    context: HarnessContext | None = None,
) -> None:
    env = os.environ.copy()
    env["CC_BEHAVIOR_REPLAY"] = "1"
    command = [
        str(context.resolve_path(token))
        if context is not None and token.startswith((".claude/", ".cairness/"))
        else token
        for token in case["command"]
    ]
    completed = subprocess.run(
        command,
        cwd=str(project_root),
        text=True,
        capture_output=True,
        check=False,
        env=env,
    )
    expected_exit = case["expect_exit_code"]
    if completed.returncode != expected_exit:
        issues.append(
            Issue(
                "E_BEHAVIOR008",
                str(path),
                f"expected exit {expected_exit}, got {completed.returncode}",
            )
        )
    combined = completed.stdout + "\n" + completed.stderr
    for expected in case["expect_output_contains"]:
        if expected not in combined:
            issues.append(Issue("E_BEHAVIOR009", str(path), f"missing expected output {expected!r}"))


def build_report(inputs: list[Path], context: HarnessContext | None = None) -> dict[str, Any]:
    context = context or load_harness_context(framework_hint=Path(__file__).resolve().parent.parent)
    project_root = context.project_root
    issues: list[Issue] = []
    cases = discover_cases(project_root, inputs, context)
    for path in cases:
        case = validate_case_shape(path, load_yaml(path, issues), issues)
        if case is not None:
            run_case(path, case, project_root, issues, context)
    return {
        "tool": "cc-behavior-check",
        "status": "failed" if issues else "passed",
        "project_root": str(project_root),
        "checked_cases": [str(path) for path in cases],
        "issues": issues_to_dicts(issues),
    }


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Replay Harness behavior eval cases.")
    parser.add_argument("paths", nargs="*", help="Behavior case files or directories.")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    parser.add_argument("--root", help="Explicit Cairness project root; overrides automatic discovery.")
    args = parser.parse_args(argv)
    try:
        context = load_harness_context(
            explicit_root=Path(args.root) if args.root else None,
            framework_hint=None if args.root else Path(__file__).resolve().parent.parent,
        )
    except HarnessContextError as exc:
        print(f"E_CONTEXT001 {exc}", file=sys.stderr)
        return 2
    report = build_report([Path(path) for path in args.paths], context)
    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    elif report["status"] == "passed":
        print("cc-behavior-check: ok")
    else:
        for issue in report["issues"]:
            print(f"{issue['code']} {issue['path']}: {issue['message']}", file=sys.stderr)
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
