RUNTIME_ROLES_PATH = ".claude/runtime/roles.yaml"
RUNTIME_ROLES_SCHEMA_PATH = ".claude/schemas/runtime-roles.schema.json"


def require_declared_path(project_root: Path, subject_path: Path, declared: Any, field: str, issues: list[Issue]) -> None:
    if is_state_path(project_root, declared):
        return  # project state files are generated by cc-* commands, not pre-existing
    resolved = project_path(project_root, declared)
    if resolved is not None and not resolved.exists():
        add(issues, "E_SCHEMA119", subject_path, f"{field} references missing path {declared}")


def load_runtime_role_registry(
    project_root: Path,
    issues: list[Issue],
    core: dict[str, Any] | None = None,
    checked: list[str] | None = None,
) -> set[str]:
    config = core.get("runtime_roles") if isinstance(core, dict) else None
    manifest_declared = (
        config.get("manifest") if isinstance(config, dict) else RUNTIME_ROLES_PATH
    )
    schema_declared = (
        config.get("schema") if isinstance(config, dict) else RUNTIME_ROLES_SCHEMA_PATH
    )
    manifest_path = project_path(project_root, manifest_declared)
    schema_path = project_path(project_root, schema_declared)
    if manifest_path is None:
        manifest_path = project_root / RUNTIME_ROLES_PATH
    if schema_path is None:
        schema_path = project_root / RUNTIME_ROLES_SCHEMA_PATH
    if checked is not None:
        checked.extend([str(manifest_path), str(schema_path)])
    manifest = load_yaml_file(manifest_path, issues)
    schema = load_json_file(schema_path, issues)
    if isinstance(manifest, dict) and isinstance(schema, dict):
        validate_against_schema(
            manifest, schema, schema, [], manifest_path, issues
        )
    roles = runtime_role_ids(manifest)
    if not roles:
        add(
            issues,
            "E_SCHEMA153",
            manifest_path,
            "runtime role registry must register at least one role",
        )
    return roles


def load_registered_roles(project_root: Path, issues: list[Issue]) -> set[str]:
    """Compatibility API returning canonical runtime role identifiers."""
    return load_runtime_role_registry(project_root, issues)


HARNESS_CONFIG_PATH = ".claude/harness.config.yaml"


def load_runtime_protocol(project_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> dict[str, Any]:
    """Merge protocol assets, pushing failures into issues via load_yaml_file.

    Thin adapter over harness_runtime.readsets.load_protocol_assets, kept under
    the historical name because validate_agent_command_protocol calls it
    directly. The derivation chain itself now lives in the shared module.
    """
    context = _ACTIVE_CONTEXT.get()
    return load_protocol_assets(
        project_root,
        core,
        issues,
        load_yaml_file,
        framework_root=context.framework_root if context is not None else None,
    )


def derive_readsets(project_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> tuple[dict[str, Any], dict[str, dict[str, Any]]]:
    """Derive readsets via the shared module; drop the config cc-readset needs.

    cc-schema-check's validate pipeline only needs (index, readsets); the
    shared module also returns a readset_config used by cc-readset for file
    paths, which we discard here.
    """
    context = _ACTIVE_CONTEXT.get()
    index, readsets, _config = _derive_readsets_shared(
        project_root,
        core,
        issues,
        load_yaml_file,
        framework_root=context.framework_root if context is not None else None,
    )
    return index, readsets


def validate_runtime_readsets(claude_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> list[str]:
    if not isinstance(core, dict):
        return []
    project_root = active_project_root(claude_root)
    config = runtime_readset_config(core)
    schema_path = project_path(project_root, config["schema"])
    index_path = project_path(project_root, config["index"])
    checked: list[str] = []
    schema = None
    if schema_path is not None:
        checked.append(str(schema_path))
        schema = load_json_file(schema_path, issues)

    expected_index, expected_readsets = derive_readsets(project_root, core, issues)
    if index_path is not None:
        checked.append(str(index_path))
        index = load_yaml_file(index_path, issues)
        if isinstance(index, dict) and index != expected_index:
            add(issues, "E_SCHEMA150", index_path, "runtime readset index is stale; run cc-readset --write")

    for command, expected in expected_readsets.items():
        declared = expected_index.get("commands", {}).get(command)
        path = project_path(project_root, declared)
        if path is None:
            continue
        checked.append(str(path))
        actual = load_yaml_file(path, issues)
        if isinstance(actual, dict):
            if schema is not None:
                validate_against_schema(actual, schema, schema, [], path, issues)
            if actual != expected:
                add(issues, "E_SCHEMA151", path, f"{command} runtime readset is stale; run cc-readset --write")

    readset_dir = project_path(project_root, config["dir"])
    expected_paths = {config["index"], *expected_index.get("commands", {}).values()}
    if readset_dir is not None and readset_dir.exists():
        for path in sorted(readset_dir.glob("*.yaml")):
            declared = f"{config['dir'].rstrip('/')}/{path.name}"
            if declared not in expected_paths:
                add(issues, "E_SCHEMA152", path, "extra runtime readset file")
    return checked


def validate_technology_catalog_shape(catalog: dict[str, Any], catalog_path: Path, issues: list[Issue]) -> None:
    issues.extend(technology_catalog_shape_issues(catalog, catalog_path))


def validate_language_profile_and_technology_catalog(
    project_root: Path,
    profile_path: Path,
    language_profile_schema: dict[str, Any] | None,
    catalog_schema: dict[str, Any] | None,
    checked: list[str],
    issues: list[Issue],
) -> None:
    if str(profile_path) not in checked:
        checked.append(str(profile_path))
    language = load_yaml_file(profile_path, issues)
    if not isinstance(language, dict):
        return
    if language_profile_schema is not None:
        validate_against_schema(language, language_profile_schema, language_profile_schema, [], profile_path, issues)
    for field in ("version", "language", "project_detection", "verification", "fixtures", "technology_decisions"):
        if field not in language:
            add(issues, "E_SCHEMA170", profile_path, f"language profile missing {field}")
    project_detection = language.get("project_detection") if isinstance(language.get("project_detection"), dict) else {}
    module_file = project_detection.get("module_file")
    module_files = project_detection.get("module_files")
    if isinstance(module_file, str) and isinstance(module_files, list) and module_file not in string_list(module_files):
        add(issues, "E_SCHEMA181", profile_path, f"project_detection.module_file {module_file} must be listed in module_files")

    technology_decisions = language.get("technology_decisions") if isinstance(language.get("technology_decisions"), dict) else {}
    declared_catalog = technology_decisions.get("catalog")
    require_declared_path(project_root, profile_path, declared_catalog, "technology_decisions.catalog", issues)
    catalog_path = project_path(project_root, declared_catalog)
    if catalog_path is None:
        return
    if str(catalog_path) not in checked:
        checked.append(str(catalog_path))
    catalog = load_yaml_file(catalog_path, issues)
    if not isinstance(catalog, dict):
        return
    if catalog_schema is not None:
        validate_against_schema(catalog, catalog_schema, catalog_schema, [], catalog_path, issues)
    if isinstance(language.get("language"), str) and catalog.get("language") != language.get("language"):
        add(issues, "E_SCHEMA178", catalog_path, f"catalog language {catalog.get('language')} does not match profile language {language.get('language')}")
    validate_technology_catalog_shape(catalog, catalog_path, issues)


def validate_agent_command_protocol(claude_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> list[str]:
    project_root = active_project_root(claude_root)
    config = runtime_protocol_config(core)
    protocol_path = project_path(project_root, config["protocol"])
    schema_path = project_path(project_root, config["schema"])
    language_path = project_path(project_root, config["default_language_profile"])
    checked: list[str] = []

    protocol: dict[str, Any] | None = None
    schema: dict[str, Any] | None = None
    if schema_path is not None:
        checked.append(str(schema_path))
        schema = load_json_file(schema_path, issues)
    for key in ("protocol", "technology_decisions", "language_profile"):
        asset_path = project_path(project_root, config.get(key))
        if asset_path is not None:
            checked.append(str(asset_path))
    protocol = load_runtime_protocol(project_root, core, issues)
    if isinstance(protocol, dict) and schema is not None and protocol_path is not None:
        validate_against_schema(protocol, schema, schema, [], protocol_path, issues)
    language_profile_schema: dict[str, Any] | None = None
    language_profile_schema_path: Path | None = None
    catalog_schema: dict[str, Any] | None = None
    catalog_schema_path: Path | None = None
    if isinstance(protocol, dict):
        declared_language_schema = (
            protocol.get("language_profile", {}).get("schema")
            if isinstance(protocol.get("language_profile"), dict)
            else None
        )
        language_profile_schema_path = project_path(project_root, declared_language_schema)
        if language_profile_schema_path is not None:
            checked.append(str(language_profile_schema_path))
            language_profile_schema = load_json_file(language_profile_schema_path, issues)
        declared_catalog_schema = (
            protocol.get("technology_decisions", {}).get("catalog_schema")
            if isinstance(protocol.get("technology_decisions"), dict)
            else None
        )
        catalog_schema_path = project_path(project_root, declared_catalog_schema)
        if catalog_schema_path is not None:
            checked.append(str(catalog_schema_path))
            catalog_schema = load_json_file(catalog_schema_path, issues)

    if not isinstance(protocol, dict) or protocol_path is None:
        return checked

    path_roles = protocol.get("path_roles") if isinstance(protocol.get("path_roles"), dict) else {}
    error_taxonomy = protocol.get("error_taxonomy") if isinstance(protocol.get("error_taxonomy"), dict) else {}
    input_contracts = protocol.get("input_contracts") if isinstance(protocol.get("input_contracts"), dict) else {}
    _E_CODE_RE = re.compile(r"^E_[A-Z]+[0-9]+$")
    for taxon, contract in error_taxonomy.items():
        if not isinstance(contract, dict):
            continue
        error_codes = contract.get("error_codes")
        if error_codes is None:
            continue
        if not isinstance(error_codes, list):
            add(issues, "E_SCHEMA131", protocol_path, f"error_taxonomy.{taxon}.error_codes must be a list")
            continue
        for code in error_codes:
            if not isinstance(code, str) or not _E_CODE_RE.match(code):
                add(issues, "E_SCHEMA131", protocol_path, f"error_taxonomy.{taxon}.error_codes entry {code!r} is not a valid E_* code")
    for name, contract in input_contracts.items():
        if not isinstance(contract, dict):
            continue
        resolves_to = contract.get("resolves_to")
        if isinstance(resolves_to, str) and resolves_to not in path_roles:
            add(issues, "E_SCHEMA171", protocol_path, f"input_contracts.{name}.resolves_to references unknown path role {resolves_to}")
        for error_field in ("missing_error", "invalid_error"):
            error_code = contract.get(error_field)
            if isinstance(error_code, str) and error_code != "none" and error_code not in error_taxonomy:
                add(issues, "E_SCHEMA172", protocol_path, f"input_contracts.{name}.{error_field} references unknown error {error_code}")

    rendering = protocol.get("result_rendering") if isinstance(protocol.get("result_rendering"), dict) else {}
    for field in ("success_template", "error_template"):
        require_declared_path(project_root, protocol_path, rendering.get(field), f"result_rendering.{field}", issues)

    lifecycle_events = protocol.get("lifecycle_events") if isinstance(protocol.get("lifecycle_events"), dict) else {}
    for field in ("schema", "template"):
        require_declared_path(project_root, protocol_path, lifecycle_events.get(field), f"lifecycle_events.{field}", issues)

    technology_decisions = protocol.get("technology_decisions") if isinstance(protocol.get("technology_decisions"), dict) else {}
    require_declared_path(project_root, protocol_path, technology_decisions.get("catalog_schema"), "technology_decisions.catalog_schema", issues)
    blocking_error = technology_decisions.get("blocking_error")
    if isinstance(blocking_error, str) and blocking_error not in error_taxonomy:
        add(issues, "E_SCHEMA179", protocol_path, f"technology_decisions.blocking_error references unknown error {blocking_error}")

    language_profile = protocol.get("language_profile") if isinstance(protocol.get("language_profile"), dict) else {}
    require_declared_path(project_root, protocol_path, language_profile.get("schema"), "language_profile.schema", issues)
    resolution = language_profile.get("resolution") if isinstance(language_profile.get("resolution"), dict) else {}
    for error_field in ("ambiguous_error", "unsupported_error"):
        error_code = resolution.get(error_field)
        if isinstance(error_code, str) and error_code not in error_taxonomy:
            add(issues, "E_SCHEMA182", protocol_path, f"language_profile.resolution.{error_field} references unknown error {error_code}")
    profiles = language_profile.get("profiles") if isinstance(language_profile.get("profiles"), dict) else {}
    default_profile = language_profile.get("default")
    if isinstance(default_profile, str) and default_profile not in profiles:
        add(issues, "E_SCHEMA173", protocol_path, f"language_profile.default {default_profile} is not declared in profiles")
    for profile_name, declared in profiles.items():
        require_declared_path(project_root, protocol_path, declared, f"language_profile.profiles.{profile_name}", issues)
        profile_path = project_path(project_root, declared)
        if profile_path is not None:
            validate_language_profile_and_technology_catalog(project_root, profile_path, language_profile_schema, catalog_schema, checked, issues)
    if language_path is not None and profiles and str(language_path) not in {
        str(project_path(project_root, value)) for value in profiles.values() if isinstance(value, str)
    }:
        add(issues, "E_SCHEMA174", protocol_path, "runtime_protocol.default_language_profile must be declared in protocol language_profile.profiles")
    # Cache the merged protocol so validate_runtime_commands can check
    # inputs.* names against input_contracts without reloading assets.
    # validate_runtime_manifests calls validate_agent_command_protocol before
    # validate_runtime_commands (see that function).
    global _PROTOCOL_CACHE
    _PROTOCOL_CACHE = protocol if isinstance(protocol, dict) else None
    return checked


def validate_topic_rules(claude_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> list[str]:
    if not isinstance(core, dict) or not isinstance(core.get("topic_rules"), dict):
        return []
    project_root = active_project_root(claude_root)
    schema_path = claude_root / "schemas" / TOPIC_RULE_SCHEMA
    schema = load_json_file(schema_path, issues)
    checked = [str(schema_path)]

    for topic_key, declared_path in sorted(core["topic_rules"].items()):
        path = project_path(project_root, declared_path)
        if path is None:
            continue
        checked.append(str(path))
        if not path.exists():
            continue

        if declared_path.endswith(".yaml"):
            data = load_yaml_file(path, issues)
            if data is None:
                continue
            for rk in TOPIC_RULE_YAML_REQUIRED_KEYS:
                if rk not in data:
                    add(issues, "E_SCHEMA137", path, f"topic rule {topic_key} missing required key: {rk}")
            ar = data.get("anti_rationalization")
            if isinstance(ar, list):
                for i, entry in enumerate(ar):
                    if isinstance(entry, dict) and ("claim" not in entry or "reality" not in entry):
                        add(issues, "E_SCHEMA139", path, f"topic rule {topic_key} anti_rationalization[{i}] missing claim/reality")
            rel = data.get("relevance")
            if rel is not None:
                if not isinstance(rel, dict):
                    add(issues, "E_SCHEMA140", path, f"topic rule {topic_key} relevance must be a mapping")
                else:
                    cat = rel.get("category")
                    if cat not in ("always", "change_type", "default_skip"):
                        add(issues, "E_SCHEMA140", path, f"topic rule {topic_key} relevance.category must be always|change_type|default_skip, got {cat}")
                    trigs = rel.get("triggers")
                    if not isinstance(trigs, list) or len(trigs) == 0:
                        add(issues, "E_SCHEMA140", path, f"topic rule {topic_key} relevance.triggers must be a non-empty list")
        else:
            text = read(path)
            if schema is not None:
                validate_against_schema(parse_frontmatter(text), schema, schema, [], path, issues)
            previous_position = -1
            for marker in TOPIC_RULE_REQUIRED_SECTIONS:
                position = text.find(marker)
                if position == -1:
                    add(issues, "E_SCHEMA137", path, f"topic rule {topic_key} missing skill-like section {marker}")
                    continue
                if position < previous_position:
                    add(issues, "E_SCHEMA138", path, f"topic rule {topic_key} has section out of order: {marker}")
                previous_position = position
            if TOPIC_RULE_RATIONALIZATION_HEADER not in text:
                add(issues, "E_SCHEMA139", path, f"topic rule {topic_key} missing anti-rationalization table")
    return checked


def validate_runtime_core(claude_root: Path, issues: list[Issue]) -> dict[str, Any] | None:
    project_root = active_project_root(claude_root)
    core_path = claude_root / "runtime" / "core.yaml"
    schema_path = claude_root / "schemas" / RUNTIME_CORE_SCHEMA
    core = load_yaml_file(core_path, issues)
    schema = load_json_file(schema_path, issues)
    if core is None:
        return None
    if schema is not None:
        validate_against_schema(core, schema, schema, [], core_path, issues)

    for field in ("workflow_definition",):
        require_declared_path(project_root, core_path, core.get(field), field, issues)
    for section in ("runtime_roles", "runtime_readsets", "runtime_protocol", "legacy_fallback", "governance", "scripts", "topic_rules"):
        values = core.get(section)
        if isinstance(values, dict):
            for key, declared in values.items():
                require_declared_path(project_root, core_path, declared, f"{section}.{key}", issues)

    validate_runtime_command_registration(project_root, core_path, core, issues)

    # Project profiles (minimal/standard/strict) — validate structure against
    # profile.schema, symmetric to language-profile validation. A4 closes the
    # gap where these files were read (readsets.resolve_active_profile_path)
    # but never schema-validated.
    profiles_cfg = core.get("profiles")
    if isinstance(profiles_cfg, dict):
        profiles_dir = profiles_cfg.get("dir")
        default_profile = profiles_cfg.get("default")
        if isinstance(default_profile, str) and default_profile not in VALID_PROFILE_IDS:
            add(issues, "E_SCHEMA194", core_path, f"profiles.default {default_profile!r} is not one of {sorted(VALID_PROFILE_IDS)}")
        if isinstance(profiles_dir, str):
            profiles_root = project_path(project_root, profiles_dir)
            profile_schema_path = claude_root / "schemas" / PROFILE_SCHEMA
            profile_schema = load_json_file(profile_schema_path, issues)
            if profiles_root is not None and profile_schema is not None:
                for profile_id in sorted(VALID_PROFILE_IDS):
                    profile_file = profiles_root / f"{profile_id}.yaml"
                    if not profile_file.exists():
                        add(issues, "E_SCHEMA195", core_path, f"profiles.dir missing {profile_id}.yaml")
                        continue
                    profile = load_yaml_file(profile_file, issues)
                    if isinstance(profile, dict):
                        validate_against_schema(profile, profile_schema, profile_schema, [], profile_file, issues)
    return core


def effective_subagent_contract(
    project_root: Path,
    command: str,
    manifest: dict[str, Any],
    manifest_path: Path,
    contract_schema: dict[str, Any] | None,
    checked: list[str],
    issues: list[Issue],
) -> dict[str, Any] | None:
    subagents = manifest.get("subagents")
    if not isinstance(subagents, dict):
        return None
    contract_declared = subagents.get("contract")
    if not isinstance(contract_declared, str):
        return subagents

    contract_path = project_path(project_root, contract_declared)
    if contract_path is None:
        add(issues, "E_SCHEMA183", manifest_path, f"subagents.contract must be a project path: {contract_declared}")
        return subagents
    checked.append(str(contract_path))
    contract = load_yaml_file(contract_path, issues)
    if not isinstance(contract, dict):
        return subagents
    if contract_schema is not None:
        validate_against_schema(contract, contract_schema, contract_schema, [], contract_path, issues)
    if contract.get("command") != command:
        add(issues, "E_SCHEMA184", contract_path, f"subagent contract command must be {command}")

    return merge_subagent_contract(subagents, contract)


def validate_subagent_runtime_contract(
    command: str,
    manifest: dict[str, Any],
    path: Path,
    issues: list[Issue],
    registered_roles: set[str],
) -> None:
    issues.extend(
        subagent_runtime_contract_issues(
            command, manifest, path, registered_roles
        )
    )


def effective_result_contract(
    project_root: Path,
    manifest: dict[str, Any],
    path: Path,
    checked: list[str],
    issues: list[Issue],
) -> dict[str, Any] | None:
    result_contract = manifest.get("result_contract")
    if not isinstance(result_contract, dict):
        return None

    profile: dict[str, Any] | None = None
    profile_declared = result_contract.get("profile")
    if isinstance(profile_declared, str):
        profile_path = project_path(project_root, profile_declared)
        if profile_path is not None:
            checked.append(str(profile_path))
            loaded_profile = load_yaml_file(profile_path, issues)
            if isinstance(loaded_profile, dict):
                profile = loaded_profile

    return merge_result_contract(profile, result_contract)


def validate_result_contract(
    project_root: Path,
    command: str,
    manifest: dict[str, Any],
    path: Path,
    checked: list[str],
    issues: list[Issue],
) -> None:
    result_contract = effective_result_contract(project_root, manifest, path, checked, issues)
    if not isinstance(result_contract, dict):
        return
    issues.extend(result_contract_issues(command, manifest, result_contract, path))


def validate_interaction_contract(command: str, manifest: dict[str, Any], path: Path, issues: list[Issue]) -> None:
    issues.extend(interaction_contract_issues(command, manifest, path))


def validate_runtime_command_references(
    project_root: Path,
    core: dict[str, Any] | None,
    command: str,
    manifest: dict[str, Any],
    path: Path,
    issues: list[Issue],
) -> None:
    registered_topics = registered_topic_paths(core)
    registered_topic_files = {
        resolved
        for declared in registered_topics
        if (resolved := project_path(project_root, declared)) is not None
    }

    if manifest.get("command") != command:
        add(issues, "E_SCHEMA126", path, f"command field must match runtime core key {command}")
    if path.name != f"{command}.yaml":
        add(issues, "E_SCHEMA127", path, f"filename must be {command}.yaml")

    state = manifest.get("state")
    if isinstance(state, dict) and state.get("change_to") == "done" and command != "cc-archive":
        add(issues, "E_SCHEMA128", path, "only cc-archive may set change_to done")

    if missing_state_transition_event_write(manifest):
        add(
            issues,
            "E_SCHEMA200",
            path,
            f"{command} invokes cc-state-transition but writes does not declare {CHANGE_EVENT_LOG_WRITE}",
        )

    if command in ANTI_RATIONALIZATION_COMMANDS:
        for key in ("anti_rationalizations", "red_flags"):
            if not isinstance(manifest.get(key), list) or not manifest.get(key):
                add(issues, "E_SCHEMA129", path, f"{command} must declare non-empty {key}")

    for field, declared in read_path_references(manifest):
        require_declared_path(project_root, path, declared, field, issues)

    missing_conditions, missing_templates = missing_template_reads(command, manifest)
    for condition in missing_conditions:
        add(issues, "E_SCHEMA189", path, f"{command} missing conditional_reads.{condition} for template artifacts")
    for condition, template in missing_templates:
        add(issues, "E_SCHEMA190", path, f"{command} must conditionally read template {template} under {condition}")

    for field, rule_path in topic_rule_references(manifest):
        resolved_rule = project_path(project_root, rule_path)
        if registered_topic_files and resolved_rule not in registered_topic_files:
            add(issues, "E_SCHEMA130", path, f"{field} is not registered in runtime/core.yaml: {rule_path}")
        require_declared_path(project_root, path, rule_path, field, issues)

    for field, declared in contract_path_references(manifest):
        require_declared_path(project_root, path, declared, field, issues)


def validate_inputs_registered(command: str, manifest: dict[str, Any], manifest_path: Path, issues: list[Issue]) -> None:
    """Check manifest.inputs.* names are registered in protocol.yaml input_contracts.

    E_SCHEMA133: a required/optional input name is not declared in input_contracts.
    E_SCHEMA134: a required input's contract uses missing_error: none (a required
                 input cannot use the 'no error' sentinel).
    E_SCHEMA199: an enum input contract is missing its values array.
    Relies on _PROTOCOL_CACHE populated by validate_agent_command_protocol.
    """
    issues.extend(
        input_contract_issues(command, manifest, manifest_path, _PROTOCOL_CACHE)
    )


def validate_runtime_commands(claude_root: Path, core: dict[str, Any] | None, issues: list[Issue]) -> list[str]:
    project_root = active_project_root(claude_root)
    schema_path = claude_root / "schemas" / RUNTIME_COMMAND_SCHEMA
    schema = load_json_file(schema_path, issues)
    subagent_schema_path = claude_root / "schemas" / RUNTIME_SUBAGENT_CONTRACT_SCHEMA
    subagent_schema = load_json_file(subagent_schema_path, issues)
    checked: list[str] = [str(subagent_schema_path)]
    registered_roles = load_runtime_role_registry(
        project_root, issues, core, checked
    )
    legacy_roles_path = (
        project_path(project_root, ROLE_CONTRACTS_PATH)
        or project_root / ROLE_CONTRACTS_PATH
    )
    fallback_paths = list((claude_root / "runtime" / "commands").glob("cc-*.yaml"))
    command_paths = [
        (
            command,
            project_path(project_root, declared)
            if isinstance(declared, str)
            else declared,
        )
        for command, declared in runtime_command_declarations(core, fallback_paths)
    ]

    for command, resolved_path in command_paths:
        if resolved_path is None:
            continue
        checked.append(str(resolved_path))
        manifest = load_yaml_file(resolved_path, issues)
        if manifest is None:
            continue
        if schema is not None:
            validate_against_schema(manifest, schema, schema, [], resolved_path, issues)
        validate_runtime_command_references(project_root, core, command, manifest, resolved_path, issues)
        effective_manifest = dict(manifest)
        effective_subagents = effective_subagent_contract(
            project_root,
            command,
            manifest,
            resolved_path,
            subagent_schema,
            checked,
            issues,
        )
        if effective_subagents is not None:
            effective_manifest["subagents"] = effective_subagents
        role_resolution = resolve_registered_roles(
            str(command), core, registered_roles, legacy_roles_path
        )
        validate_subagent_runtime_contract(
            command,
            effective_manifest,
            resolved_path,
            issues,
            role_resolution.roles,
        )
        validate_result_contract(project_root, command, manifest, resolved_path, checked, issues)
        validate_interaction_contract(command, manifest, resolved_path, issues)
        validate_inputs_registered(command, manifest, resolved_path, issues)
    return checked


def validate_execution_profiles(claude_root: Path, issues: list[Issue]) -> list[str]:
    """Validate all runtime/profiles/*.yaml files against profile.schema.json."""
    profiles_dir = claude_root / "runtime" / "profiles"
    schema_path = claude_root / "schemas" / PROFILE_SCHEMA
    schema = load_json_file(schema_path, issues)
    if schema is None:
        return []

    checked: list[str] = []
    if not profiles_dir.is_dir():
        return checked

    for profile_file in sorted(profiles_dir.glob("*.yaml")):
        profile = load_yaml_file(profile_file, issues)
        checked.append(str(profile_file))
        if profile is None:
            continue
        validate_against_schema(profile, schema, schema, [], profile_file, issues)

    return checked


def validate_runtime_manifests(claude_root: Path, issues: list[Issue]) -> tuple[list[str], list[str]]:
    core = validate_runtime_core(claude_root, issues)
    checked = [str(claude_root / "runtime" / "core.yaml")]
    config_path = claude_root / "harness.config.yaml"
    config_schema_path = claude_root / "schemas" / "harness-config.schema.json"
    checked.extend([str(config_path), str(config_schema_path)])
    try:
        load_harness_config(config_path, schema_path=config_schema_path)
    except HarnessConfigError as exc:
        add(issues, "E_SCHEMA199", config_path, str(exc))
    checked.extend(validate_agent_command_protocol(claude_root, core, issues))
    checked.extend(validate_runtime_commands(claude_root, core, issues))
    checked.extend(validate_runtime_readsets(claude_root, core, issues))
    checked.extend(validate_knowledge_categories(claude_root, issues))
    checked.extend(validate_enums(claude_root, issues))
    checked.extend(validate_execution_profiles(claude_root, issues))
    checked_topic_rules = validate_topic_rules(claude_root, core, issues)
    return checked, checked_topic_rules


def validate_knowledge_categories(claude_root: Path, issues: list[Issue]) -> list[str]:
    catalog_path = claude_root / "runtime" / "knowledge-categories.yaml"
    schema_path = claude_root / "schemas" / KNOWLEDGE_CATEGORIES_SCHEMA
    catalog = load_yaml_file(catalog_path, issues)
    schema = load_json_file(schema_path, issues)
    if catalog is None or schema is None:
        return [str(catalog_path)] if catalog_path.exists() else []
    validate_against_schema(catalog, schema, schema, [], catalog_path, issues)

    seen_subdirs: set[str] = set()
    seen_display: set[str] = set()
    for entry in catalog.get("categories", []) or []:
        if not isinstance(entry, dict):
            continue
        subdir = entry.get("subdir")
        if isinstance(subdir, str):
            if subdir in seen_subdirs:
                add(
                    issues,
                    "E_SCHEMA160",
                    catalog_path,
                    f"duplicate knowledge category subdir: {subdir}",
                )
            seen_subdirs.add(subdir)
        display = entry.get("display_name")
        if isinstance(display, str):
            if display in seen_display:
                add(
                    issues,
                    "E_SCHEMA161",
                    catalog_path,
                    f"duplicate knowledge category display_name: {display}",
                )
            seen_display.add(display)
    return [str(catalog_path)]


def validate_change_id(value: Any) -> bool:
    return isinstance(value, str) and bool(CHANGE_ID_RE.match(value))


# enums.yaml required enums and their subset relationships. Lightweight code
# validation (no schema) — mirrors validate_knowledge_categories' approach for
# runtime/*.yaml structural checks. The source-of-truth structure is also
# guarded by tests/test_enums_single_source.py.
ENUMS_REQUIRED = {
    "change_status": ("core",),
    "task_status": ("core",),
    "finding_status": ("core",),
    "validation_mapping_status": ("core",),
    "test_mode": ("core",),
}


def validate_enums(claude_root: Path, issues: list[Issue]) -> list[str]:
    enums_path = claude_root / "runtime" / "enums.yaml"
    if not enums_path.exists():
        add(issues, "E_SCHEMA196", enums_path, "enums.yaml not found (lifecycle enum single source)")
        return []
    enums = load_yaml_file(enums_path, issues)
    if not isinstance(enums, dict):
        add(issues, "E_SCHEMA196", enums_path, "enums.yaml root must be a mapping")
        return [str(enums_path)]
    for name, required_subsets in ENUMS_REQUIRED.items():
        entry = enums.get(name)
        if not isinstance(entry, dict):
            add(issues, "E_SCHEMA196", enums_path, f"enums.yaml missing enum {name!r}")
            continue
        for subset in required_subsets:
            values = entry.get(subset)
            if not isinstance(values, list) or not values:
                add(issues, "E_SCHEMA197", enums_path, f"enums.yaml {name}.{subset} must be a non-empty list")
    # Subset relationships (core ⊆ from_set/to_set; closed ⊆ core).
    cs = enums.get("change_status")
    if isinstance(cs, dict):
        core = _enum_values(cs.get("core"))
        from_set = _enum_values(cs.get("from_set"))
        to_set = _enum_values(cs.get("to_set"))
        if core and from_set and not core <= from_set:
            add(issues, "E_SCHEMA198", enums_path, "change_status.core must be a subset of from_set")
        if core and to_set and not core <= to_set:
            add(issues, "E_SCHEMA198", enums_path, "change_status.core must be a subset of to_set")
    vm = enums.get("validation_mapping_status")
    if isinstance(vm, dict):
        core = _enum_values(vm.get("core"))
        closed = _enum_values(vm.get("closed"))
        if core and closed and not closed <= core:
            add(issues, "E_SCHEMA198", enums_path, "validation_mapping_status.closed must be a subset of core")
    return [str(enums_path)]


def _enum_values(value: Any) -> set[str]:
    if not isinstance(value, list):
        return set()
    return {str(v) for v in value}


def validate_spec(path: Path, issues: list[Issue]) -> set[str]:
    text = read(path)
    meta = parse_meta(text)
    change_id = meta.get("change_id")
    if not validate_change_id(change_id):
        add(issues, "E_SCHEMA001", path, "invalid or missing change_id")
    elif change_id != path.parent.name:
        add(issues, "E_SCHEMA201", path, "change_id must match the change directory name")
    if meta.get("status") not in VALID_CHANGE_STATUS:
        add(issues, "E_SCHEMA002", path, "invalid or missing status")
    for key in ("depends_on", "parallel_safe", "branch", "created", "updated", "complexity"):
        if key not in meta:
            add(issues, "E_SCHEMA003", path, f"missing metadata field {key}")
    depends_on = meta.get("depends_on")
    if depends_on is not None and not isinstance(depends_on, list):
        add(issues, "E_SCHEMA004", path, "depends_on must be a list")
    if "parallel_safe" in meta and not isinstance(meta.get("parallel_safe"), bool):
        add(issues, "E_SCHEMA005", path, "parallel_safe must be boolean")

    mapping_ids: set[str] = set()
    rows = validation_rows(text)
    if not rows:
        add(issues, "E_SCHEMA006", path, "missing validation mapping rows")
    for row in rows:
        if len(row) < 7:
            add(issues, "E_SCHEMA007", path, f"validation row {row[0]} has fewer than 7 columns")
            continue
        vid, level, evidence, status = row[0], row[2], row[3], row[6]
        mapping_ids.add(vid)
        if level not in EVIDENCE_BY_LEVEL:
            add(issues, "E_SCHEMA008", path, f"{vid} has invalid level {level}")
        elif evidence not in EVIDENCE_BY_LEVEL[level]:
            add(issues, "E_SCHEMA009", path, f"{vid} evidence {evidence} does not match {level}")
        if status not in VALID_MAPPING_STATUS:
            add(issues, "E_SCHEMA010", path, f"{vid} has invalid closure status {status}")

    for field in HARD_GATE_FIELDS:
        if f"**{field}**" not in text:
            add(issues, "E_SCHEMA011", path, f"HARD-GATE missing {field}")
    return mapping_ids


def validate_tasks(path: Path, mapping_ids: set[str], issues: list[Issue]) -> None:
    text = read(path)
    meta = parse_meta(text)
    change_id = meta.get("change_id")
    if not validate_change_id(change_id):
        add(issues, "E_SCHEMA012", path, "invalid or missing change_id")
    elif change_id != path.parent.name:
        add(issues, "E_SCHEMA202", path, "change_id must match the change directory name")
    sections = task_sections(text)
    if not sections:
        add(issues, "E_SCHEMA013", path, "no task sections found")
    for section in sections:
        title = section.splitlines()[0].strip()
        for field in TASK_FIELDS:
            if field not in section:
                add(issues, "E_SCHEMA014", path, f"{title} missing {field}")
        match = re.search(r"\*\*完成后状态\*\*\s*:\s*`?([a-z_]+)`?", section)
        if match and match.group(1) not in VALID_TASK_STATUS:
            add(issues, "E_SCHEMA015", path, f"{title} has invalid task status {match.group(1)}")
    for vid in mapping_ids:
        if vid not in text:
            add(issues, "E_SCHEMA016", path, f"missing validation mapping {vid}")


def validate_review(path: Path, issues: list[Issue]) -> None:
    if not path.exists():
        return
    text = read(path)
    meta = parse_meta(text)
    # Delegate the review rules to the shared collect_review_violations (same
    # body cc-lint.lint_review runs); only the output shape differs (Issue +
    # E_SCHEMA* codes here). Keeps cc-lint and cc-schema-check in lockstep —
    # a rule change applied to one can no longer silently miss the other.
    for code, msg in collect_review_violations(
        text, meta, valid_review_status=VALID_REVIEW_STATUS, valid_finding_status=_FINDING_STATUS
    ):
        add(issues, code, path, msg)


def validate_test_spec(path: Path, issues: list[Issue]) -> None:
    if not path.exists():
        return
    text = read(path)
    meta = parse_meta(text)
    if meta and meta.get("status") not in VALID_CHANGE_STATUS:
        add(issues, "E_SCHEMA019", path, "invalid status")
    for row in table_rows(text):
        if len(row) >= 2 and row[0].replace("`", "") == "cc-test 模式":
            mode = row[1].strip("` ")
            if mode not in VALID_TEST_MODE:
                add(issues, "E_SCHEMA020", path, f"invalid cc-test mode {mode}")
            return
    add(issues, "E_SCHEMA021", path, "missing cc-test mode row")


def discover_change_dirs(inputs: list[Path]) -> list[Path]:
    dirs: set[Path] = set()
    for item in inputs:
        if item.is_file():
            parent = item.parent
            if (parent / "spec.md").exists() and (parent / "tasks.md").exists():
                dirs.add(parent)
            continue
        if (item / "spec.md").exists() and (item / "tasks.md").exists():
            dirs.add(item)
            continue
        if item.is_dir():
            for spec in item.rglob("spec.md"):
                if "templates" in spec.parts:
                    continue
                parent = spec.parent
                if (parent / "tasks.md").exists():
                    dirs.add(parent)
    return sorted(dirs)


def default_input(context: HarnessContext | None = None) -> Path:
    if context is not None:
        return context.state_root / "changes"
    cwd = Path.cwd()
    if (cwd / ".cairness" / "changes").exists():
        return cwd / ".cairness" / "changes"
    return Path(__file__).resolve().parent.parent.parent / ".cairness" / "changes"


def build_report(inputs: list[Path], context: HarnessContext | None = None) -> dict[str, Any]:
    issues: list[Issue] = []
    claude_root = context.framework_root if context is not None else Path(__file__).resolve().parent.parent
    token = _ACTIVE_CONTEXT.set(context)
    path_token = set_path_roots(
        context.framework_root if context is not None else claude_root,
        context.state_root if context is not None else claude_root.parent / ".cairness",
    )
    try:
        checked_runtime, checked_topic_rules = validate_runtime_manifests(claude_root, issues)
        change_dirs = discover_change_dirs(inputs)
        for change_dir in change_dirs:
            mapping_ids = validate_spec(change_dir / "spec.md", issues)
            validate_tasks(change_dir / "tasks.md", mapping_ids, issues)
            validate_review(change_dir / "review.md", issues)
            validate_test_spec(change_dir / "test-spec.md", issues)
    finally:
        _ACTIVE_CONTEXT.reset(token)
        reset_path_roots(path_token)
    return {
        "tool": "cc-schema-check",
        "status": "failed" if issues else "passed",
        "project_root": str(context.project_root) if context is not None else str(claude_root.parent),
        "checked_runtime": checked_runtime,
        "checked_topic_rules": checked_topic_rules,
        "checked_changes": [str(path) for path in change_dirs],
        "issues": issues_to_dicts(issues),
    }


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Check cc_spec Harness document metadata and shape.")
    parser.add_argument("paths", nargs="*", help="Change directories, files, or changes root.")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    parser.add_argument("--root", help="Explicit Cairness project root; overrides automatic discovery.")
    args = parser.parse_args(argv)

    try:
        context = load_harness_context(
            explicit_root=Path(args.root) if args.root else None,
            framework_hint=None if args.root else Path(__file__).resolve().parent.parent,
            validate_config=False,
        )
    except HarnessContextError as exc:
        print(f"E_CONTEXT001 {exc}", file=sys.stderr)
        return 2
    inputs = [Path(path) for path in args.paths] if args.paths else [default_input(context)]
    report = build_report(inputs, context)
    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    elif report["status"] == "passed":
        print("cc-schema-check: ok")
    else:
        for issue in report["issues"]:
            print(f"{issue['code']} {issue['path']}: {issue['message']}", file=sys.stderr)
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
