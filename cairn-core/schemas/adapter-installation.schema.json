{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/adapter-installation.schema.json",
  "title": "Cairness Adapter Installation Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "adapter", "framework", "paths", "host_assets"],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "adapter": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "framework": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prefix", "root_convention"],
      "properties": {
        "prefix": {
          "type": "string",
          "pattern": "^\\.[a-zA-Z0-9][a-zA-Z0-9._-]*$"
        },
        "root_convention": {
          "type": "string",
          "enum": ["project-relative", "user-relative"]
        },
        "exclude_from_copy": {
          "type": "array",
          "items": {"$ref": "#/$defs/relativePath"},
          "uniqueItems": true
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["settings", "entrypoint", "capabilities", "capabilities_schema"],
      "properties": {
        "settings": {"$ref": "#/$defs/relativePath"},
        "entrypoint": {"$ref": "#/$defs/relativePath"},
        "capabilities": {"$ref": "#/$defs/relativePath"},
        "capabilities_schema": {"$ref": "#/$defs/relativePath"}
      }
    },
    "host_assets": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/hostAsset"}
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1
    },
    "hostAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "action", "source", "target"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "action": {
          "type": "string",
          "enum": ["copy-file", "copy-tree", "generate"]
        },
        "target_root": {
          "type": "string",
          "enum": ["adapter", "project"]
        },
        "source": {"$ref": "#/$defs/relativePath"},
        "target": {"$ref": "#/$defs/relativePath"}
      }
    }
  }
}
