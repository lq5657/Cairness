{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/review.schema.json",
  "title": "Golang Harness Review",
  "type": "object",
  "required": [
    "change_id",
    "stage1_status",
    "stage2_status",
    "final_status",
    "findings"
  ],
  "properties": {
    "change_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "stage1_status": {
      "type": "string",
      "enum": ["pass", "fail", "partial"]
    },
    "stage2_status": {
      "type": "string",
      "enum": ["pass", "fail", "skipped", "partial"]
    },
    "final_status": {
      "type": "string",
      "enum": ["pass", "fail", "partial"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "description", "status"],
        "properties": {
          "level": {
            "type": "string",
            "enum": ["Critical", "Important", "Minor", "无"]
          },
          "status": {
            "type": "string",
            "enum": ["open", "fixed", "accepted", "无", "-"]
          }
        }
      }
    }
  }
}
