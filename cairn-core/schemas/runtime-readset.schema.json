{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/runtime-readset.schema.json",
  "title": "cc_spec Harness Runtime Read Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "command",
    "source_manifest",
    "generated_from",
    "always_reads",
    "optional_reads",
    "conditional_reads"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "command": {
      "$ref": "#/$defs/ccCommand"
    },
    "source_manifest": {
      "type": "string",
      "pattern": "^\\.claude/runtime/commands/cc-[a-z0-9-]+\\.yaml$"
    },
    "generated_from": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "always_reads": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "optional_reads": {
      "$ref": "#/$defs/stringList"
    },
    "conditional_reads": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^when_[a-z0-9_]+$"
      },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "ccCommand": {
      "type": "string",
      "pattern": "^cc-[a-z0-9-]+$"
    },
    "stringList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
