#!/usr/bin/env python3
"""Deterministic topic-rule trigger detection CLI."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

from harness_runtime.context import HarnessContextError, load_harness_context
from harness_runtime.topic_trigger import (
    changed_files_from_diff,
    changed_files_from_git,
    changed_files_from_tasks,
    default_project_root,
    detect_triggers,
    file_matches_content_regex,
    file_matches_glob,
    file_matches_import_regex,
    load_patterns,
)


def main() -> None:
    parser = argparse.ArgumentParser(description="Deterministic topic rule trigger detection")
    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("--change-id", help="从 change 文档推断变更文件")
    group.add_argument("--files", nargs="+", help="直接指定文件列表")
    group.add_argument("--diff", action="store_true", help="从 stdin 读取 diff")
    group.add_argument("--changed", action="store_true", help="从 git diff HEAD~1 获取")
    parser.add_argument("--root", help="显式 Cairness 项目根目录；默认自动发现")
    args = parser.parse_args()

    try:
        context = load_harness_context(
            explicit_root=Path(args.root) if args.root else None,
            framework_hint=None if args.root else Path(__file__).resolve().parent.parent,
        )
    except HarnessContextError as exc:
        print(f"E_CONTEXT001 {exc}", file=sys.stderr)
        raise SystemExit(2)

    patterns = load_patterns(context.framework_root)
    if args.change_id:
        changed_files = changed_files_from_tasks(args.change_id, context.project_root)
    elif args.files:
        changed_files = args.files
    elif args.diff:
        changed_files = changed_files_from_diff(sys.stdin.read())
    else:
        changed_files = changed_files_from_git(context.project_root)

    result = {
        "project_root": str(context.project_root),
        **detect_triggers(changed_files, patterns, context.project_root),
    }
    json.dump(result, sys.stdout, indent=2, ensure_ascii=False)
    sys.stdout.write("\n")


if __name__ == "__main__":
    main()
