#!/usr/bin/env python3
"""Audit active references to legacy Harness paths, roles, commands, and checkpoints."""

from __future__ import annotations

import argparse
import json
from pathlib import Path

from harness_runtime.legacy_audit import scan_legacy_references
from harness_runtime.runtime_fallback_audit import load_runtime_boundary_report


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Audit legacy Harness references.")
    parser.add_argument("--root", type=Path, default=Path.cwd(), help="Project root to scan.")
    parser.add_argument("--json", action="store_true", help="Emit a JSON report.")
    args = parser.parse_args(argv)
    report_path = args.root / "cc-legacy-audit.json"
    report = scan_legacy_references(args.root, report_path=report_path)
    try:
        runtime_boundaries = load_runtime_boundary_report(args.root)
    except FileNotFoundError:
        runtime_boundaries = None
    except (OSError, ValueError) as exc:
        runtime_boundaries = {"status": "failed", "error": str(exc)}
    if runtime_boundaries is not None:
        report["runtime_boundaries"] = runtime_boundaries
        if runtime_boundaries.get("status") == "failed":
            report["status"] = "failed"
    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        if report["references"]:
            for item in report["references"]:
                print(f"{item['category']} {item['path']}:{item['line']}: {item['text']}")
        else:
            print("cc-legacy-audit: ok")
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main())
