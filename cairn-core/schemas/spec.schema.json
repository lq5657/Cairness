{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/spec.schema.json",
  "title": "cc_spec Harness Spec",
  "type": "object",
  "required": [
    "change_id",
    "status",
    "depends_on",
    "parallel_safe",
    "branch",
    "created",
    "updated",
    "complexity",
    "validation_map",
    "hard_gate"
  ],
  "properties": {
    "change_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "status": {
      "type": "string",
      "enum": ["propose", "apply", "review", "done"]
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      }
    },
    "parallel_safe": {
      "type": "boolean"
    },
    "branch": {
      "type": "string"
    },
    "created": {
      "type": "string"
    },
    "updated": {
      "type": "string"
    },
    "complexity": {
      "type": "string"
    },
    "validation_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "requirement_item", "level", "evidence_type", "suggested_action", "task", "status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^V[0-9]+$"
          },
          "requirement_item": {
            "type": "string",
            "description": "需求项 / 风险点"
          },
          "level": {
            "type": "string",
            "enum": ["L1", "L2", "L3", "L4", "L5"]
          },
          "evidence_type": {
            "type": "string",
            "enum": [
              "build",
              "doc-check",
              "package",
              "unit",
              "chain",
              "integration",
              "manual",
              "migration-safety",
              "release-safety"
            ]
          },
          "suggested_action": {
            "type": "string",
            "description": "建议验证动作"
          },
          "task": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["todo", "apply-covered", "test-covered", "gap"]
          }
        }
      }
    },
    "hard_gate": {
      "type": "object",
      "required": [
        "confirmed_at",
        "confirmed_by",
        "confirmed_spec_revision",
        "confirmed_tasks_revision",
        "confirmed_scope",
        "resolved_risk_decisions",
        "accepted_residual_risks",
        "human_review_required",
        "human_review_status"
      ],
      "properties": {
        "resolved_risk_decisions": {
          "type": "string"
        },
        "accepted_residual_risks": {
          "type": "string"
        },
        "human_review_required": {
          "type": "boolean"
        },
        "human_review_status": {
          "type": "string",
          "enum": ["not_required", "pending", "approved", "rejected"]
        }
      }
    }
  }
}
