{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/command-event.schema.json",
  "title": "Harness Command Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "occurred_at",
    "command",
    "change_id",
    "actor",
    "transition",
    "summary",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "event_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "occurred_at": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "pattern": "^cc-[a-z0-9-]+$"
    },
    "change_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {
          "type": "string",
          "enum": ["none", "propose", "apply", "review", "done", "unchanged"]
        },
        "to": {
          "type": "string",
          "enum": ["unchanged", "propose", "apply", "review", "done"]
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "命令执行耗时（毫秒）"
    },
    "token_count": {
      "type": "integer",
      "minimum": 0,
      "description": "估算的 token 消耗"
    },
    "subagent_count": {
      "type": "integer",
      "minimum": 0,
      "description": "调度的子 agent 数量"
    },
    "verification_status": {
      "type": "string",
      "enum": ["passed", "failed", "partial", "not_run"],
      "description": "验证门禁结果"
    },
    "result_status": {
      "type": "string",
      "enum": ["passed", "blocked", "partial"],
      "description": "命令最终结果；blocked/partial 事件必须使用 unchanged transition"
    },
    "error_codes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^E_[A-Z]+[0-9]+$"
      },
      "description": "本次命令遇到的错误码 (E_INPUT*/E_EVENT020/...)。与 verification_status 独立 — passed 事件可携带码,failed 事件可不携带"
    },
    "files_changed": {
      "type": "integer",
      "minimum": 0,
      "description": "修改的文件数量"
    },
    "phase": {
      "type": "string",
      "enum": ["propose", "apply", "review", "fix", "test", "archive"],
      "description": "生命周期阶段；preflight 是 activity，不是 phase"
    },
    "activity": {
      "type": "string",
      "enum": ["preflight", "execute", "verify", "transition", "wait"]
    },
    "run_kind": {
      "type": "string",
      "enum": ["primary", "retry", "shadow", "delta", "probe"]
    },
    "logical_run_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "terminal": {
      "type": "boolean"
    },
    "failure_class": {
      "type": "string",
      "minLength": 1
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "elapsed_ms": {"type": "number", "minimum": 0},
        "active_ms": {"type": "number", "minimum": 0},
        "tool_ms": {"type": "number", "minimum": 0},
        "verification_ms": {"type": "number", "minimum": 0},
        "wait_ms": {"type": "number", "minimum": 0},
        "blocked_ms": {"type": "number", "minimum": 0}
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input_tokens": {"type": "number", "minimum": 0},
        "output_tokens": {"type": "number", "minimum": 0},
        "cached_input_tokens": {"type": "number", "minimum": 0},
        "cache_write_tokens": {"type": "number", "minimum": 0},
        "reasoning_tokens": {"type": "number", "minimum": 0},
        "total_tokens": {"type": "number", "minimum": 0},
        "source": {"type": "string", "minLength": 1},
        "coverage": {"type": "string", "minLength": 1}
      }
    },
    "findings_summary": {
      "type": "object",
      "additionalProperties": false,
      "description": "review/fix 命令的 finding 汇总",
      "properties": {
        "total_open": {"type": "integer", "minimum": 0},
        "total_fixed": {"type": "integer", "minimum": 0},
        "total_accepted": {"type": "integer", "minimum": 0},
        "by_severity": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        }
      }
    },
    "gate_effectiveness": {
      "type": "object",
      "description": "门禁有效性度量 — cc-review/cc-fix 时记录",
      "properties": {
        "gates_triggered": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gate_id", "blocked"],
            "properties": {
              "gate_id": {
                "type": "string",
                "description": "门禁标识 (lens name / topic rule / script)"
              },
              "blocked": {
                "type": "boolean",
                "description": "是否阻止了命令继续"
              },
              "was_real_error": {
                "type": "boolean",
                "description": "cc-fix 确认是否为真实错误"
              },
              "finding_ids": {
                "type": "array",
                "items": {"type": "string"},
                "description": "关联的 finding ID 列表"
              }
            }
          }
        }
      }
    }
  }
}
