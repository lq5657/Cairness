#!/usr/bin/env python3
"""Cairness framework updater.

Pulls the latest Cairness release from the remote repository and updates the
system installation. Requires Python 3.9+ and git.

Usage:
    python3 cairn_update                   # auto-detect repo location
    python3 cairn_update --repo <path>      # specify repo path
"""

import os
import sys
import shutil
import subprocess
from pathlib import Path

MIN_PYTHON = (3, 9)
REMOTE_URL = "https://github.com/lq5657/Cairness.git"


def check_python():
    if sys.version_info < MIN_PYTHON:
        v = ".".join(map(str, MIN_PYTHON))
        sys.exit(f"Cairness requires Python {v}+ (current: {sys.version})")


def get_platform_paths():
    system = sys.platform
    home = Path.home()
    if system == "linux":
        return home / ".local" / "share" / "cairness"
    elif system == "darwin":
        return home / "Library" / "Application Support" / "cairness"
    elif system == "win32":
        local = os.environ.get("LOCALAPPDATA", str(home / "AppData" / "Local"))
        return Path(local) / "cairness"
    else:
        sys.exit(f"Unsupported platform: {system}")


def get_installed_version(data_dir: Path):
    vf = data_dir / "VERSION"
    if vf.exists():
        return vf.read_text().strip()
    return None


def find_repo():
    """Find the Cairness repo by searching upward for cairn-core/VERSION."""
    d = Path.cwd()
    while d != d.parent:
        if (d / "cairn-core" / "VERSION").exists() and (d / "cairn_install").exists():
            return d
        d = d.parent
    return None


def git_pull(repo: Path):
    result = subprocess.run(
        ["git", "pull", "origin", "main"],
        cwd=repo, capture_output=True, text=True
    )
    if result.returncode != 0:
        print(f"git pull failed: {result.stderr}")
        sys.exit(1)
    print(result.stdout.strip())


def git_clone(repo: Path):
    if repo.exists():
        shutil.rmtree(repo)
    result = subprocess.run(
        ["git", "clone", REMOTE_URL, str(repo)],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        print(f"git clone failed: {result.stderr}")
        sys.exit(1)
    print(f"Cloned to {repo}")


def update_system(data_dir: Path, repo: Path):
    core_src = repo / "cairn-core"
    if not core_src.exists():
        sys.exit(f"cairn-core/ not found in repo: {repo}")

    new_ver = (core_src / "VERSION").read_text().strip()
    old_ver = get_installed_version(data_dir)

    if old_ver == new_ver:
        print(f"Already up to date (v{old_ver}).")
        return

    print(f"Updating system installation: v{old_ver} → v{new_ver}")
    if data_dir.exists():
        shutil.rmtree(data_dir)
    shutil.copytree(core_src, data_dir)
    print(f"Updated to v{new_ver}.")


def main():
    check_python()

    repo_arg = None
    args = sys.argv[1:]
    for i, a in enumerate(args):
        if a == "--repo" and i + 1 < len(args):
            repo_arg = Path(args[i + 1])

    data_dir = get_platform_paths()

    if repo_arg:
        repo = repo_arg.resolve()
    else:
        repo = find_repo()

    if repo is None:
        print("Cairness repo not found. Cloning from remote...")
        clone_path = Path.home() / ".local" / "share" / "cairness-repo"
        git_clone(clone_path)
        repo = clone_path
    else:
        print(f"Found Cairness repo at: {repo}")
        git_pull(repo)

    update_system(data_dir, repo)

    print("\nDone. Run 'cc-cairn update' in your project directories to apply.")


if __name__ == "__main__":
    main()
