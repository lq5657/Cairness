#!/usr/bin/env python3
"""Validate optional Harness lifecycle event logs."""

from __future__ import annotations

import json
import sys
from pathlib import Path
from typing import Any

from harness_runtime.issues import Issue, add, issues_to_dicts
from harness_runtime.events import (
    CHANGE_ID_RE,
    validate_event,
)


def read(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def discover_event_logs(project_root: Path, inputs: list[Path]) -> list[Path]:
    logs: set[Path] = set()
    search_inputs = inputs or [project_root / ".cairness" / "changes"]
    for item in search_inputs:
        if item.is_file() and item.name == "events.jsonl":
            logs.add(item)
        elif item.is_dir():
            logs.update(path for path in item.rglob("events.jsonl") if ".claude" not in path.parts)
    return sorted(logs)


def _latest_meaningful_to(events: list[Any]) -> str | None:
    """The most recent event's ``transition.to`` that carries lifecycle signal.

    ``unchanged`` (cc-test/cc-discuss/cc-promote-audit) is a no-op marker that
    washes out the latest asserted state, so we skip it. Only well-formed events
    whose transition is a dict with a ``to`` value count — malformed lines are
    already flagged by E_EVENT00x and must not feed the consistency check (else
    E_EVENT020 would pile on behind a shape error).
    """
    latest: str | None = None
    for event in events:
        if not isinstance(event, dict):
            continue
        transition = event.get("transition")
        if not isinstance(transition, dict):
            continue
        to_state = transition.get("to")
        if isinstance(to_state, str) and to_state != "unchanged":
            latest = to_state
    return latest


# spec.md status <-> latest event transition.to compatibility.
# ``apply`` is a transient mid-cc-apply status (no command terminates in apply
# per COMMAND_TO); it is compatible with a latest event of propose or review so
# the check does not fire on every in-flight cc-apply. Any spec status not in
# this map (missing/malformed) opts out — pass silently (cc-schema-check owns
# spec frontmatter validation).
SPEC_STATUS_COMPATIBLE_EVENT_TO: dict[str, set[str]] = {
    "propose": {"propose"},
    "apply": {"propose", "review"},
    "review": {"review"},
    "done": {"done"},
}


def _parse_spec_status(spec_path: Path) -> str | None:
    """Read the ``status`` field from spec.md YAML frontmatter.

    Inlined (not imported from change_docs.parse_meta) deliberately: cc-event-check
    has no other reason to reach into change_docs, and parse_meta is typed/list-aware
    for a different caller surface. ~12 lines of frontmatter parsing is cheaper
    than a cross-module coupling for one field.
    """
    if not spec_path.exists():
        return None
    text = spec_path.read_text(encoding="utf-8")
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return None
    for line in lines[1:]:
        if line.strip() == "---":
            break
        if line.startswith("status:"):
            return line.split(":", 1)[1].strip()
    return None


def check_event_spec_consistency(path: Path, events: list[Any], issues: list[Issue]) -> None:
    """E_EVENT020: latest meaningful event transition.to must be compatible with spec.md status.

    Opt-in by file presence: only asserts when events.jsonl has at least one
    well-formed event AND a sibling spec.md exists with a parseable status.
    Absent events.jsonl (the framework repo, historical changes that never
    logged) → no assertion. This preserves the runtime-model opt-in policy.
    """
    latest_to = _latest_meaningful_to(events)
    if latest_to is None:
        return  # no well-formed lifecycle event recorded → nothing to assert
    spec_status = _parse_spec_status(path.parent / "spec.md")
    if spec_status is None:
        return  # no spec.md or no status → out of scope (cc-schema-check owns this)
    compatible = SPEC_STATUS_COMPATIBLE_EVENT_TO.get(spec_status)
    if compatible is None:
        return  # unrecognized spec status → don't double-report
    if latest_to not in compatible:
        add(issues, "E_EVENT020", path, f"events.jsonl latest non-unchanged transition.to is '{latest_to}' but spec.md status is '{spec_status}'")


def validate_log(path: Path, issues: list[Issue]) -> None:
    change_id = path.parent.name
    if not CHANGE_ID_RE.match(change_id):
        add(issues, "E_EVENT013", path, f"invalid change directory name {change_id}")
    previous_ids: set[str] = set()
    parsed_events: list[Any] = []
    for idx, raw_line in enumerate(read(path).splitlines(), start=1):
        line = raw_line.strip()
        if not line:
            continue
        try:
            event = json.loads(line)
        except json.JSONDecodeError as exc:
            add(issues, "E_EVENT014", path, f"line {idx}: invalid JSON: {exc}")
            continue
        parsed_events.append(event)
        event_id = event.get("event_id") if isinstance(event, dict) else None
        if isinstance(event_id, str):
            if event_id in previous_ids:
                add(issues, "E_EVENT015", path, f"line {idx}: duplicate event_id {event_id}")
            previous_ids.add(event_id)
        validate_event(path, idx, event, change_id, issues)
    # Event↔spec consistency is opt-in (only when events exist) and runs after
    # per-line validation so it never piles on behind shape errors.
    check_event_spec_consistency(path, parsed_events, issues)


def build_report(inputs: list[Path]) -> dict[str, Any]:
    claude_root = Path(__file__).resolve().parent.parent
    project_root = claude_root.parent
    issues: list[Issue] = []
    logs = discover_event_logs(project_root, inputs)
    for log in logs:
        validate_log(log, issues)
    return {
        "tool": "cc-event-check",
        "status": "failed" if issues else "passed",
        "checked_event_logs": [str(path) for path in logs],
        "issues": issues_to_dicts(issues),
    }


def main(argv: list[str]) -> int:
    json_output = "--json" in argv
    paths = [Path(arg) for arg in argv if arg != "--json"]
    report = build_report(paths)
    if json_output:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    elif report["status"] == "passed":
        print("cc-event-check: ok")
    else:
        for issue in report["issues"]:
            print(f"{issue['code']} {issue['path']}: {issue['message']}", file=sys.stderr)
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))

