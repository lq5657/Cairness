#!/usr/bin/env python3
"""cc-index-check — knowledge/index.md 格式与一致性检查。

检查 .cairness/knowledge/index.md 中的条目是否符合三元组格式
**关键词** : 描述 → 路径，并验证关键词唯一、路径存在、分类一致等。

退出码:
  0  ok 或仅 warn/info
  1  error（关键词重复、路径重复、路径不存在）
  2  脚本自身错误（index.md 缺失等）

用法:
  cc-index-check                 检查并以人类可读格式输出
  cc-index-check --json          JSON 格式输出
  cc-index-check --strict        warn 也算失败（CI 严格模式）
"""

from __future__ import annotations

import argparse
import json
import re
import sys
from collections import defaultdict
from pathlib import Path
from typing import Any


KNOWN_CATEGORIES_FALLBACK = {
    "domain-rules",
    "technical-conventions",
    "pitfalls",
    "module-guides",
    "decision-records",
    "data-assets",
    "non-functional",
    "external-references",
}
FORBIDDEN_IN_INDEX_FALLBACK = {"refinement-candidates"}
KNOWLEDGE_CATALOG_REL = "runtime/knowledge-categories.yaml"
HARNESS_REFERENCE_PREFIX = ".claude/"


def _load_catalog(root: Path) -> tuple[set[str], set[str]]:
    """Load (known_categories, forbidden_in_index) from runtime YAML or fall back."""
    candidates = [
        Path(__file__).resolve().parent.parent / KNOWLEDGE_CATALOG_REL,
        root / ".claude" / KNOWLEDGE_CATALOG_REL,
    ]
    catalog_path = next((c for c in candidates if c.is_file()), None)
    if catalog_path is None:
        return set(KNOWN_CATEGORIES_FALLBACK), set(FORBIDDEN_IN_INDEX_FALLBACK)
    try:
        import yaml  # type: ignore
    except ImportError:
        return set(KNOWN_CATEGORIES_FALLBACK), set(FORBIDDEN_IN_INDEX_FALLBACK)
    try:
        data = yaml.safe_load(catalog_path.read_text(encoding="utf-8"))
    except Exception:
        return set(KNOWN_CATEGORIES_FALLBACK), set(FORBIDDEN_IN_INDEX_FALLBACK)
    if not isinstance(data, dict):
        return set(KNOWN_CATEGORIES_FALLBACK), set(FORBIDDEN_IN_INDEX_FALLBACK)
    cats = data.get("categories")
    if not isinstance(cats, list) or not cats:
        return set(KNOWN_CATEGORIES_FALLBACK), set(FORBIDDEN_IN_INDEX_FALLBACK)
    known: set[str] = set()
    forbidden: set[str] = set()
    for c in cats:
        if not isinstance(c, dict):
            return set(KNOWN_CATEGORIES_FALLBACK), set(FORBIDDEN_IN_INDEX_FALLBACK)
        sub = c.get("subdir")
        if not isinstance(sub, str):
            return set(KNOWN_CATEGORIES_FALLBACK), set(FORBIDDEN_IN_INDEX_FALLBACK)
        if c.get("indexed"):
            known.add(sub)
        else:
            forbidden.add(sub)
    return known, forbidden

ENTRY_RE = re.compile(r"\*\*(.+?)\*\*\s*:\s*(.+)\s*→\s*(\S+)\s*$")
LOOSE_BOLD_LINE_RE = re.compile(r"\*\*[^*]+\*\*")
HEADING_RE = re.compile(r"^(#{1,6})\s+(.+)$")
SECTION_MARKER_RE = re.compile(r"\(([a-z][a-z0-9-]*)/\)")
HTML_COMMENT_RE = re.compile(r"<!--.*?-->", re.DOTALL)


def _is_in_inline_code(line: str, match_start: int) -> bool:
    """True if the match position falls inside an inline `…` span."""
    return line.count("`", 0, match_start) % 2 == 1


def project_root() -> Path:
    return Path(__file__).resolve().parent.parent.parent


def strip_comments(text: str) -> str:
    return HTML_COMMENT_RE.sub("", text)


def find_section_for_line(lines: list[str], lineno: int) -> str | None:
    """Return subdir marker for the nearest preceding heading, or None."""
    for i in range(lineno, -1, -1):
        m = HEADING_RE.match(lines[i])
        if m:
            sm = SECTION_MARKER_RE.search(m.group(2))
            if sm:
                return sm.group(1)
            return None
    return None


def lint_index(index_path: Path, project_root: Path) -> dict[str, Any]:
    known_categories, forbidden_in_index = _load_catalog(project_root)
    text = index_path.read_text(encoding="utf-8")
    cleaned = strip_comments(text)
    lines = cleaned.splitlines()
    raw_lines = text.splitlines()

    findings: list[dict[str, Any]] = []
    seen_keywords: dict[str, tuple[int, str]] = {}
    seen_paths: dict[str, int] = {}
    entry_count = 0

    in_fence = False
    for idx, line in enumerate(lines):
        stripped = line.strip()
        if stripped.startswith("```"):
            in_fence = not in_fence
            continue
        if in_fence:
            continue
        # Suspicious lines: bold + arrow → looks like a triple but malformed
        if "→" in line and LOOSE_BOLD_LINE_RE.search(line) and not ENTRY_RE.search(line):
            bold_pos = LOOSE_BOLD_LINE_RE.search(line).start()
            if _is_in_inline_code(line, bold_pos):
                continue
            findings.append({
                "level": "warn",
                "code": "format-broken",
                "line": idx + 1,
                "message": f"line has bold + arrow but doesn't match **kw** : desc → path: {stripped[:80]}",
            })
            continue

        m = ENTRY_RE.search(line)
        if not m:
            continue
        if _is_in_inline_code(line, m.start()):
            continue
        entry_count += 1
        keyword = m.group(1).strip()
        path = m.group(3).strip().rstrip("`")
        path = path.strip("`")

        # keyword duplicate
        if keyword in seen_keywords:
            prev_line, prev_path = seen_keywords[keyword]
            findings.append({
                "level": "error",
                "code": "keyword-duplicate",
                "line": idx + 1,
                "message": f"keyword '{keyword}' already used at line {prev_line} (path: {prev_path})",
            })
        else:
            seen_keywords[keyword] = (idx + 1, path)

        # path duplicate
        if path in seen_paths:
            findings.append({
                "level": "error",
                "code": "path-duplicate",
                "line": idx + 1,
                "message": f"path '{path}' already registered at line {seen_paths[path]}",
            })
        else:
            seen_paths[path] = idx + 1

        # path classification
        first_seg = path.split("/", 1)[0] if "/" in path else ""
        is_harness_ref = path.startswith(HARNESS_REFERENCE_PREFIX) or "`.claude/" in raw_lines[idx]
        if is_harness_ref:
            findings.append({
                "level": "info",
                "code": "harness-reference",
                "line": idx + 1,
                "message": f"cross-tree reference to {path} (allowed for Harness maintenance entries)",
            })
        elif first_seg in forbidden_in_index:
            findings.append({
                "level": "warn",
                "code": "forbidden-category",
                "line": idx + 1,
                "message": f"refinement-candidates/ should not appear in index.md: {path}",
            })
        elif first_seg not in known_categories:
            findings.append({
                "level": "warn",
                "code": "unknown-category",
                "line": idx + 1,
                "message": f"path's first segment '{first_seg}' is not a known category: {path}",
            })

        # path existence (skip harness references — `cc-knowledge-check` separately checks)
        if not is_harness_ref:
            target = project_root / ".cairness" / "knowledge" / path
            if not target.exists():
                findings.append({
                    "level": "error",
                    "code": "path-missing",
                    "line": idx + 1,
                    "message": f"file does not exist: .cairness/knowledge/{path}",
                })

        # category-section mismatch
        if first_seg in known_categories:
            section_subdir = find_section_for_line(lines, idx)
            if section_subdir is not None and section_subdir != first_seg:
                findings.append({
                    "level": "warn",
                    "code": "category-section-mismatch",
                    "line": idx + 1,
                    "message": f"entry path is under '{first_seg}/' but placed in section '({section_subdir}/)'",
                })

    summary = defaultdict(int)
    for f in findings:
        summary[f["level"]] += 1

    return {
        "index_path": str(index_path),
        "entry_count": entry_count,
        "findings": findings,
        "summary": dict(summary),
    }


def main() -> int:
    parser = argparse.ArgumentParser(description="knowledge/index.md format & consistency check")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--strict", action="store_true", help="treat warn as failure")
    parser.add_argument("--root", help="override project root")
    args = parser.parse_args()

    root = Path(args.root).resolve() if args.root else project_root()
    index_path = root / ".cairness" / "knowledge" / "index.md"

    if not index_path.is_file():
        print(f"cc-index-check: error: index.md not found at {index_path}", file=sys.stderr)
        return 2

    result = lint_index(index_path, root)

    if args.json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        s = result["summary"]
        e_count = s.get("error", 0)
        w_count = s.get("warn", 0)
        i_count = s.get("info", 0)
        print(
            f"cc-index-check: {result['entry_count']} entries, "
            f"{e_count} error, {w_count} warn, {i_count} info"
        )
        if result["findings"]:
            print()
            for f in result["findings"]:
                tag = f["level"].upper()
                print(f"  {tag:5s} L{f['line']:<4d} [{f['code']}] {f['message']}")

    if result["summary"].get("error", 0) > 0:
        return 1
    if args.strict and result["summary"].get("warn", 0) > 0:
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
