#!/usr/bin/env python3
"""Dirty-worktree write-scope checks for cc-* command contracts."""

from __future__ import annotations

import argparse
import fnmatch
import json
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path
from typing import Any

from harness_runtime import require_yaml

BASELINE_FILENAME = "role-baseline.json"


ABSTRACT_WRITE_PATTERNS = {
    "task_declared_code_files",
    "finding_related_code_files",
    "business_code_changes",
    "test_files",
    "fixed_code",
    "change_docs_update",
    "synced_change_docs",
    "tests_or_evidence",
    "change_docs_update",
    "change_docs_update_if_needed",
    "task_board_update",
    "updated_findings",
    "task_board_archive_state",
    "optional_commits",
    "optional_knowledge",
    "structured_preflight_result",
}


def run_git(project_root: Path, args: list[str]) -> list[str]:
    completed = subprocess.run(
        ["git", "-C", str(project_root), *args],
        text=True,
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        raise RuntimeError(completed.stderr.strip() or completed.stdout.strip() or "git command failed")
    return [line.strip() for line in completed.stdout.splitlines() if line.strip()]


def dirty_paths(project_root: Path) -> list[str]:
    paths: set[str] = set()
    for args in (
        ["diff", "--name-only", "--relative", "--", "."],
        ["diff", "--cached", "--name-only", "--relative", "--", "."],
        ["ls-files", "--others", "--exclude-standard", "--", "."],
    ):
        for path in run_git(project_root, args):
            paths.add(path)
    return sorted(paths)


def baseline_path(project_root: Path, change_id: str) -> Path:
    return project_root / ".cairness" / "changes" / change_id / "baseline" / BASELINE_FILENAME


def load_baseline(path: Path) -> list[str]:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return []
    if not isinstance(data, dict) or "dirty_paths" not in data:
        return []
    return [str(p) for p in data["dirty_paths"]]


def save_baseline(path: Path, dirty: list[str]) -> None:
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(
            json.dumps({"dirty_paths": dirty, "saved_at": datetime.now().isoformat()}, indent=2),
            encoding="utf-8",
        )
    except OSError:
        pass


def reset_baseline(path: Path) -> bool:
    try:
        path.unlink()
        return True
    except FileNotFoundError:
        return True
    except OSError:
        return False


def parse_inline_list(raw: str) -> list[str]:
    value = raw.strip()
    if value == "[]":
        return []
    if not value.startswith("[") or not value.endswith("]"):
        return []
    body = value[1:-1].strip()
    if not body:
        return []
    return [item.strip().strip('"').strip("'") for item in body.split(",")]


def parse_workflow_commands(text: str) -> dict[str, str]:
    match = re.search(r"^commands:\s*\n(?P<body>.*)\Z", text, re.S | re.M)
    if not match:
        return {}
    body = match.group("body")
    matches = list(re.finditer(r"^  (cc-[a-z0-9-]+):\s*$", body, re.M))
    blocks: dict[str, str] = {}
    for idx, item in enumerate(matches):
        start = item.end()
        end = matches[idx + 1].start() if idx + 1 < len(matches) else len(body)
        blocks[item.group(1)] = body[start:end]
    return blocks


def parse_key_value(block: str, key: str) -> str | None:
    match = re.search(rf"^\s+{re.escape(key)}:\s*(.*?)\s*$", block, re.M)
    return match.group(1).strip() if match else None


def _load_manifest_writes(claude_root: Path, command: str) -> list[str] | None:
    """Read the `writes` list from the command's runtime manifest.

    Returns None if the manifest cannot be resolved/loaded (caller falls back
    to workflow during the A1 transition). The manifest is the SSOT for write
    scope; this is the authoritative source going forward.
    """
    project_root = claude_root.parent
    core_path = claude_root / "runtime" / "core.yaml"
    if not core_path.exists():
        return None
    yaml = require_yaml()
    try:
        core = yaml.safe_load(core_path.read_text(encoding="utf-8"))
    except Exception:
        return None
    if not isinstance(core, dict):
        return None
    runtime_commands = core.get("runtime_commands")
    if not isinstance(runtime_commands, dict):
        return None
    declared = runtime_commands.get(command)
    if not isinstance(declared, str):
        return None
    manifest_path = project_root / declared if declared.startswith(".claude/") else None
    if manifest_path is None or not manifest_path.exists():
        return None
    try:
        manifest = yaml.safe_load(manifest_path.read_text(encoding="utf-8"))
    except Exception:
        return None
    if not isinstance(manifest, dict):
        return None
    writes = manifest.get("writes")
    if not isinstance(writes, list):
        return None
    return [w for w in writes if isinstance(w, str)]


def load_command_writes(claude_root: Path, command: str) -> tuple[list[str], bool]:
    # Manifest is the SSOT for write scope (A1). Prefer it; fall back to the
    # generated workflow view only if the manifest can't be resolved (e.g.
    # core.yaml unreadable / PyYAML missing) so the write-permission gate
    # never silently degrades to "allow all".
    writes = _load_manifest_writes(claude_root, command)
    if writes is None:
        writes = _load_workflow_writes(claude_root, command)
    has_abstract = any(item in ABSTRACT_WRITE_PATTERNS for item in writes)
    concrete: list[str] = []
    for item in writes:
        if item in ABSTRACT_WRITE_PATTERNS:
            continue
        concrete.append(concretize_pattern(item))
    return concrete, has_abstract


def _load_workflow_writes(claude_root: Path, command: str) -> list[str]:
    workflow_path = claude_root / "workflows" / "cc-workflow.yaml"
    if not workflow_path.exists():
        raise RuntimeError(f"{workflow_path} not found")
    blocks = parse_workflow_commands(workflow_path.read_text(encoding="utf-8"))
    if command not in blocks:
        raise RuntimeError(f"{command} not defined in workflow")
    writes_value = parse_key_value(blocks[command], "writes")
    if writes_value is None:
        raise RuntimeError(f"{command} missing writes field")
    return parse_inline_list(writes_value)


def concretize_pattern(pattern: str) -> str:
    if pattern.startswith(".claude/") or pattern.startswith(".cairness/"):
        return pattern
    state_relative_prefixes = (
        "changes/",
        "context/",
        "audits/",
        "knowledge/",
    )
    if pattern.startswith(state_relative_prefixes):
        return f".cairness/{pattern}"
    claude_relative_prefixes = (
        "rules/",
        "schemas/",
        "scripts/",
        "skills/",
        "workflows/",
        "runtime/",
        "evals/",
        "CHANGELOG.md",
        "UPGRADE.md",
        "VERSION",
        "harness.config.yaml",
    )
    if pattern.startswith(claude_relative_prefixes):
        return f".claude/{pattern}"
    return pattern


def expand(pattern: str, change_id: str | None) -> str:
    return pattern.replace("<change-id>", change_id or "")


def is_allowed(path: str, patterns: list[str], change_id: str | None) -> bool:
    expanded = [expand(pattern, change_id) for pattern in patterns]
    return any(fnmatch.fnmatch(path, pattern) for pattern in expanded)


def build_report(command: str, change_id: str | None, project_root: Path) -> dict[str, Any]:
    claude_root = project_root / ".claude"
    patterns, has_abstract = load_command_writes(claude_root, command)
    if any("<change-id>" in pattern for pattern in patterns) and not change_id:
        return {
            "tool": "cc-role-check",
            "status": "failed",
            "reason": f"{command} requires --change",
            "dirty_paths": [],
            "violations": [{"code": "E_ROLE001", "path": "", "message": "missing --change"}],
        }
    if has_abstract:
        return {
            "tool": "cc-role-check",
            "status": "skipped",
            "reason": f"{command} has task-dependent or abstract write scope",
            "allowed": [expand(pattern, change_id) for pattern in patterns],
            "dirty_paths": [],
            "violations": [],
        }
    paths = dirty_paths(project_root)
    previous_paths: list[str] = []
    if change_id:
        bp = baseline_path(project_root, change_id)
        previous_paths = load_baseline(bp)
    new_paths = [p for p in paths if p not in previous_paths]
    violations = [
        {"code": "E_ROLE002", "path": path, "message": f"{command} may not write this path"}
        for path in new_paths
        if not is_allowed(path, patterns, change_id)
    ]
    if change_id:
        save_baseline(baseline_path(project_root, change_id), paths)
    return {
        "tool": "cc-role-check",
        "status": "failed" if violations else "passed",
        "command": command,
        "change_id": change_id or "",
        "allowed": [expand(pattern, change_id) for pattern in patterns],
        "dirty_paths": new_paths,
        "violations": violations,
    }


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Check dirty worktree against cc-* command write scope.")
    parser.add_argument("--command", help="cc-* command, for example cc-review.")
    parser.add_argument("--change", help="Formal change-id when the command is change-scoped.")
    parser.add_argument("--project-root", help="Project root. Defaults to parent of .claude.")
    parser.add_argument("--json", action="store_true", help="Emit JSON report.")
    parser.add_argument("--reset-baseline", action="store_true", help="Clear the role baseline for --change.")
    args = parser.parse_args(argv)

    claude_root = Path(__file__).resolve().parent.parent
    project_root = Path(args.project_root) if args.project_root else claude_root.parent

    if args.reset_baseline:
        if not args.change:
            report = {
                "tool": "cc-role-check",
                "status": "failed",
                "reason": "--reset-baseline requires --change",
                "violations": [{"code": "E_ROLE001", "path": "", "message": "missing --change for --reset-baseline"}],
            }
            print(json.dumps(report, ensure_ascii=False, indent=2) if args.json else "cc-role-check: --reset-baseline requires --change", file=sys.stderr)
            return 1
        bp = baseline_path(project_root, args.change)
        ok = reset_baseline(bp)
        if ok:
            print(f"cc-role-check: baseline reset for {args.change}")
            return 0
        print(f"cc-role-check: failed to reset baseline for {args.change}", file=sys.stderr)
        return 1

    if not args.command:
        report = {
            "tool": "cc-role-check",
            "status": "failed",
            "reason": "--command is required (unless using --reset-baseline)",
            "violations": [{"code": "E_ROLE003", "path": "", "message": "missing --command"}],
        }
        print(json.dumps(report, ensure_ascii=False, indent=2) if args.json else "cc-role-check: --command is required", file=sys.stderr)
        return 1
    try:
        report = build_report(args.command, args.change, project_root)
    except RuntimeError as exc:
        report = {
            "tool": "cc-role-check",
            "status": "failed",
            "reason": str(exc),
            "violations": [{"code": "E_ROLE003", "path": "", "message": str(exc)}],
        }

    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    elif report["status"] == "passed":
        print("cc-role-check: ok")
    elif report["status"] == "skipped":
        print(f"cc-role-check: skipped ({report['reason']})")
    else:
        for violation in report.get("violations", []):
            print(f"{violation['code']} {violation['path']}: {violation['message']}", file=sys.stderr)
    return 1 if report["status"] == "failed" else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
