{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/command-protocol.schema.json",
  "title": "Agent Command Protocol",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "protocol_id",
    "summary",
    "command_flow",
    "path_roles",
    "input_contracts",
    "error_taxonomy",
    "result_rendering",
    "language_profile"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "protocol_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "command_flow": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/snakeId"
      }
    },
    "path_roles": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/snakeId"
      },
      "additionalProperties": {
        "$ref": "#/$defs/pathRole"
      }
    },
    "input_contracts": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/snakeId"
      },
      "additionalProperties": {
        "$ref": "#/$defs/inputContract"
      }
    },
    "error_taxonomy": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/snakeId"
      },
      "additionalProperties": {
        "$ref": "#/$defs/errorContract"
      }
    },
    "result_rendering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success_template", "error_template"],
      "properties": {
        "success_template": {
          "type": "string",
          "pattern": "^\\.claude/templates/results/.+\\.md$"
        },
        "error_template": {
          "type": "string",
          "pattern": "^\\.claude/templates/results/.+\\.md$"
        }
      }
    },
    "language_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default", "profiles"],
      "properties": {
        "default": {
          "$ref": "#/$defs/snakeId"
        },
        "profiles": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/snakeId"
          },
          "additionalProperties": {
            "type": "string",
            "pattern": "^\\.claude/runtime/languages/[a-z0-9_-]+\\.yaml$"
          }
        }
      }
    }
  },
  "$defs": {
    "snakeId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "pathRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["file", "dir"]
        }
      }
    },
    "inputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "missing_error", "invalid_error"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "enum"]
        },
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "resolves_to": {
          "$ref": "#/$defs/snakeId"
        },
        "missing_error": {
          "$ref": "#/$defs/snakeId"
        },
        "invalid_error": {
          "$ref": "#/$defs/snakeId"
        }
      }
    },
    "errorContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "blocking"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "blocked", "partial"]
        },
        "blocking": {
          "type": "boolean"
        }
      }
    }
  }
}

