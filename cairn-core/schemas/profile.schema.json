{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/profile.schema.json",
  "title": "cc_spec Harness Runtime Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "description", "topic_rules", "subagents", "validation", "interaction"],
  "properties": {
    "id": {
      "type": "string",
      "enum": ["minimal", "standard", "strict", "loop"]
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "topic_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["always", "conditional", "disabled"],
      "properties": {
        "always": {
          "type": "array",
          "items": {"type": "string"}
        },
        "conditional": {
          "oneOf": [
            {"type": "string", "const": "all"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "disabled": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "subagents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "extra_validation": {"type": "boolean"}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "run_on"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["harness_only", "full"]
        },
        "run_on": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "interaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skip_technology_confirmations",
        "skip_task_split_confirmations",
        "accept_recommended_defaults"
      ],
      "properties": {
        "skip_technology_confirmations": {"type": "boolean"},
        "skip_task_split_confirmations": {"type": "boolean"},
        "accept_recommended_defaults": {"type": "boolean"},
        "require_written_risk_acceptance_for_accepted_findings": {"type": "boolean"}
      }
    },
    "wave_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "max_parallel": {"type": "integer", "minimum": 1},
        "join_timeout_ms": {"type": "integer", "minimum": 1},
        "cleanup_timeout_ms": {"type": "integer", "minimum": 1},
        "double_confirmation": {"type": "boolean"}
      }
    },
    "loop_mode": {
      "type": "object",
      "description": "Loop Engineering configuration — only used when id=loop",
      "additionalProperties": false,
      "required": ["trust_envelope_required", "gate_overrides", "circuit_breakers"],
      "properties": {
        "trust_envelope_required": {"type": "boolean"},
        "trust_envelope_path": {"type": "string"},
        "gate_overrides": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hard_gate_confirm": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode"],
              "properties": {
                "mode": {"type": "string", "enum": ["self_eval", "interactive"]},
                "handler": {"type": "string"},
                "escalate_on_fail": {"type": "boolean"},
                "audit": {"type": "boolean"}
              }
            },
            "finding_accepted": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode"],
              "properties": {
                "mode": {"type": "string", "enum": ["auto_disposition", "interactive"]},
                "auto_accept_severity_threshold": {"type": "string"},
                "always_escalate_severity": {"type": "array", "items": {"type": "string"}}
              }
            },
            "archive_done": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode"],
              "properties": {
                "mode": {"type": "string", "enum": ["auto_archive", "interactive"]},
                "knowledge_compounding_default": {"type": "string"}
              }
            }
          }
        },
        "circuit_breakers": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean"},
            "output_dir": {"type": "string"},
            "file_pattern": {"type": "string"}
          }
        }
      }
    }
  }
}
