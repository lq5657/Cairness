#!/usr/bin/env python3
"""Cairness framework installer.

Installs the cairn-core/ framework to a system location and registers the
cc-cairn CLI command. Requires Python 3.9+.

Usage:
    python3 cairn_install
"""

import os
import sys
import shutil
import stat
import subprocess
from pathlib import Path

MIN_PYTHON = (3, 9)

REPO_ROOT = Path(__file__).resolve().parent
CORE_SRC = REPO_ROOT / "cairn-core"
VERSION_FILE = CORE_SRC / "VERSION"
SCRIPTS_DIR = CORE_SRC / "scripts"
if str(SCRIPTS_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPTS_DIR))

from harness_runtime.versioning import VersionMetadataError, read_version

# Patterns excluded from every ship copy (system install + project init/update).
# Dev-local or build artifacts that must never reach a target project:
#   __pycache__/ + *.pyc  — Python bytecode (incl. malformed names produced by
#                          extension-less scripts such as `cc-eval`)
#   node_modules/         — JS deps bundled inside fixture samples
#   settings.local.json   — the developer's local Claude Code permission whitelist
# Keep in sync with SHIP_IGNORE in cairn-core/cc-cairn.py.
SHIP_IGNORE = shutil.ignore_patterns(
    "__pycache__", "*.pyc", "node_modules", "settings.local.json",
)


def check_python():
    if sys.version_info < MIN_PYTHON:
        v = ".".join(map(str, MIN_PYTHON))
        sys.exit(f"Cairness requires Python {v}+ (current: {sys.version})")


def get_platform_paths():
    """Return (data_dir, bin_dir) for the current platform."""
    system = sys.platform
    home = Path.home()

    if system == "linux":
        data_dir = home / ".local" / "share" / "cairness"
        bin_dir = home / ".local" / "bin"
    elif system == "darwin":
        data_dir = home / "Library" / "Application Support" / "cairness"
        bin_dir = Path("/usr/local/bin")
    elif system == "win32":
        data_dir = Path(os.environ.get("LOCALAPPDATA", home / "AppData" / "Local")) / "cairness"
        bin_dir = data_dir  # cc-cairn.cmd goes alongside core
    else:
        sys.exit(f"Unsupported platform: {system}")

    return data_dir, bin_dir


def install_core(data_dir: Path):
    backup = None
    if data_dir.exists():
        # Back up the previous install before replacing it, so a failed or
        # interrupted install never leaves the system without a working copy.
        backup = data_dir.with_name(data_dir.name + ".bak")
        if backup.exists():
            shutil.rmtree(backup)
        os.rename(data_dir, backup)

    try:
        shutil.copytree(CORE_SRC, data_dir, ignore=SHIP_IGNORE)
    except Exception:
        # Restore the backup if the fresh copy failed.
        if backup is not None and backup.exists():
            if data_dir.exists():
                shutil.rmtree(data_dir, ignore_errors=True)
            os.rename(backup, data_dir)
        raise

    # Record git commit hash for future update comparisons
    result = subprocess.run(
        ["git", "rev-parse", "HEAD"],
        cwd=REPO_ROOT, capture_output=True, text=True
    )
    if result.returncode == 0:
        (data_dir / "COMMIT").write_text(result.stdout.strip() + "\n")

    if backup is not None and backup.exists():
        print(f"  Previous install backed up to: {backup}")
    print(f"Installed framework core to: {data_dir}")


def install_cli(data_dir: Path, bin_dir: Path):
    bin_dir.mkdir(parents=True, exist_ok=True)

    if sys.platform == "win32":
        cli_path = bin_dir / "cc-cairn.cmd"
        cli_content = (
            f'@echo off\r\n'
            f'python "{data_dir / "cc-cairn.py"}" %*\r\n'
        )
    else:
        cli_path = bin_dir / "cc-cairn"
        cli_content = (
            f'#!/bin/sh\n'
            f'exec python3 "{data_dir / "cc-cairn.py"}" "$@"\n'
        )

    cli_path.write_text(cli_content)
    if sys.platform != "win32":
        cli_path.chmod(cli_path.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)

    print(f"Installed CLI to: {cli_path}")


def check_path(bin_dir: Path):
    paths = os.environ.get("PATH", "").split(os.pathsep)
    if str(bin_dir) not in paths:
        print()
        print(f"WARNING: {bin_dir} is not in your PATH.")
        print("Add it to your shell profile to use the 'cc-cairn' command:")
        if sys.platform == "linux":
            print(f'  echo \'export PATH="${{PATH}}:{bin_dir}"\' >> ~/.bashrc')
        elif sys.platform == "darwin":
            print(f'  echo \'export PATH="${{PATH}}:{bin_dir}"\' >> ~/.zshrc')
        print()


def main():
    check_python()

    try:
        version = read_version(VERSION_FILE)
    except VersionMetadataError as exc:
        sys.exit(f"Invalid Cairness release metadata: {exc}")
    print(f"Cairness v{version} installer")
    print(f"Python {sys.version}")
    print()

    data_dir, bin_dir = get_platform_paths()

    install_core(data_dir)
    install_cli(data_dir, bin_dir)
    check_path(bin_dir)

    print("Done. Use 'cc-cairn init' in a project directory to get started.")


if __name__ == "__main__":
    main()
