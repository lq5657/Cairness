{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spec.local/schemas/runtime-core.schema.json",
  "title": "cc_spec Harness Runtime Core",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "runtime_id",
    "workflow_definition",
    "migrated_commands",
    "runtime_commands",
    "runtime_roles",
    "runtime_readsets",
    "runtime_protocol",
    "legacy_fallback",
    "governance",
    "scripts",
    "topic_rules",
    "default_runtime_rules"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "runtime_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "workflow_definition": {
      "type": "string",
      "pattern": "^core://workflows/.+\\.yaml$"
    },
    "migrated_commands": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/ccCommand"
      }
    },
    "workflow_order": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ccCommand"
      }
    },
    "runtime_commands": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/ccCommand"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^core://runtime/commands/cc-[a-z0-9-]+\\.yaml$"
      }
    },
    "runtime_roles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "schema"],
      "properties": {
        "manifest": {
          "type": "string",
          "pattern": "^core://runtime/roles\\.yaml$"
        },
        "schema": {
          "type": "string",
          "pattern": "^core://schemas/runtime-roles\\.schema\\.json$"
        }
      }
    },
    "runtime_readsets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dir", "index", "schema"],
      "properties": {
        "dir": {
          "type": "string",
          "pattern": "^core://runtime/readsets$"
        },
        "index": {
          "type": "string",
          "pattern": "^core://runtime/readsets/index\\.yaml$"
        },
        "schema": {
          "type": "string",
          "pattern": "^core://schemas/runtime-readset\\.schema\\.json$"
        }
      }
    },
    "runtime_protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "technology_decisions", "language_profile", "schema", "default_language_profile"],
      "properties": {
        "protocol": {
          "type": "string",
          "pattern": "^core://runtime/protocol\\.yaml$"
        },
        "technology_decisions": {
          "type": "string",
          "pattern": "^core://runtime/protocol/technology-decisions\\.yaml$"
        },
        "language_profile": {
          "type": "string",
          "pattern": "^core://runtime/protocol/language-profile\\.yaml$"
        },
        "schema": {
          "type": "string",
          "pattern": "^core://schemas/command-protocol\\.schema\\.json$"
        },
        "default_language_profile": {
          "type": "string",
          "pattern": "^core://runtime/languages/[a-z0-9_-]+\\.yaml$"
        }
      }
    },
    "legacy_fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands_dir", "checkpoints_dir"],
      "properties": {
        "commands_dir": {
          "type": "string"
        },
        "checkpoints_dir": {
          "type": "string"
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_board", "dev_map", "memory_policy", "subagent_policy"],
      "properties": {
        "task_board": {
          "type": "string"
        },
        "dev_map": {
          "type": "string"
        },
        "memory_policy": {
          "type": "string"
        },
        "subagent_policy": {
          "type": "string"
        }
      }
    },
    "scripts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verify", "delta", "role", "eval", "readset", "doctor", "event", "behavior", "upgrade"],
      "properties": {
        "verify": {
          "type": "string"
        },
        "delta": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "eval": {
          "type": "string"
        },
        "readset": {
          "type": "string"
        },
        "doctor": {
          "type": "string"
        },
        "event": {
          "type": "string"
        },
        "event-write": {
          "type": "string"
        },
        "state-transition": {
          "type": "string"
        },
        "behavior": {
          "type": "string"
        },
        "upgrade": {
          "type": "string"
        },
        "topic-trigger": {
          "type": "string"
        },
        "stats": {
          "type": "string"
        },
        "knowledge-check": {
          "type": "string"
        },
        "budget-check": {
          "type": "string"
        },
        "deps": {
          "type": "string"
        },
        "wave-plan": {
          "type": "string"
        },
        "gate-stats": {
          "type": "string"
        },
        "benchmark": {
          "type": "string"
        },
        "context-pack": {
          "type": "string"
        },
        "help": {
          "type": "string"
        },
        "adapter-check": {
          "type": "string"
        }
      }
    },
    "topic_rules": {
      "type": "object",
      "minProperties": 1,
      "required": [
        "verification",
        "testing_strategy",
        "change_sizing",
        "coding_style",
        "debugging_workflow",
        "database_changes",
        "api_compatibility",
        "configuration",
        "observability",
        "release",
        "security",
        "source_driven_development",
        "git_workflow",
        "interaction_guidance"
      ],
      "propertyNames": {
        "$ref": "#/$defs/snakeId"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^core://runtime/topic-rules/.+\\.(md|yaml)$"
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dir", "default", "active_resolution"],
      "properties": {
        "dir": {
          "type": "string",
          "pattern": "^core://runtime/profiles$"
        },
        "default": {
          "type": "string",
          "enum": ["minimal", "standard", "strict"]
        },
        "active_resolution": {
          "type": "string",
          "enum": ["harness_config_profile_field"]
        }
      }
    },
    "default_runtime_rules": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/snakeId"
      }
    }
  },
  "$defs": {
    "ccCommand": {
      "type": "string",
      "pattern": "^cc-[a-z0-9-]+$"
    },
    "snakeId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    }
  }
}
