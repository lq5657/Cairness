#!/usr/bin/env bash
# cc-self-eval: Self-evaluation gate for Loop Engineering mode
# Usage: cc-self-eval --command <command> --change-id <id> [--decision] [--verbose]
#
# Returns (the default first line preserves the historical APPROVED/ESCALATE
# output; --decision adds the machine-readable decision line):
#   0 + "APPROVED" [and DECISION: autonomous|supervised|staged]
#   1 + "ESCALATE: <reason>" [and DECISION: *_approval_required|blocked]
#   2 + error message - configuration or runtime error

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Allow tests (or CI) to override the project root via env var.
# Default: two levels up from scripts/ → cairn-core/../ = project root.
PROJECT_ROOT="${CAIRNESS_PROJECT_ROOT:-$(cd "$SCRIPT_DIR/../.." && pwd)}"

# Default values
COMMAND=""
CHANGE_ID=""
VERBOSE=false
DECISION_OUTPUT=false
LOOP_CONFIG="$PROJECT_ROOT/.cairness/loop-config.yaml"
SPEC_FILE=""
SCOPE_OVERAGE_MODE="supervised"
RISK_OVERAGE_MODE="staged"

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --command)
      COMMAND="$2"
      shift 2
      ;;
    --change-id)
      CHANGE_ID="$2"
      shift 2
      ;;
    --verbose)
      VERBOSE=true
      shift
      ;;
    --decision)
      DECISION_OUTPUT=true
      shift
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ -z "$COMMAND" || -z "$CHANGE_ID" ]]; then
  echo "Error: --command and --change-id are required" >&2
  echo "Usage: cc-self-eval --command <command> --change-id <id> [--decision] [--verbose]" >&2
  exit 2
fi

SPEC_FILE="$PROJECT_ROOT/.cairness/changes/$CHANGE_ID/spec.md"

# Check if loop config exists
if [[ ! -f "$LOOP_CONFIG" ]]; then
  echo "Error: Loop config not found at $LOOP_CONFIG" >&2
  echo "Run: cp .claude/templates/loop-config.yaml .cairness/loop-config.yaml" >&2
  exit 2
fi

# Check if spec exists
if [[ ! -f "$SPEC_FILE" ]]; then
  echo "Error: Spec file not found at $SPEC_FILE" >&2
  exit 2
fi

# Logging helper
log_verbose() {
  if [[ "$VERBOSE" == "true" ]]; then
    echo "[cc-self-eval] $*" >&2
  fi
}

# Extract YAML field using grep/sed (no PyYAML dependency).
# Matches both top-level and indented keys (e.g. fields under trust_envelope:).
extract_yaml_field() {
  local file="$1"
  local field="$2"
  grep -E "[[:space:]]*${field}:" "$file" | head -1 | sed "s/.*${field}:[[:space:]]*//"
}

# Extract YAML array items for a given field (top-level or indented).
extract_yaml_array() {
  local file="$1"
  local field="$2"
  awk "/[[:space:]]*${field}:/,/^[^[:space:]-]/ { if (/^[[:space:]]+-[[:space:]]/) { sub(/^[[:space:]]+-[[:space:]]+/, \"\"); print } }" "$file"
}

# Extract a hard-gate field from the markdown confirmation section. Restricting
# the search to HARD-GATE prevents a similarly named note in a log/risk section
# from being mistaken for a user authorization. The templates use a full-width
# colon in prose fields.
extract_gate_field() {
  local file="$1"
  local field="$2"
  awk -v field="$field" '
    /HARD-GATE/ { in_gate = 1 }
    in_gate && $0 ~ field ".*(:|：)" { line = $0 }
    END { if (line != "") print line }
  ' "$file" \
    | sed -E 's/.*(:|：)[[:space:]]*//' \
    | sed -E 's/[`*_]//g' | xargs
}

has_human_gate_approval() {
  local status required required_lower status_lower field value
  required="$(extract_gate_field "$SPEC_FILE" "human_review_required")"
  status="$(extract_gate_field "$SPEC_FILE" "human_review_status")"
  required_lower="$(printf '%s' "$required" | tr '[:upper:]' '[:lower:]')"
  status_lower="$(printf '%s' "$status" | tr '[:upper:]' '[:lower:]')"
  [[ "$required_lower" == "true" && "$status_lower" == "approved" ]] || return 1

  for field in confirmed_at confirmed_by confirmed_spec_revision \
    confirmed_tasks_revision confirmed_scope resolved_risk_decisions \
    accepted_residual_risks; do
    value="$(extract_gate_field "$SPEC_FILE" "$field")"
    [[ -n "$value" ]] || return 1
  done
}

# Check if value is in array
in_array() {
  local needle="$1"
  shift
  local haystack=("$@")
  for item in "${haystack[@]}"; do
    if [[ "$item" == "$needle" ]]; then
      return 0
    fi
  done
  return 1
}

# Optional policy knobs keep existing loop configs valid while allowing a
# graduated response to bounded scope/risk overages. `blocked` restores the
# original binary behavior for teams that require it.
SCOPE_OVERAGE_MODE="$(extract_yaml_field "$LOOP_CONFIG" "scope_overage" || echo "supervised")"
RISK_OVERAGE_MODE="$(extract_yaml_field "$LOOP_CONFIG" "risk_overage" || echo "staged")"
for mode in "$SCOPE_OVERAGE_MODE" "$RISK_OVERAGE_MODE"; do
  case "$mode" in
    supervised|staged|blocked) ;;
    *)
      echo "Error: invalid Loop autonomy mode: $mode (expected supervised, staged, or blocked)" >&2
      exit 2
      ;;
  esac
done
# Risk overage intentionally has no "supervised" mode: a high residual risk
# must either be explicitly staged or remain fail-closed. Keep this check here
# as a defense-in-depth guard when an older config bypasses schema validation.
case "$RISK_OVERAGE_MODE" in
  staged|blocked) ;;
  *)
    echo "Error: invalid risk_overage mode: $RISK_OVERAGE_MODE (expected staged or blocked)" >&2
    exit 2
    ;;
esac

# Self-evaluation checklist
SCORE=0
MAX_SCORE=6
FAILURES=()
SCOPE_EXCEEDED=false
CRITICAL_RISK_EXCEEDED=false

log_verbose "Starting self-evaluation for $COMMAND / $CHANGE_ID"

# === Check 1: Change type within trust envelope ===
log_verbose "Check 1: Change type within trust envelope"

CHANGE_TYPE=$(extract_yaml_field "$SPEC_FILE" "change_type" || echo "")
if [[ -z "$CHANGE_TYPE" ]]; then
  FAILURES+=("change_type_missing_in_spec")
else
  # Read allowed and disallowed types from loop config
  DISALLOWED_TYPES=($(extract_yaml_array "$LOOP_CONFIG" "disallowed_change_types"))

  if in_array "$CHANGE_TYPE" "${DISALLOWED_TYPES[@]}"; then
    FAILURES+=("change_type_disallowed: $CHANGE_TYPE")
  else
    ALLOWED_TYPES=($(extract_yaml_array "$LOOP_CONFIG" "allowed_change_types"))
    if in_array "$CHANGE_TYPE" "${ALLOWED_TYPES[@]}"; then
      ((SCORE += 1))
      log_verbose "  ✓ Change type $CHANGE_TYPE is allowed"
    else
      FAILURES+=("change_type_not_in_allowed_list: $CHANGE_TYPE")
    fi
  fi
fi

# === Check 2: Scope within trust envelope ===
log_verbose "Check 2: Scope within trust envelope"

CHANGE_SIZE=$(extract_yaml_field "$SPEC_FILE" "change_size" || echo "")
MAX_SCOPE=$(extract_yaml_field "$LOOP_CONFIG" "max_scope" || echo "small")

# Returns ordinal rank for a scope size; 999 = unknown
size_rank() {
  case "$1" in
    micro)  echo 1 ;;
    small)  echo 2 ;;
    medium) echo 3 ;;
    large)  echo 4 ;;
    xlarge) echo 5 ;;
    *)      echo 999 ;;
  esac
}

if [[ -z "$CHANGE_SIZE" ]]; then
  FAILURES+=("change_size_missing_in_spec")
else
  CHANGE_RANK=$(size_rank "$CHANGE_SIZE")
  MAX_RANK=$(size_rank "$MAX_SCOPE")

  if [[ $CHANGE_RANK -le $MAX_RANK ]]; then
    ((SCORE += 1))
    log_verbose "  ✓ Change size $CHANGE_SIZE ≤ $MAX_SCOPE"
  else
    SCOPE_EXCEEDED=true
    FAILURES+=("scope_exceeds_envelope: $CHANGE_SIZE > $MAX_SCOPE")
  fi
fi

# === Check 3: All clarifications resolved ===
log_verbose "Check 3: Clarifications resolved"

OPEN_CLARIFICATIONS=$(grep -c "status: open" "$SPEC_FILE" || true)
if [[ $OPEN_CLARIFICATIONS -eq 0 ]]; then
  ((SCORE += 1))
  log_verbose "  ✓ No open clarifications"
else
  FAILURES+=("unresolved_clarifications: $OPEN_CLARIFICATIONS open")
fi

# === Check 4: Validation mapping complete ===
log_verbose "Check 4: Validation mapping complete"

# Check if validation_map section exists and has no 'gap' status
if grep -q "^## Validation Mapping" "$SPEC_FILE"; then
  GAP_COUNT=$(grep -c "| gap |" "$SPEC_FILE" || true)
  if [[ $GAP_COUNT -eq 0 ]]; then
    ((SCORE += 1))
    log_verbose "  ✓ Validation mapping complete (no gaps)"
  else
    FAILURES+=("validation_mapping_has_gaps: $GAP_COUNT gaps")
  fi
else
  FAILURES+=("validation_mapping_missing")
fi

# === Check 5: Residual risks within envelope ===
log_verbose "Check 5: Residual risks within envelope"

MAX_RISK=$(extract_yaml_field "$LOOP_CONFIG" "max_residual_risk" || echo "medium")

# Count high/critical risks in spec
HIGH_RISK_COUNT=$(grep -c "severity: high" "$SPEC_FILE" || true)
CRITICAL_RISK_COUNT=$(grep -c "severity: critical" "$SPEC_FILE" || true)

# Returns ordinal rank for a risk level; 999 = unknown
risk_rank() {
  case "$1" in
    low)      echo 1 ;;
    medium)   echo 2 ;;
    high)     echo 3 ;;
    critical) echo 4 ;;
    *)        echo 999 ;;
  esac
}

MAX_RISK_RANK=$(risk_rank "$MAX_RISK")

EXCEEDS_RISK=false
if [[ $MAX_RISK_RANK -lt 3 && $HIGH_RISK_COUNT -gt 0 ]]; then
  EXCEEDS_RISK=true
  FAILURES+=("residual_risk_exceeds_envelope: high risk > $MAX_RISK")
fi

if [[ $MAX_RISK_RANK -lt 4 && $CRITICAL_RISK_COUNT -gt 0 ]]; then
  EXCEEDS_RISK=true
  CRITICAL_RISK_EXCEEDED=true
  FAILURES+=("residual_risk_exceeds_envelope: critical risk > $MAX_RISK")
fi

if [[ "$EXCEEDS_RISK" == "false" ]]; then
  ((SCORE += 1))
  log_verbose "  ✓ Residual risks within envelope (≤ $MAX_RISK)"
fi

# === Check 6: No dependency conflicts ===
log_verbose "Check 6: Dependency check"

# Run cc-deps conflict check.
# Only treat exit code 1 (confirmed conflict) as failure.
# Exit code 2+ = script error (deps unavailable, no change found, etc.) → skip check.
CC_DEPS_CMD="${CC_DEPS_CMD:-$SCRIPT_DIR/cc-deps}"
CC_DEPS_RC=0
CC_DEPS_OUT=$("$CC_DEPS_CMD" conflicts --change "$CHANGE_ID" 2>&1) || CC_DEPS_RC=$?
if [[ $CC_DEPS_RC -eq 0 ]]; then
  ((SCORE += 1))
  log_verbose "  ✓ No dependency conflicts"
elif [[ $CC_DEPS_RC -eq 1 ]]; then
  FAILURES+=("dependency_conflict_detected")
else
  # Script error or change not found — do not penalise, award point with warning
  ((SCORE += 1))
  log_verbose "  ~ Dependency check skipped (cc-deps exit $CC_DEPS_RC): $CC_DEPS_OUT" >&2
fi

# === Compute confidence score ===
CONFIDENCE=$(awk "BEGIN {printf \"%.2f\", $SCORE / $MAX_SCORE}")

log_verbose "Self-eval score: $SCORE/$MAX_SCORE (confidence: $CONFIDENCE)"

# === Decision ===
THRESHOLD=0.7  # from loop profile

if [[ ${#FAILURES[@]} -eq 0 ]]; then
  echo "APPROVED"
  [[ "$DECISION_OUTPUT" == "true" ]] && echo "DECISION: autonomous"
  exit 0
fi

# Scope/risk overages can continue only after the current hard gate records a
# human approval. Unrelated blockers remain non-bypassable. This preserves the
# old fail-closed behavior when no approval exists while allowing a bounded,
# auditable supervised Loop transaction.
ONLY_BOUNDARY_FAILURES=true
for failure in "${FAILURES[@]}"; do
  case "$failure" in
    scope_exceeds_envelope:*|residual_risk_exceeds_envelope:*) ;;
    *) ONLY_BOUNDARY_FAILURES=false ;;
  esac
done

if [[ "$ONLY_BOUNDARY_FAILURES" == "true" && "$CRITICAL_RISK_EXCEEDED" == "false" ]]; then
  # Risk overage takes precedence over scope overage. A config that marks
  # risk overage blocked can never be bypassed by a scope approval.
  if [[ "$EXCEEDS_RISK" == "true" && "$RISK_OVERAGE_MODE" == "staged" ]]; then
    if has_human_gate_approval; then
      echo "APPROVED"
      [[ "$DECISION_OUTPUT" == "true" ]] && echo "DECISION: staged"
      exit 0
    else
      echo "ESCALATE: ${FAILURES[0]}"
      [[ "$DECISION_OUTPUT" == "true" ]] && echo "DECISION: staged_approval_required"
      exit 1
    fi
  elif [[ "$EXCEEDS_RISK" == "false" && "$SCOPE_EXCEEDED" == "true" && "$SCOPE_OVERAGE_MODE" == "supervised" ]]; then
    if has_human_gate_approval; then
      echo "APPROVED"
      [[ "$DECISION_OUTPUT" == "true" ]] && echo "DECISION: supervised"
      exit 0
    fi
    echo "ESCALATE: ${FAILURES[0]}"
    [[ "$DECISION_OUTPUT" == "true" ]] && echo "DECISION: supervised_approval_required"
    exit 1
  elif [[ "$EXCEEDS_RISK" == "false" && "$SCOPE_EXCEEDED" == "true" && "$SCOPE_OVERAGE_MODE" == "staged" ]]; then
    if has_human_gate_approval; then
      echo "APPROVED"
      [[ "$DECISION_OUTPUT" == "true" ]] && echo "DECISION: staged"
      exit 0
    fi
    echo "ESCALATE: ${FAILURES[0]}"
    [[ "$DECISION_OUTPUT" == "true" ]] && echo "DECISION: staged_approval_required"
    exit 1
  fi
fi

# Report first failure as a non-bypassable escalation.
REASON="${FAILURES[0]}"
echo "ESCALATE: $REASON"
[[ "$DECISION_OUTPUT" == "true" ]] && echo "DECISION: blocked"

if [[ "$VERBOSE" == "true" ]]; then
  echo "All failures:" >&2
  printf '  - %s\n' "${FAILURES[@]}" >&2
  echo "Score: $SCORE/$MAX_SCORE (confidence: $CONFIDENCE)" >&2
fi

exit 1
